{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiSettings": {
    "BaseUrl": "https://localhost:7274"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=FluxDb;Username=postgres;Password=YOUR_DATABASE_PASSWORD"
  },
  "Jwt": {
    "Key": "YOUR_PRODUCTION_JWT_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "FluxApp",
    "Audience": "FluxUsers",
    "ExpiryInMinutes": 60
  }
}
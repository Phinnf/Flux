@page "/invite/{code}"
@layout Layout.EmptyLayout
@using Flux.Infrastructure.Client
@inject WorkspaceClientService WorkspaceService
@inject NavigationManager Navigation
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<div class="flex justify-center items-center h-screen bg-gray-900 text-white">
    <div class="w-96 p-10 bg-gray-800 rounded-lg shadow-lg text-center">
        <div class="flex items-center justify-center gap-2 mb-8">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
            <h1 class="text-2xl font-extrabold text-white m-0">Flux</h1>
        </div>

        @if (_isLoading)
        {
            <div class="flex flex-col items-center">
                <div class="w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="mt-4 text-gray-400">Loading invitation details...</p>
            </div>
        }
        else if (_errorMessage != null)
        {
            <div class="bg-red-900/30 text-red-400 p-4 rounded mb-5">
                @_errorMessage
            </div>
            <button class="w-full px-4 py-2 border border-gray-500 rounded hover:bg-gray-700 transition-colors" @onclick='() => Navigation.NavigateTo("/")'>Return to Home</button>
        }
        else if (_inviteDetails != null)
        {
            <h2 class="text-xl mb-2 text-white">You've been invited!</h2>
            <p class="text-gray-400 mb-6">
                Join <strong>@_inviteDetails.WorkspaceName</strong> on Flux.
                @if (!string.IsNullOrEmpty(_inviteDetails.WorkspaceDescription))
                {
                    <br />
                    <span class="text-sm opacity-80">@_inviteDetails.WorkspaceDescription</span>
                }
            </p>

            <button class="w-full h-10 mb-4 px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700 transition-colors flex items-center justify-center gap-2" @onclick="JoinWorkspace" disabled="@_isJoining">
                @if (_isJoining)
                {
                    <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                }
                Accept Invitation
            </button>

            @if (!_isAuthenticated)
            {
                <p class="text-xs text-gray-400">
                    You need to be logged in to join. 
                    <a href="/auth?returnUrl=/invite/@Code" class="text-purple-400 font-bold hover:underline">Log in here</a>.
                </p>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public string Code { get; set; } = string.Empty;

    private bool _isLoading = true;
    private bool _isJoining = false;
    private string? _errorMessage;
    private InviteDetailsDto? _inviteDetails;
    private bool _isAuthenticated = false;
    private Guid _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;
        
        if (_isAuthenticated)
        {
            var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier) ?? authState.User.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                _currentUserId = id;
            }
        }

        var result = await WorkspaceService.GetInviteDetailsAsync(Code);
        
        if (result.IsSuccess)
        {
            _inviteDetails = result.Value;
            // Auto-join if authenticated and coming back from login
            if (_isAuthenticated && _currentUserId != Guid.Empty)
            {
                await JoinWorkspace();
            }
        }
        else
        {
            _errorMessage = result.Error;
        }

        _isLoading = false;
    }

    private async Task JoinWorkspace()
    {
        if (!_isAuthenticated || _currentUserId == Guid.Empty)
        {
            Navigation.NavigateTo($"/auth?returnUrl=/invite/{Code}");
            return;
        }

        _isJoining = true;
        _errorMessage = null;

        var result = await WorkspaceService.JoinWorkspaceViaInviteAsync(Code, _currentUserId);
        
        if (result.IsSuccess && result.Value != Guid.Empty)
        {
            Navigation.NavigateTo($"/workspace/{result.Value}");
        }
        else
        {
            _errorMessage = result.Error;
            _isJoining = false;
        }
    }
}
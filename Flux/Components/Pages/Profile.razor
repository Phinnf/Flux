@page "/profile"
@using Flux.Infrastructure.Client
@using Microsoft.AspNetCore.Components.Authorization
@inject FluxClientService FluxService
@inject WorkspaceStateService WorkspaceState
@inject NavigationManager Navigation
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Edit Profile - Flux</PageTitle>

<div class="slack-layout" style="font-family: 'Inter', sans-serif;">
    
    <!-- 1. Activity Bar (Matches Workspace) -->
    <div class="activity-bar">
        <div class="activity-top">
            <div class="workspace-icon-wrapper" @onclick='() => Navigation.NavigateTo("/workspaces")' title="Go to Workspaces">
                <div class="workspace-initial">@(string.IsNullOrEmpty(WorkspaceState.CurrentWorkspaceName) ? "F" : WorkspaceState.CurrentWorkspaceName[0].ToString().ToUpper())</div>
            </div>

            <div id="home-icon" class="activity-item" title="Home" @onclick="NavigateToFirstChannel">
                <FluentIcon Value="@(new Icons.Regular.Size24.Home())" Color="@Color.Custom" CustomColor="currentColor" />
            </div>

            <div id="dm-icon" class="activity-item" title="Direct Messages" @onclick='() => Navigation.NavigateTo("/dms")'>
                <FluentIcon Value="@(new Icons.Regular.Size24.Chat())" Color="@Color.Custom" CustomColor="currentColor" />
            </div>
        </div>
        
        <div style="flex-grow: 1;"></div>
        
        <div class="activity-bottom">
            <div id="profile-icon" class="activity-item active" title="Profile" style="margin-bottom: 12px; cursor: pointer;">
                <FluentPersona Status="PresenceStatus.Available" ImageSize="32px" Image="@_model.AvatarUrl" Initials="@_initials" />
            </div>
        </div>
    </div>

    <!-- 2. Profile Sidebar (Matches Workspace Sidebar) -->
    <div class="workspace-sidebar">
        <div class="sidebar-header">
            <div style="display: flex; align-items: center; gap: 12px;">
                <FluentIcon Value="@(new Icons.Filled.Size20.Settings())" Color="Color.Custom" CustomColor="currentColor" />
                <span style="font-size: 16px; font-weight: 700; color: inherit;">Settings</span>
            </div>
        </div>
        
        <div class="sidebar-scrollable" style="padding: 12px 8px;">
            <button class="profile-menu-item active">
                <FluentIcon Value="@(new Icons.Regular.Size20.Edit())" />
                <span>Edit profile</span>
            </button>
            <button class="profile-menu-item">
                <FluentIcon Value="@(new Icons.Regular.Size20.Alert())" />
                <span>Notification</span>
            </button>
            <button class="profile-menu-item">
                <FluentIcon Value="@(new Icons.Regular.Size20.LockClosed())" />
                <span>Security</span>
            </button>
            <button class="profile-menu-item">
                <FluentIcon Value="@(new Icons.Regular.Size20.Color())" />
                <span>Appearance</span>
            </button>
            <button class="profile-menu-item">
                <FluentIcon Value="@(new Icons.Regular.Size20.QuestionCircle())" />
                <span>Help</span>
            </button>
        </div>
    </div>

    <!-- 3. Main Content Area -->
    <div class="main-content profile-main-content">
        <div class="top-bar">
            <div class="top-bar-right">
                <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Custom" CustomColor="currentColor" />
                <FluentPersona Status="PresenceStatus.Available" ImageSize="36px" Image="@_model.AvatarUrl" Initials="@_initials" />
            </div>
        </div>

        <div class="profile-container">
            <div class="content-header">
                <h1>Edit profile</h1>
                <div class="avatar-upload">
                    <FluentPersona Status="PresenceStatus.Available" ImageSize="80px" Image="@_model.AvatarUrl" Initials="@_initials" />
                    <InputFile id="avatarUpload" OnChange="HandleAvatarUpload" style="display: none;" accept="image/*" />
                    <label for="avatarUpload" class="upload-btn">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Camera())" Color="Color.Custom" CustomColor="#fff" />
                    </label>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="loading-container">
                    <FluentProgressRing />
                </div>
            }
            else
            {
                <div class="glass-card profile-form">
                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text" @bind="_model.Username" class="glass-input form-input" />
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text" @bind="_model.FullName" class="glass-input form-input" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <div class="input-with-icon">
                            <input type="email" value="@_email" readonly class="glass-input form-input readonly-input" />
                            <FluentIcon Value="@(new Icons.Filled.Size20.CheckmarkCircle())" Color="Color.Success" class="input-icon" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Contact Number</label>
                        <input type="text" @bind="_model.NickName" class="glass-input form-input" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Country</label>
                            <div class="select-wrapper">
                                <select @bind="_model.Country" class="glass-input form-input select-input">
                                    <option value="">Select a country</option>
                                    <option value="USA">United States</option>
                                    <option value="UK">United Kingdom</option>
                                    <option value="Vietnam">Vietnam</option>
                                    <option value="Japan">Japan</option>
                                    <option value="Australia">Australia</option>
                                </select>
                                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" class="select-icon" />
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label>Status</label>
                            <div class="select-wrapper">
                                <select @bind="_model.Status" class="glass-input form-input select-input">
                                    <option value="Online">🟢 Online</option>
                                    <option value="Working">💻 Working</option>
                                    <option value="Idle">🌙 Idle</option>
                                    <option value="Offline">⚫ Offline</option>
                                </select>
                                <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" class="select-icon" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <div class="input-with-icon">
                            <input type="password" @bind="_newPassword" placeholder="Enter new password to change..." class="glass-input form-input" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button class="btn btn-cancel" @onclick='() => Navigation.NavigateTo("/workspaces")'>Cancel</button>
                        <button class="btn btn-save" @onclick="HandleSubmit" disabled="@_isSaving">
                            @if (_isSaving) { <FluentProgressRing Width="16px" Style="margin-right: 8px;" /> } Save
                        </button>
                        <button class="btn btn-logout" @onclick="HandleLogout">Logout</button>
                        <button class="btn btn-delete" @onclick="HandleDeleteAccount">Delete Account</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .profile-main-content {
        overflow-y: auto;
        padding: 0 40px 60px 40px;
    }

    .profile-menu-item {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: transparent;
        border: none;
        color: var(--flux-main-text);
        opacity: 0.8;
        font-size: 14px;
        font-weight: 500;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: left;
        margin-bottom: 4px;
    }

    .profile-menu-item:hover {
        background-color: var(--flux-glass-white);
        opacity: 1;
    }

    .profile-menu-item.active {
        color: white;
        background-color: var(--flux-primary);
        font-weight: 700;
        opacity: 1;
    }
    
    .profile-menu-item fluent-icon {
        color: currentColor;
        fill: currentColor;
    }

    .top-bar {
        display: flex;
        justify-content: flex-end;
        padding: 20px 0;
        margin-bottom: 20px;
    }

    .top-bar-right {
        display: flex;
        align-items: center;
        gap: 20px;
        color: var(--flux-main-text);
    }

    .profile-container {
        max-width: 800px;
        margin: 0 auto;
        width: 100%;
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .content-header h1 {
        font-size: 32px;
        font-weight: 800;
        color: var(--flux-main-text);
        margin: 0;
    }

    .avatar-upload {
        position: relative;
    }

    .upload-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        background-color: var(--flux-primary);
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        transition: transform 0.2s;
    }
    
    .upload-btn:hover {
        background-color: var(--flux-primary-hover);
        transform: scale(1.05);
    }

    /* Form Styles */
    .profile-form {
        display: flex;
        flex-direction: column;
        gap: 24px;
        padding: 40px;
    }

    .form-row {
        display: flex;
        gap: 24px;
    }

    .form-group {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group label {
        font-size: 14px;
        font-weight: 600;
        color: var(--flux-main-text);
    }

    .form-input {
        width: 100%;
        padding: 14px 16px;
        border-radius: 8px;
        font-size: 15px;
        outline: none;
        box-sizing: border-box;
    }
    
    .form-input::placeholder {
        color: rgba(19, 94, 75, 0.5);
    }

    .readonly-input {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .input-with-icon {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        right: 16px;
    }

    .select-wrapper {
        position: relative;
    }

    .select-input {
        appearance: none;
        -webkit-appearance: none;
    }

    .select-input option {
        background: white;
        color: var(--flux-main-text);
    }

    .select-icon {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: var(--flux-main-text);
    }

    /* Actions */
    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 20px;
    }

    .btn {
        padding: 12px 32px;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
    }

    .btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(19, 94, 75, 0.1);
    }

    .btn:active {
        transform: translateY(0);
    }

    .btn-cancel {
        background-color: transparent;
        color: var(--flux-main-text);
        border: 1px solid var(--flux-main-text);
    }

    .btn-cancel:hover {
        background-color: rgba(19, 94, 75, 0.05);
    }

    .btn-save {
        background-color: var(--flux-primary);
        color: white;
        display: flex;
        align-items: center;
    }

    .btn-save:hover {
        background-color: var(--flux-primary-hover);
    }
    
    .btn-logout {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        margin-left: auto;
        border: 1px solid rgba(220, 53, 69, 0.2);
    }

    .btn-logout:hover {
        background-color: rgba(220, 53, 69, 0.2);
        color: #c82333;
    }

    .btn-delete {
        background-color: #dc3545;
        color: white;
    }

    .btn-delete:hover {
        background-color: #c82333;
    }

    .loading-container {
        display: flex;
        justify-content: center;
        padding: 50px;
    }
</style>

@code {
    private Guid _currentUserId;
    private bool _isLoading = true;
    private bool _isSaving = false;
    
    private string _email = "";
    private string _initials = "U";
    private string _newPassword = "";
    
    private ProfileModel _model = new();

    private class ProfileModel
    {
        public string? Username { get; set; }
        public string? FullName { get; set; }
        public string? NickName { get; set; }
        public string? Country { get; set; }
        public string? AvatarUrl { get; set; }
        public string? Status { get; set; } = "Online";
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                _currentUserId = id;
            }
        }

        if (_currentUserId == Guid.Empty)
        {
            Navigation.NavigateTo("/auth");
            return;
        }

        var result = await FluxService.GetProfileAsync(_currentUserId);
        
        if (result.IsSuccess && result.Value != null)
        {
            _email = result.Value.Email;
            
            _model.Username = result.Value.Username;
            _model.FullName = result.Value.FullName;
            _model.NickName = result.Value.NickName;
            _model.Country = result.Value.Country;
            _model.AvatarUrl = result.Value.AvatarUrl;
            _model.Status = result.Value.Status ?? "Online";

            _initials = string.IsNullOrEmpty(_model.FullName) 
                ? (_model.Username?.Length > 0 ? _model.Username[0].ToString().ToUpper() : "U")
                : _model.FullName[0].ToString().ToUpper();
        }
        else
        {
            ToastService.ShowError("Failed to load profile.");
        }
        
        _isLoading = false;
    }

    private void NavigateToFirstChannel()
    {
        if (WorkspaceState.CurrentWorkspaceId != null && WorkspaceState.Channels.Any())
            Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/chat/{WorkspaceState.Channels.First().Id}");
        else
            Navigation.NavigateTo("/workspaces");
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;

        string? validatedPassword = null;
        if (!string.IsNullOrWhiteSpace(_newPassword))
        {
            // Password validation
            var passwordRegex = new System.Text.RegularExpressions.Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$");
            if (!passwordRegex.IsMatch(_newPassword))
            {
                ToastService.ShowWarning("Password must be at least 8 chars, 1 uppercase, 1 lowercase, 1 number, 1 special char.");
                _isSaving = false;
                return;
            }
            validatedPassword = _newPassword;
        }

        var result = await FluxService.UpdateProfileAsync(
            _currentUserId,
            _model.Username,
            _model.FullName, 
            _model.NickName, 
            null,
            _model.Country, 
            _model.AvatarUrl,
            _model.Status,
            validatedPassword);

        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Profile updated successfully!");
            if (!string.IsNullOrEmpty(validatedPassword))
            {
                ToastService.ShowSuccess("Password updated successfully!");
                _newPassword = "";
            }

            _initials = string.IsNullOrEmpty(_model.FullName) 
                ? (_model.Username?.Length > 0 ? _model.Username[0].ToString().ToUpper() : "U")
                : _model.FullName[0].ToString().ToUpper();
        }
        else
        {
            ToastService.ShowError($"Error: {result.Error}");
        }

        _isSaving = false;
    }
    
    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
        
        if (AuthStateProvider is Flux.Infrastructure.Identity.FluxAuthStateProvider fluxAuthProvider)
        {
            fluxAuthProvider.NotifyUserLogout();
        }
        
        Navigation.NavigateTo("/auth", forceLoad: true);
    }

    private async Task HandleDeleteAccount()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete your account? This action is permanent and all your data will be lost.");
        if (!confirmed) return;

        _isSaving = true;
        var result = await FluxService.DeleteAccountAsync(_currentUserId);
        _isSaving = false;

        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Your account has been deleted.");
            await HandleLogout();
        }
        else
        {
            ToastService.ShowError($"Failed to delete account: {result.Error}");
        }
    }

    private async Task HandleAvatarUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        long maxFileSize = 1024 * 1024 * 5;
        if (file.Size > maxFileSize)
        {
            ToastService.ShowError("Image size must be less than 5MB.");
            return;
        }

        try
        {
            _isLoading = true;
            using var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(file.OpenReadStream(maxFileSize));
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            
            content.Add(streamContent, "file", file.Name);

            var result = await FluxService.UploadImageAsync(content);
            if (result.IsSuccess)
            {
                _model.AvatarUrl = result.Value;
                ToastService.ShowSuccess("Avatar uploaded! Remember to click Save.");
            }
            else
            {
                ToastService.ShowError($"Failed to upload avatar: {result.Error}");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Upload error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }
}
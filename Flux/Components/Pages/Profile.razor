@page "/profile"
@using Flux.Infrastructure.Client
@using Microsoft.AspNetCore.Components.Authorization
@inject UserClientService UserService
@inject UploadClientService UploadService
@inject WorkspaceStateService WorkspaceState
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@layout Flux.Components.Layout.WorkspaceLayout

<PageTitle>Edit Profile - Flux</PageTitle>

<!-- 2. Settings Sidebar -->
<div class="w-64 bg-[#1a1c24] border-r border-white/5 flex flex-col">
        <div class="h-[60px] px-6 border-b border-white/5 flex items-center gap-3">
            <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 15.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Z"/><path d="m19.4 15c.3-1 .3-2 0-3l2.1-1.7c.2-.2.2-.4.1-.6l-2-3.5c-.1-.2-.3-.3-.5-.2l-2.5 1c-.8-.6-1.7-1.1-2.7-1.4l-.4-2.6c0-.2-.2-.4-.4-.4h-4c-.2 0-.4.2-.4.4l-.4 2.6c-1 .3-1.9.8-2.7 1.4l-2.5-1c-.2-.1-.4 0-.5.2l-2 3.5c-.1.2-.1.4.1.6l2.1 1.7c-.3 1-.3 2 0 3l-2.1 1.7c-.2.2-.2.4-.1.6l2 3.5c.1.2.3.3.5.2l2.5-1c.8.6 1.7 1.1 2.7 1.4l.4 2.6c0 .2.2.4.4.4h4c.2 0 .4-.2.4-.4l.4-2.6c1-.3 1.9-.8 2.7-1.4l2.5 1c.2.1.4 0 .5-.2l2-3.5c.1-.2.1-.4-.1-.6l-2.1-1.7Z"/></svg>
            <span class="font-bold text-lg text-white">Settings</span>
        </div>
        
        <div class="flex-1 overflow-y-auto p-3 space-y-1">
            <button class="w-full flex items-center gap-3 px-4 py-2.5 rounded-xl bg-blue-600/10 text-blue-400 font-bold text-sm transition-all border border-blue-500/20">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                <span>Edit profile</span>
            </button>
        
            <button class="w-full flex items-center gap-3 px-4 py-2.5 rounded-xl hover:bg-white/5 text-white/60 hover:text-white text-sm transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                <span>Security</span>
            </button>
        </div>
    </div>

    <!-- 3. Main Content Area -->
    <div class="flex-1 flex flex-col bg-[#0b0c10] overflow-y-auto relative">
        <!-- Header -->
        <div class="h-[60px] px-8 flex items-center justify-end gap-5 border-b border-white/5 bg-[#0b0c10]/50 backdrop-blur-md sticky top-0 z-10">
            <div class="w-9 h-9 rounded-full border border-white/10 overflow-hidden">
                @if (!string.IsNullOrEmpty(_model.AvatarUrl)) {
                    <img src="@_model.AvatarUrl" class="w-full h-full object-cover" />
                } else {
                    <div class="w-full h-full bg-blue-600 flex items-center justify-center text-white font-bold text-xs">@_initials</div>
                }
            </div>
        </div>

        <div class="max-w-3xl mx-auto w-full px-8 py-12">
            <div class="flex justify-between items-center mb-12">
                <div>
                    <h1 class="text-4xl font-black text-white tracking-tight">Edit profile</h1>
                    <p class="text-white/50 mt-2">Manage your public profile and account settings.</p>
                </div>
                <div class="relative">
                    <div class="w-24 h-24 rounded-3xl overflow-hidden border-2 border-white/10 shadow-2xl">
                         @if (!string.IsNullOrEmpty(_model.AvatarUrl)) {
                            <img src="@_model.AvatarUrl" class="w-full h-full object-cover" />
                        } else {
                            <div class="w-full h-full bg-blue-600 flex items-center justify-center text-white font-bold text-3xl">@_initials</div>
                        }
                    </div>
                    <InputFile id="avatarUpload" OnChange="HandleAvatarUpload" class="hidden" accept="image/*" />
                    <label for="avatarUpload" class="absolute -bottom-2 -right-2 w-10 h-10 bg-blue-600 hover:bg-blue-500 rounded-2xl flex items-center justify-center cursor-pointer border-4 border-[#0b0c10] shadow-xl transition-all hover:scale-110 active:scale-95">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </label>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="flex flex-col items-center justify-center py-24 gap-4">
                    <div class="w-12 h-12 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin"></div>
                    <p class="text-white/40 font-medium">Loading your profile...</p>
                </div>
            }
            else
            {
                <div class="bg-[#1a1c24] border border-white/10 rounded-3xl shadow-2xl p-10 space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-white/40 uppercase tracking-widest ml-1">Username</label>
                            <input type="text" @bind="_model.Username" class="profile-input" placeholder="e.g. john_doe" />
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-white/40 uppercase tracking-widest ml-1">Full Name</label>
                            <input type="text" @bind="_model.FullName" class="profile-input" placeholder="e.g. John Doe" />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold text-white/40 uppercase tracking-widest ml-1">Email Address</label>
                        <div class="relative flex items-center">
                            <input type="email" value="@_email" readonly class="profile-input opacity-50 cursor-not-allowed pr-12" />
                            <svg class="absolute right-4 w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-4">
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-white/40 uppercase tracking-widest ml-1">Location</label>
                            <div class="relative">
                                <select @bind="_model.Country" class="profile-input appearance-none">
                                    <option value="" class="bg-[#1a1c24]">Select a country</option>
                                    <option value="USA" class="bg-[#1a1c24]">United States</option>
                                    <option value="UK" class="bg-[#1a1c24]">United Kingdom</option>
                                    <option value="Vietnam" class="bg-[#1a1c24]">Vietnam</option>
                                    <option value="Japan" class="bg-[#1a1c24]">Japan</option>
                                    <option value="Australia" class="bg-[#1a1c24]">Australia</option>
                                </select>
                                <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-white/30 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </div>
                        
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-white/40 uppercase tracking-widest ml-1">Your Status</label>
                            <div class="relative">
                                <select @bind="_model.Status" class="profile-input appearance-none">
                                    <option value="Online" class="bg-[#1a1c24]">🟢 Online</option>
                                    <option value="Working" class="bg-[#1a1c24]">💻 Working</option>
                                    <option value="Idle" class="bg-[#1a1c24]">🌙 Idle</option>
                                    <option value="Offline" class="bg-[#1a1c24]">⚫ Offline</option>
                                </select>
                                <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-white/30 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold text-white/40 uppercase tracking-widest ml-1">Update Password</label>
                        <input type="password" @bind="_newPassword" placeholder="Leave empty to keep current password" class="profile-input" />
                    </div>

                    <div class="flex flex-wrap items-center gap-4 pt-6 border-t border-white/5">
                        <button class="px-8 py-4 rounded-2xl bg-blue-600 hover:bg-blue-500 text-white font-bold shadow-lg shadow-blue-600/20 flex items-center gap-2 transition-all active:scale-95 disabled:opacity-50" @onclick="HandleSubmit" disabled="@_isSaving">
                            @if (_isSaving) { <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> } 
                            Save Changes
                        </button>
                        <button class="px-8 py-4 rounded-2xl border border-white/10 text-white/60 font-bold hover:bg-white/5 hover:text-white transition-all active:scale-95" @onclick='() => Navigation.NavigateTo("/workspaces")'>Cancel</button>
                        
                        <div class="flex-1 min-w-[20px]"></div>
                        
                        <div class="flex items-center gap-3">
                            <button class="p-4 rounded-2xl bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white font-bold transition-all active:scale-95 group" @onclick="HandleDeleteAccount" title="Delete Account">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            </button>
                            <button class="px-6 py-4 rounded-2xl bg-white/5 hover:bg-white/10 text-white font-bold transition-all active:scale-95" @onclick="HandleLogout">Logout</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
<!-- End of Profile Page Wrapper (now handled by Layout) -->

<style>
    .profile-page-wrapper {
        background: #0b0c10;
    }

    .profile-input {
        width: 100%;
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        color: white;
        font-size: 15px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .profile-input:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.05);
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    }

    .profile-input::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    /* Activity Bar Customization */
    .activity-bar {
        width: 72px;
        background-color: #0a0b0f;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px 0;
        z-index: 100;
    }

    .workspace-brand-wrapper {
        width: 44px;
        height: 44px;
        background: #3b82f6;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
        cursor: pointer;
        box-shadow: 0 8px 16px -4px rgba(59, 130, 246, 0.4);
        transition: all 0.2s;
    }

    .workspace-brand-wrapper:hover {
        transform: translateY(-2px) scale(1.05);
    }

    .activity-item {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border-radius: 14px;
        margin-bottom: 8px;
        color: #e2e8f0;
        opacity: 0.4;
        transition: all 0.2s;
    }

    .activity-item:hover {
        opacity: 1;
        background: rgba(255, 255, 255, 0.05);
        transform: translateY(-1px);
    }
</style>

@code {
    private Guid _currentUserId;
    private bool _isLoading = true;
    private bool _isSaving = false;
    
    private string _email = "";
    private string _initials = "U";
    private string _newPassword = "";
    
    private ProfileModel _model = new();

    private class ProfileModel
    {
        public string? Username { get; set; }
        public string? FullName { get; set; }
        public string? NickName { get; set; }
        public string? Country { get; set; }
        public string? AvatarUrl { get; set; }
        public string? Status { get; set; } = "Online";
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                _currentUserId = id;
            }
        }

        if (_currentUserId == Guid.Empty)
        {
            Navigation.NavigateTo("/auth");
            return;
        }

        var result = await UserService.GetProfileAsync(_currentUserId);
        
        if (result.IsSuccess && result.Value != null)
        {
            _email = result.Value.Email;
            
            _model.Username = result.Value.Username;
            _model.FullName = result.Value.FullName;
            _model.NickName = result.Value.NickName;
            _model.Country = result.Value.Country;
            _model.AvatarUrl = result.Value.AvatarUrl;
            _model.Status = result.Value.Status ?? "Online";

            _initials = string.IsNullOrEmpty(_model.FullName) 
                ? (_model.Username?.Length > 0 ? _model.Username[0].ToString().ToUpper() : "U")
                : _model.FullName[0].ToString().ToUpper();
        }
        else
        {
             ToastService.ShowError("Failed to load profile.");
        }
        
        _isLoading = false;
    }

    [Inject] private IToastService ToastService { get; set; } = default!;

    private void NavigateToFirstChannel()
    {
        if (WorkspaceState.CurrentWorkspaceId != null && WorkspaceState.Channels.Any())
            Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/chat/{WorkspaceState.Channels.First().Id}");
        else
            Navigation.NavigateTo("/workspaces");
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;

        string? validatedPassword = null;
        if (!string.IsNullOrWhiteSpace(_newPassword))
        {
            // Password validation
            var passwordRegex = new System.Text.RegularExpressions.Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$");
            if (!passwordRegex.IsMatch(_newPassword))
            {
                ToastService.ShowError("Password must be at least 8 chars, 1 uppercase, 1 lowercase, 1 number, 1 special char.");
                _isSaving = false;
                return;
            }
            validatedPassword = _newPassword;
        }

        var result = await UserService.UpdateProfileAsync(
            _currentUserId,
            _model.Username,
            _model.FullName, 
            _model.NickName, 
            null,
            _model.Country, 
            _model.AvatarUrl,
            _model.Status,
            validatedPassword);

        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Profile updated successfully!");
            _newPassword = "";

            _initials = string.IsNullOrEmpty(_model.FullName) 
                ? (_model.Username?.Length > 0 ? _model.Username[0].ToString().ToUpper() : "U")
                : _model.FullName[0].ToString().ToUpper();
                
            if (WorkspaceState.CurrentWorkspaceId.HasValue)
            {
                await WorkspaceState.RefreshMembersAsync(_currentUserId);
            }
        }
        else
        {
            ToastService.ShowError($"Error: {result.Error}");
        }

        _isSaving = false;
    }
    
    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JS.InvokeVoidAsync("sessionStorage.removeItem", "authToken");
        
        if (AuthStateProvider is Flux.Infrastructure.Identity.FluxAuthStateProvider fluxAuthProvider)
        {
            fluxAuthProvider.NotifyUserLogout();
        }
        
        Navigation.NavigateTo("/auth", forceLoad: true);
    }

    private async Task HandleDeleteAccount()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete your account? This action is permanent and all your data will be lost.");
        if (!confirmed) return;

        _isSaving = true;
        var result = await UserService.DeleteAccountAsync(_currentUserId);
        _isSaving = false;

        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Your account has been deleted.");
            await HandleLogout();
        }
        else
        {
            ToastService.ShowError($"Failed to delete account: {result.Error}");
        }
    }

    private async Task HandleAvatarUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        long maxFileSize = 1024 * 1024 * 5;
        if (file.Size > maxFileSize)
        {
            ToastService.ShowWarning("Image size must be less than 5MB.");
            return;
        }

        try
        {
            _isLoading = true;
            using var content = new MultipartFormDataContent();
            var streamContent = new StreamContent(file.OpenReadStream(maxFileSize));
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            
            content.Add(streamContent, "file", file.Name);

            var result = await UploadService.UploadImageAsync(content);
            if (result.IsSuccess)
            {
                _model.AvatarUrl = result.Value;
                ToastService.ShowSuccess("Avatar uploaded! Remember to click Save.");
            }
            else
            {
                ToastService.ShowError($"Failed to upload avatar: {result.Error}");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Upload error: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }
}

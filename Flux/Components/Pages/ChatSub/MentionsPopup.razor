@using Flux.Infrastructure.Client

@if (Members != null && Members.Any())
{
    <div class="mentions-dropdown">
        @foreach (var member in Members)
        {
            <div class="mention-item @(member.Id == SelectedMemberId ? "selected" : "")"
                 @onclick="() => OnMemberSelected.InvokeAsync(member)">
                @if (!string.IsNullOrEmpty(member.AvatarUrl))
                {
                    <img src="@member.AvatarUrl" class="w-6 h-6 rounded-md object-cover" alt="@member.Username" />
                }
                else
                {
                    <div class="w-6 h-6 rounded-md bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-[10px]">
                        @GetInitials(member.Username)
                    </div>
                }
                <span class="ml-2 text-sm">@member.Username</span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<MemberDto> Members { get; set; } = new();
    [Parameter] public Guid? SelectedMemberId { get; set; }
    [Parameter] public EventCallback<MemberDto> OnMemberSelected { get; set; }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }
}

@using Flux.Infrastructure.Client
@inject IJSRuntime JS

<div class="video-recorder-overlay" @onclick="OnClose">
    <div class="video-recorder-dialog" @onclick:stopPropagation>
        <div class="recorder-header flex justify-between items-center p-4 border-b border-white/5">
            <h3 class="text-white font-bold">Record video clip</h3>
            <button class="p-2 text-white/40 hover:text-white transition-colors" @onclick="OnClose">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>

        <div class="recorder-body relative bg-black aspect-video flex items-center justify-center">
            <video id="videoPreview" autoplay playsinline class="w-full h-full object-cover"></video>
            @if (IsCameraError)
            {
                <div class="camera-error-overlay absolute inset-0 flex flex-col items-center justify-center p-6 text-center bg-black/90">
                    <svg class="w-12 h-12 text-yellow-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                    <h4 class="text-lg font-bold text-white mb-2">Can't access camera</h4>
                    <p class="text-white/60 text-sm max-w-xs">Check your browser settings to make sure Flux has permission to access your camera, and try again.</p>
                </div>
            }
        </div>

        <div class="recorder-footer flex items-center gap-4 p-4 bg-[#1a1a1d] border-t border-white/5">
            @if (RecordedVideoUrl != null)
            {
                <button class="flex items-center gap-2 px-3 py-1.5 text-sm text-white/60 hover:text-white transition-colors" @onclick="OnDownload">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Download Video
                </button>
                <div class="flex-1"></div>
                <button class="px-4 py-2 text-sm font-medium text-white/60 hover:text-white transition-colors" @onclick="OnRetake" disabled="@IsUploading">Retake</button>
                <button class="px-6 py-2 text-sm font-bold bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors flex items-center gap-2" @onclick="OnUpload" disabled="@IsUploading">
                    @if (IsUploading) { <div class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin"></div> }
                    Upload Video
                </button>
            }
            else
            {
                <div class="device-controls flex gap-2">
                    <button class="p-2 rounded-lg @(CurrentCaptureMode == "camera" ? "bg-white/10 text-white" : "text-white/40 hover:text-white hover:bg-white/5")" @onclick='() => OnSwitchCaptureMode.InvokeAsync("camera")' title="Camera">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                    </button>
                    <button class="p-2 rounded-lg @(CurrentCaptureMode == "screen" ? "bg-white/10 text-white" : "text-white/40 hover:text-white hover:bg-white/5")" @onclick='() => OnSwitchCaptureMode.InvokeAsync("screen")' title="Screen Share">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    </button>
                    <button class="p-2 rounded-lg @(IsMicEnabled ? "text-white/40 hover:text-white" : "bg-red-500/20 text-red-500")" @onclick="OnToggleMic" title="Toggle Microphone">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@(IsMicEnabled ? "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" : "M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z")" /></svg>
                    </button>
                </div>
                <div class="flex-1"></div>
                @if (IsCountingDown)
                {
                    <div class="px-6 py-2 text-sm font-bold bg-red-600/50 text-white rounded-lg">Starting in @CountdownSeconds...</div>
                }
                else if (IsRecording)
                {
                    <div class="flex items-center gap-3 mr-4">
                        <div class="w-3 h-3 bg-red-600 rounded-full animate-pulse shadow-[0_0_10px_rgba(220,38,38,0.5)]"></div>
                        <span class="text-white font-mono font-bold text-lg">@RecordingDurationString</span>
                    </div>
                    <button class="px-6 py-2 text-sm font-bold bg-white text-black rounded-lg hover:bg-white/90 transition-colors" @onclick="OnStop">Stop Recording</button>
                }
                else
                {
                    <button class="px-6 py-2 text-sm font-bold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors flex items-center gap-2" @onclick="OnStart">
                        <div class="w-3 h-3 bg-white rounded-full"></div>
                        Record
                    </button>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public bool IsCameraError { get; set; }
    [Parameter] public bool IsRecording { get; set; }
    [Parameter] public string? RecordedVideoUrl { get; set; }
    [Parameter] public string CurrentCaptureMode { get; set; } = "camera";
    [Parameter] public bool IsMicEnabled { get; set; } = true;
    [Parameter] public bool IsUploading { get; set; }
    [Parameter] public string RecordingDurationString { get; set; } = "00:00";
    [Parameter] public int CountdownSeconds { get; set; }
    [Parameter] public bool IsCountingDown { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnStart { get; set; }
    [Parameter] public EventCallback OnStop { get; set; }
    [Parameter] public EventCallback OnRetake { get; set; }
    [Parameter] public EventCallback OnDownload { get; set; }
    [Parameter] public EventCallback OnUpload { get; set; }
    [Parameter] public EventCallback<string> OnSwitchCaptureMode { get; set; }
    [Parameter] public EventCallback OnToggleMic { get; set; }
}

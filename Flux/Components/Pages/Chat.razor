@page "/workspace/{WorkspaceId:guid}/chat/{ChannelId:guid}"
@layout Flux.Components.Layout.WorkspaceLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@using Flux.Features.Messages.EditMessage
@inject FluxClientService FluxService
@inject WorkspaceStateService StateService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject IToastService ToastService
@implements IAsyncDisposable

<PageTitle>Chat - @(_currentChannelName ?? "Loading...")</PageTitle>

<div class="chat-container">
    <!-- Chat Header -->
    <div class="chat-header">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center">
            <div class="channel-info">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="4">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Tag())" />
                    <FluentLabel Typo="Typography.H6" Style="font-weight: 700; color: white">@(_currentChannelName ?? "channel-name")</FluentLabel>
                    <FluentIcon Value="@(new Icons.Regular.Size12.ChevronDown())" Style="margin-left: 4px; opacity: 0.6;" />
                </FluentStack>
            </div>
            <FluentSpacer />
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
                
                <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.Info())" />
            </FluentStack>
        </FluentStack>
    </div>

    <!-- Messages Viewport -->
    <div class="messages-viewport" @ref="_messagesViewport">
        @if (_isLoading)
        {
            <div class="loading-container">
                <FluentProgressRing />
                <FluentLabel>Loading messages...</FluentLabel>
            </div>
        }
        else if (!_messages.Any())
        {
            <div class="empty-chat">
                <div class="empty-chat-hero">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Chat())" Color="Color.Accent" />
                    <FluentLabel Typo="Typography.H5">This is the start of the #@_currentChannelName channel</FluentLabel>
                    <FluentLabel Typo="Typography.Body" Style="opacity: 0.7;">Be the first to send a message!</FluentLabel>
                </div>
            </div>
        }
        else
        {
            <div class="message-list">
                @if (_hasMoreMessages)
                {
                    <div class="load-more-container">
                        <FluentButton Appearance="Appearance.Stealth" 
                                      OnClick="LoadMoreMessages" 
                                      Loading="_isLoadingMore"
                                      IconStart="@(new Icons.Regular.Size16.ArrowClockwise())">
                            Load older messages
                        </FluentButton>
                    </div>
                }

                @foreach (var msg in _messages)
                {
                    bool isSelf = msg.UserId == CurrentUserId;
                    <div class="message-group @(isSelf ? "self" : "")" @onclick="@(e => ShowMessageMenu(e, msg))">
                        <FluentPersona Status="PresenceStatus.Available"
                                      ImageSize="36px" 
                                      Initials="@GetInitials(msg.Username)"
                                      Title="@msg.Username" />
                        
                        <div class="message-content">
                            <div class="message-meta">
                                <span class="username">@msg.Username</span>
                                <span class="timestamp">@msg.CreatedAt.ToString("h:mm tt")</span>
                            </div>
                            <div class="message-bubble-wrapper">
                                <div class="message-bubble">
                                    @if (msg.Content.Contains("[video: "))
                                    {
                                        var startIndex = msg.Content.IndexOf("[video: ");
                                        var endIndex = msg.Content.IndexOf("]", startIndex);
                                        if (startIndex >= 0 && endIndex > startIndex)
                                        {
                                            var before = msg.Content.Substring(0, startIndex);
                                            var url = msg.Content.Substring(startIndex + 8, endIndex - startIndex - 8);
                                            var after = msg.Content.Substring(endIndex + 1);
                                            
                                            if (!string.IsNullOrWhiteSpace(before))
                                            {
                                                <span>@before</span>
                                            }
                                            <video src="@url" controls class="message-video" preload="metadata"></video>
                                            if (!string.IsNullOrWhiteSpace(after))
                                            {
                                                <span>@after</span>
                                            }
                                        }
                                        else
                                        {
                                            @msg.Content
                                        }
                                    }
                                    else
                                    {
                                        @msg.Content
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Message Actions Menu Overlay -->
    @if (_showMessageMenu)
    {
        <div class="menu-overlay" @onclick="CloseMessageMenu" @oncontextmenu:preventDefault="true"></div>
        <div class="message-context-menu" style="left: @(_menuX)px; top: @(_menuY)px;">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="0">
                <FluentMenuItem Icon="@(new Icons.Regular.Size16.ArrowReply())" OnClick="@(() => HandleAction("Reply"))">Reply</FluentMenuItem>
                <FluentMenuItem Icon="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => HandleAction("Edit"))">Edit</FluentMenuItem>
                <FluentDivider />
                <FluentMenuItem Icon="@(new Icons.Regular.Size16.Delete())" OnClick="@(() => HandleAction("Delete"))">
                    <FluentLabel Color="Color.Error">Delete</FluentLabel>
                </FluentMenuItem>
            </FluentStack>
        </div>
    }

    <!-- Edit Message Dialog -->
    <FluentDialog Hidden="!_showEditDialog" Modal="true" TrapFocus="true" @onclick:stopPropagation>
        <div class="glass-dialog" style="padding: 20px; width: 500px; max-width: 90vw; background: rgba(30,30,34,0.9); backdrop-filter: blur(20px); border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);">
            <h3 style="color: white; margin-top: 0; margin-bottom: 15px;">Edit Message</h3>
            <FluentTextArea @bind-Value="_editMessageContent" Style="width: 100%; margin-bottom: 20px; background: rgba(0,0,0,0.3); color: white; border: 1px solid rgba(255,255,255,0.2);" Rows="4" />
            <div style="display: flex; justify-content: flex-end; gap: 10px;">
                <FluentButton Appearance="Appearance.Stealth" OnClick="() => _showEditDialog = false" Style="color: white;">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="SaveEditMessage">Save</FluentButton>
            </div>
        </div>
    </FluentDialog>

    <!-- Video Recorder Dialog -->
    @if (_showVideoRecorder)
    {
        <div class="video-recorder-overlay" @onclick="CloseVideoRecorder">
            <div class="video-recorder-dialog" @onclick:stopPropagation>
                <div class="recorder-header">
                    <h3>Record video clip</h3>
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size16.Dismiss())" OnClick="CloseVideoRecorder" />
                </div>
                
                <div class="recorder-body">
                    <video id="videoPreview" autoplay playsinline class="video-preview"></video>
                    @if (_isCameraError)
                    {
                        <div class="camera-error-overlay">
                            <FluentIcon Value="@(new Icons.Regular.Size32.Warning())" Color="Color.Custom" CustomColor="#ffb300" />
                            <h4>Can't access camera</h4>
                            <p>Check your browser settings to make sure Flux has permission to access your camera, and try again.</p>
                        </div>
                    }
                </div>
                
                <div class="recorder-footer">
                    @if (_recordedVideoUrl != null)
                    {
                        <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.ArrowDownload())" OnClick="DownloadVideo">Download Video</FluentButton>
                        <FluentSpacer />
                        <FluentButton Appearance="Appearance.Stealth" OnClick="RetakeVideo" Disabled="@_isUploading">Retake</FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="UploadVideo" Loading="@_isUploading">Upload Video</FluentButton>
                    }
                    else
                    {
                        <div class="device-controls">
                            <FluentButton Appearance="@(_currentCaptureMode == "camera" ? Appearance.Neutral : Appearance.Stealth)" IconEnd="@(new Icons.Regular.Size20.Video())" OnClick='() => SwitchCaptureMode("camera")' Title="Camera" />
                            <FluentButton Appearance="@(_currentCaptureMode == "screen" ? Appearance.Neutral : Appearance.Stealth)" IconEnd="@(new Icons.Regular.Size20.Desktop())" OnClick='() => SwitchCaptureMode("screen")' Title="Screen Share" />
                            <FluentButton Appearance="@(_isMicEnabled ? Appearance.Stealth : Appearance.Neutral)" 
                                          IconEnd="@(_isMicEnabled ? new Icons.Regular.Size20.Mic() : new Icons.Regular.Size20.MicOff())" 
                                          OnClick="ToggleMic" Title="Toggle Microphone" />
                        </div>
                        <FluentSpacer />
                        @if (_isCountingDown)
                        {
                            <FluentButton Appearance="Appearance.Accent" Style="background-color: #e01e5a; opacity: 0.8;" Disabled="true">
                                Starting in @_countdownSeconds...
                            </FluentButton>
                        }
                        else if (_isRecording)
                        {
                            <span style="color: #ff0055; font-family: monospace; font-weight: bold; margin-right: 15px; font-size: 1.2rem; display: flex; align-items: center; gap: 8px;">
                                <span class="status-dot" style="background-color: #ff0055; box-shadow: 0 0 10px #ff0055;"></span>
                                @_recordingDurationString
                            </span>
                            <FluentButton Appearance="Appearance.Stealth" OnClick="StopRecording" Style="color: white; border: 1px solid rgba(255,255,255,0.2);">Stop Recording</FluentButton>
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Accent" OnClick="StartRecording" Style="background-color: #e01e5a;" Disabled="@_isCameraError">Record</FluentButton>
                        }
                    }
                </div>
            </div>
        </div>
    }

    <!-- Chat Input -->
    <div class="chat-input-container">
        <div class="chat-input-box">
            <FluentTextArea @ref="_textAreaRef"
                            @bind-Value="_newMessageContent"
                            Immediate="true"
                            Placeholder="@($"Message #{(_currentChannelName?.StartsWith("#") == true ? _currentChannelName.Substring(1) : _currentChannelName)}")"
                            title="Press Enter to send. Press Ctrl+Enter for a new line."
                            Class="chat-textarea-redesigned"
                            Rows="1" />
            <div class="bottom-toolbar">
                <div class="toolbar-left">
                    <FluentButton class="add-button" Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Add())" />
                    <FluentDivider Vertical="true" style="height: 20px;" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.Video())" OnClick="OpenVideoRecorder" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.Mic())" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.Emoji())" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.Mention())" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.TextFont())" />
                    <FluentDivider Vertical="true" style="height: 20px;" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size20.ChatWarning())" />
                </div>
                <div class="toolbar-right">
                    <FluentButton Appearance="@(string.IsNullOrWhiteSpace(_newMessageContent) ? Appearance.Stealth : Appearance.Accent)"
                                  IconEnd="@(new Icons.Regular.Size16.Send())"
                                  OnClick="SendMessage"
                                  Disabled="@(string.IsNullOrWhiteSpace(_newMessageContent))"
                                  Title="Send message (Enter)" />
                    <FluentDivider Vertical="true" style="height: 20px;" />
                    <FluentButton Appearance="Appearance.Stealth" IconEnd="@(new Icons.Regular.Size12.ChevronDown())" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }
    [Parameter] public Guid ChannelId { get; set; }

    private List<MessageDto> _messages = new();
    private string _newMessageContent = "";
    private string? _currentChannelName;
    private bool _isLoading = true;
    private bool _isLoadingMore = false;
    private bool _hasMoreMessages = true;
    private ElementReference _messagesViewport;
    private FluentTextArea _textAreaRef = default!;
    private DotNetObjectReference<Chat>? _objRef;
    private bool _shouldScrollToBottom = false;
    private HubConnection? _hubConnection;

    // Hardcoded for now, will be replaced by Auth service later
    private Guid CurrentUserId;
    
    // Video Recorder State
    private bool _showVideoRecorder = false;
    private bool _isCameraError = false;
    private bool _isRecording = false;
    private string? _recordedVideoUrl = null;
    private string _currentCaptureMode = "camera";
    private bool _isCameraEnabled = true;
    private bool _isMicEnabled = true;

    private System.Timers.Timer? _recordingTimer;
    private int _recordingSeconds = 0;
    private string _recordingDurationString = "00:00";
    
    private int _countdownSeconds = 0;
    private bool _isCountingDown = false;

    private async Task OpenVideoRecorder()
    {
        _showVideoRecorder = true;
        _isCameraError = false;
        _isRecording = false;
        _recordedVideoUrl = null;
        _currentCaptureMode = "camera";
        _isCameraEnabled = true;
        _isMicEnabled = true;
        _recordingSeconds = 0;
        _recordingDurationString = "00:00";
        StateHasChanged();

        await Task.Delay(100);
        await SwitchCaptureMode("camera");
    }

    private async Task ToggleCamera()
    {
        _isCameraEnabled = !_isCameraEnabled;
        await JS.InvokeVoidAsync("window.videoRecorder.toggleVideo", _isCameraEnabled);
    }

    private async Task ToggleMic()
    {
        _isMicEnabled = !_isMicEnabled;
        await JS.InvokeVoidAsync("window.videoRecorder.toggleAudio", _isMicEnabled);
    }

    private async Task SwitchCaptureMode(string mode)
    {
        _currentCaptureMode = mode;
        _isCameraError = false;
        StateHasChanged();
        
        bool started;
        if (mode == "camera")
        {
            started = await JS.InvokeAsync<bool>("window.videoRecorder.startCamera", "videoPreview");
        }
        else
        {
            started = await JS.InvokeAsync<bool>("window.videoRecorder.startScreenShare", "videoPreview");
        }

        if (!started)
        {
            _isCameraError = true;
            StateHasChanged();
        }
        else
        {
            // Sync current toggle states
            await JS.InvokeVoidAsync("window.videoRecorder.toggleVideo", _isCameraEnabled);
            await JS.InvokeVoidAsync("window.videoRecorder.toggleAudio", _isMicEnabled);
        }
    }

    private async Task CloseVideoRecorder()
    {
        _showVideoRecorder = false;
        if (_isRecording)
        {
            await StopRecording();
        }
        await JS.InvokeVoidAsync("window.videoRecorder.stopCamera");
    }

    private async Task StartRecording()
    {
        if (_isCountingDown) return;
        
        _isCountingDown = true;
        _countdownSeconds = 3;
        StateHasChanged();

        // 3 seconds countdown
        while (_countdownSeconds > 0)
        {
            await Task.Delay(1000);
            _countdownSeconds--;
            StateHasChanged();
        }
        
        _isCountingDown = false;

        var started = await JS.InvokeAsync<bool>("window.videoRecorder.startRecording");
        if (started)
        {
            _isRecording = true;
            _recordingSeconds = 0;
            _recordingDurationString = "00:00";
            
            if (_recordingTimer != null)
            {
                _recordingTimer.Stop();
                _recordingTimer.Dispose();
            }
            
            _recordingTimer = new System.Timers.Timer(1000);
            _recordingTimer.Elapsed += (sender, e) =>
            {
                _recordingSeconds++;
                var ts = TimeSpan.FromSeconds(_recordingSeconds);
                _recordingDurationString = ts.ToString(@"mm\:ss");
                InvokeAsync(StateHasChanged);
            };
            _recordingTimer.Start();
        }
    }

    private async Task StopRecording()
    {
        _isRecording = false;
        if (_recordingTimer != null)
        {
            _recordingTimer.Stop();
            _recordingTimer.Dispose();
            _recordingTimer = null;
        }
        _recordedVideoUrl = await JS.InvokeAsync<string>("window.videoRecorder.stopRecording", "videoPreview");
    }

    private async Task RetakeVideo()
    {
        _recordedVideoUrl = null;
        await JS.InvokeVoidAsync("window.videoRecorder.startCamera", "videoPreview");
    }

    private async Task DownloadVideo()
    {
        if (_recordedVideoUrl != null)
        {
            await JS.InvokeVoidAsync("window.videoRecorder.downloadVideo", _recordedVideoUrl);
        }
    }

    private bool _isUploading = false;

    private async Task UploadVideo()
    {
        if (_recordedVideoUrl == null) return;

        _isUploading = true;
        StateHasChanged();

        var uploadedUrl = await JS.InvokeAsync<string>("window.videoRecorder.uploadVideo", _recordedVideoUrl, "/api/uploads/video");

        _isUploading = false;

        if (!string.IsNullOrEmpty(uploadedUrl))
        {
            ToastService.ShowSuccess("Video ready to send!");
            _newMessageContent += (string.IsNullOrEmpty(_newMessageContent) ? "" : "\n") + $"[video: {uploadedUrl}]";
            await CloseVideoRecorder();
        }
        else
        {
            ToastService.ShowError("Failed to upload video.");
        }
        StateHasChanged();
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                CurrentUserId = id;
                Console.WriteLine($"[Chat.razor] CurrentUserId set to: {CurrentUserId}");
            }
            else
            {
                Console.WriteLine($"[Chat.razor] Failed to parse idClaim: {idClaim?.Value}");
            }
        }
        else
        {
            Console.WriteLine("[Chat.razor] User is not authenticated.");
        }

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chatHub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<SendMessageResponse>("ReceiveMessage", async (response) =>
        {
            if (response.ChannelId == ChannelId)
            {
                if (!_messages.Any(m => m.Id == response.Id))
                {
                    _messages.Add(new MessageDto(
                        response.Id, 
                        response.Content, 
                        response.UserId, 
                        response.Username, 
                        response.CreatedAt, 
                        null));
                    
                    _shouldScrollToBottom = true;
                    await InvokeAsync(StateHasChanged);
                }
            }
        });

        _hubConnection.On<EditMessageResponse>("MessageUpdated", async (response) =>
        {
            var index = _messages.FindIndex(m => m.Id == response.MessageId);
            if (index != -1)
            {
                _messages[index] = _messages[index] with { Content = response.Content, UpdatedAt = response.UpdatedAt };
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<Guid>("MessageDeleted", async (messageId) =>
        {
            var index = _messages.FindIndex(m => m.Id == messageId);
            if (index != -1)
            {
                _messages.RemoveAt(index);
                await InvokeAsync(StateHasChanged);
            }
        });

        await _hubConnection.StartAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_hubConnection?.State == HubConnectionState.Connected)
        {
            await _hubConnection.InvokeAsync("JoinChannel", ChannelId.ToString());
        }
        await LoadChatData();
    }

    private async Task LoadChatData()
    {
        _isLoading = true;
        _messages.Clear();
        _hasMoreMessages = true;
        try
        {
            // Try to find channel name from WorkspaceState
            var channel = StateService.Channels.FirstOrDefault(c => c.Id == ChannelId);
            _currentChannelName = channel?.Name ?? "general"; 
            
            var result = await FluxService.GetMessagesAsync(ChannelId);
            if (result.IsSuccess)
            {
                _messages = result.Value ?? new();
                _hasMoreMessages = _messages.Count >= 50; // Assume there's more if we hit the limit
                _shouldScrollToBottom = true;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMoreMessages()
    {
        if (_isLoadingMore || !_hasMoreMessages || !_messages.Any()) return;

        _isLoadingMore = true;
        try
        {
            var oldestMessageTimestamp = _messages.First().CreatedAt;
            var result = await FluxService.GetMessagesAsync(ChannelId, oldestMessageTimestamp);
            
            if (result.IsSuccess && result.Value != null && result.Value.Any())
            {
                var olderMessages = result.Value;
                _hasMoreMessages = olderMessages.Count >= 50;
                
                // Prepend older messages
                _messages.InsertRange(0, olderMessages);
                
                // We don't want to scroll to bottom when loading older messages
                // In a real app, we'd preserve the scroll position relative to the current view
            }
            else
            {
                _hasMoreMessages = false;
            }
        }
        finally
        {
            _isLoadingMore = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerEnterKeyHandler", _textAreaRef.Element, _objRef);
        }

        if (_shouldScrollToBottom)
        {
            _shouldScrollToBottom = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await JS.InvokeVoidAsync("scrollToBottom", _messagesViewport);
    }

    [JSInvokable]
    public async Task SendMessageFromJS()
    {
        await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_newMessageContent)) return;

        var content = _newMessageContent.Trim();
        _newMessageContent = string.Empty; // Clear optimistically

        // Force UI update to clear textarea and disable button
        await InvokeAsync(StateHasChanged);

        var command = new SendMessageCommand(content, ChannelId, CurrentUserId);
        var result = await FluxService.SendMessageAsync(command);

        if (!result.IsSuccess)
        {
            // On failure, restore the content so the user can retry.
            _newMessageContent = content;
            ToastService.ShowError($"Failed to send message: {result.Error}");
        }
        
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        if (_hubConnection != null)
        {
            try
            {
                if (_hubConnection.State == HubConnectionState.Connected)
                {
                    await _hubConnection.InvokeAsync("LeaveChannel", ChannelId.ToString());
                }
            }
            catch { }
            await _hubConnection.DisposeAsync();
            _hubConnection = null;
        }
    }

    // --- Message Actions Logic ---
    private bool _showMessageMenu = false;
    private double _menuX = 0;
    private double _menuY = 0;
    private MessageDto? _selectedMessage;

    private bool _showEditDialog = false;
    private string _editMessageContent = "";
    private Guid _editingMessageId;

    private void ShowMessageMenu(MouseEventArgs e, MessageDto message)
    {
        _selectedMessage = message;
        _menuX = e.ClientX;
        _menuY = e.ClientY;
        _showMessageMenu = true;
    }

    private void CloseMessageMenu()
    {
        _showMessageMenu = false;
        _selectedMessage = null;
    }

    private async Task HandleAction(string action)
    {
        if (_selectedMessage == null) return;
        
        var messageId = _selectedMessage.Id;
        var content = _selectedMessage.Content;
        var username = _selectedMessage.Username;
        
        CloseMessageMenu();

        switch (action)
        {
            case "Reply":
                _newMessageContent = $"[Replying to {username}]:\n> {content.Replace("\n", "\n> ")}\n\n" + _newMessageContent;
                await InvokeAsync(StateHasChanged);
                break;
            case "Edit":
                _editingMessageId = messageId;
                _editMessageContent = content;
                _showEditDialog = true;
                break;
            case "Delete":
                await ConfirmDeleteMessage(messageId);
                break;
        }
    }

    private async Task SaveEditMessage()
    {
        if (string.IsNullOrWhiteSpace(_editMessageContent)) return;
        
        var request = new Flux.Features.Messages.EditMessage.EditMessageRequest(_editMessageContent, CurrentUserId);
        var result = await FluxService.EditMessageAsync(_editingMessageId, request);
        
        if (result.IsSuccess)
        {
            var index = _messages.FindIndex(m => m.Id == _editingMessageId);
            if (index != -1)
            {
                _messages[index] = _messages[index] with { Content = _editMessageContent, UpdatedAt = DateTime.UtcNow };
            }
            ToastService.ShowSuccess("Message updated.");
        }
        else
        {
            ToastService.ShowError($"Failed to edit message: {result.Error}");
        }
        
        _showEditDialog = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmDeleteMessage(Guid messageId)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this message?");
        if (confirmed)
        {
            var result = await FluxService.DeleteMessageAsync(messageId, CurrentUserId);
            if (result.IsSuccess)
            {
                _messages.RemoveAll(m => m.Id == messageId);
                ToastService.ShowSuccess("Message deleted.");
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                ToastService.ShowError($"Failed to delete message: {result.Error}");
            }
        }
    }
}


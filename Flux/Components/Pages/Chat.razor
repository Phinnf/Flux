@page "/workspace/{WorkspaceId:guid}/chat/{ChannelId:guid}"
@page "/workspace/{WorkspaceId:guid}/dms/{ChannelId:guid}"
@layout Flux.Components.Layout.WorkspaceLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@using Flux.Features.Messages.EditMessage
@using Flux.Features.Messages.SendMessage
@using Flux.Features.Messages.GetMessages
@implements IAsyncDisposable

<PageTitle>Chat - @(_currentChannelName ?? "Loading...")</PageTitle>

@if (StateService.Channels.FirstOrDefault(c => c.Id == ChannelId)?.Type != Flux.Domain.Entities.ChannelType.Direct)
{
    <Flux.Components.Layout.WorkspaceSidebar />
}
else
{
    <Flux.Components.Layout.DmSidebar />
}

<div class="chat-main-wrapper flex-1">
    <div class="chat-container">
        <!-- Chat Header -->
        <div class="chat-header">
            <div class="flex items-center gap-3 w-full">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-xl @(StateService.ActiveCallChannelIds.Contains(ChannelId) ? "bg-[#3E9E60]/20 text-[#3E9E60]" : "bg-blue-500/10 text-blue-400") flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-base font-bold leading-none @(StateService.ActiveCallChannelIds.Contains(ChannelId) ? "text-[#3E9E60]" : "text-white")">@(_currentChannelName ?? "channel-name")</h2>
                        @if (StateService.ActiveCallChannelIds.Contains(ChannelId))
                        {
                            <p class="text-[10px] text-[#3E9E60]/80 uppercase tracking-widest mt-1 flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-[#3E9E60] animate-pulse"></span> Huddle in progress
                            </p>
                        }
                        else
                        {
                            <p class="text-[10px] text-white/30 uppercase tracking-widest mt-1">Active Channel</p>
                        }
                    </div>
                </div>
                <div class="flex-1"></div>
                <div class="flex items-center gap-1">
                    @if (StateService.ActiveCallChannelIds.Contains(ChannelId))
                    {
                        <button class="px-3 py-1.5 bg-[#3E9E60] hover:bg-[#348b52] text-white text-xs font-bold rounded-md flex items-center gap-1.5 transition-colors animate-pulse" @onclick="StartHuddle" title="Join Huddle">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                            Join
                        </button>
                    }
                    else
                    {
                        <button class="p-2 text-white/20 hover:text-[#3E9E60] transition-colors" @onclick="StartHuddle" title="Start Huddle">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                        </button>
                    }
                    <button class="p-2 text-white/20 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </button>
                    <button class="p-2 text-white/20 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Messages Viewport -->
        <div class="messages-viewport" @ref="_messagesViewport">
            @if (_isLoading)
            {
                <div class="flex flex-col items-center justify-center h-full gap-4">
                    <div class="w-10 h-10 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin"></div>
                    <p class="text-sm font-medium text-white/60">Loading messages...</p>
                </div>
            }
            else
            {
                <div class="message-list">
                    @if (!_messages.Any())
                    {
                        <div class="channel-hero">
                            <p class="hero-title"># @(_currentChannelName ?? "channel-name")</p>
                            <p class="hero-desc">This is the very beginning of the <strong>@(_currentChannelName ?? "channel-name")</strong> channel.</p>
                        </div>
                    }
                    else
                    {
                        @if (_hasMoreMessages)
                        {
                            <div class="flex justify-center my-4">
                                <button class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-white/60 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg transition-all disabled:opacity-50" 
                                        @onclick="LoadMoreMessages" 
                                        disabled="@_isLoadingMore">
                                    @if (_isLoadingMore)
                                    {
                                        <div class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin"></div>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                                    }
                                    Load older messages
                                </button>
                            </div>
                        }

                        <div class="channel-hero">
                            <p class="hero-title"># @(_currentChannelName ?? "channel-name")</p>
                            <p class="hero-desc">This is the very beginning of the <strong>@(_currentChannelName ?? "channel-name")</strong> channel.</p>
                        </div>

                        <Virtualize @ref="_messageVirtualizeRef" Items="@RootMessages" Context="msg" OverscanCount="20">
                            @{
                                var index = RootMessages.IndexOf(msg);
                                var prevMsg = index > 0 ? RootMessages[index - 1] : null;
                                bool showDate = prevMsg == null || msg.CreatedAt.Date != prevMsg.CreatedAt.Date;
                                bool isCompact = !showDate && prevMsg != null && prevMsg.UserId == msg.UserId && (msg.CreatedAt - prevMsg.CreatedAt).TotalMinutes < 5;
                                bool isSelf = msg.UserId == CurrentUserId;
                            }
                            
                            @if (showDate)
                            {
                                var dateLabel = msg.CreatedAt.Date == DateTime.Today ? "Today" : 
                                                msg.CreatedAt.Date == DateTime.Today.AddDays(-1) ? "Yesterday" : 
                                                msg.CreatedAt.ToString("dddd, MMMM d");
                                                
                                <div class="date-divider">
                                    <hr />
                                    <span>@dateLabel</span>
                                </div>
                            }

                            <div class="message-group @(isSelf ? "self" : "") @(_activeThreadParent?.Id == msg.Id ? "active-thread" : "") @(isCompact ? "compact" : "")">
                                    <!-- Hover Toolbar -->
                                    <div class="message-hover-toolbar" @onclick:stopPropagation>
                                        <div class="toolbar-container">
                                            <button class="toolbar-btn" title="Add Reaction" @onclick="@((e) => OpenEmojiPicker(e, msg.Id))">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                            </button>
                                            <button class="toolbar-btn" title="Reply in thread" @onclick="@(() => OpenThread(msg))">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l5 5m-5-5l5-5" /></svg>
                                            </button>
                                            @if (isSelf)
                                            {
                                                <button class="toolbar-btn" title="Edit message" @onclick="@(() => HandleQuickAction(msg, "Edit"))">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                                </button>
                                                <button class="toolbar-btn text-red-500 hover:bg-red-500/10" title="Delete message" @onclick="@(() => HandleQuickAction(msg, "Delete"))">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                                </button>
                                            }
                                        </div>
                                    </div>

                                    @if (!isCompact)
                                    {
                                        <div class="avatar-wrapper flex-shrink-0 cursor-pointer" @onclick="@(() => OpenProfile(msg.UserId))">
                                            @if (!string.IsNullOrEmpty(msg.AvatarUrl))
                                            {
                                                <img src="@msg.AvatarUrl" class="w-9 h-9 rounded-lg object-cover" alt="@msg.Username" title="@msg.Username" />
                                            }
                                            else
                                            {
                                                <div class="w-9 h-9 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-xs" title="@msg.Username">
                                                    @GetInitials(msg.Username)
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="compact-time">@msg.CreatedAt.ToString("hh:mm")</div>
                                    }
                                    
                                    <div class="message-content">
                                        @if (!isCompact)
                                        {
                                            <div class="message-meta">
                                                <span class="username" style="cursor: pointer;" @onclick="@(() => OpenProfile(msg.UserId))">@msg.Username</span>
                                                <span class="timestamp">@msg.CreatedAt.ToString("h:mm tt")</span>
                                            </div>
                                        }
                                        <div class="message-bubble-wrapper">
                                            @if (_editingMessageId == msg.Id)
                                            {
                                                <div class="inline-editor flex flex-col gap-2 w-full max-w-[600px]">
                                                    <textarea @bind="_editMessageContent" 
                                                              class="w-full bg-white/5 border border-blue-500 rounded-lg p-3 text-white focus:outline-none focus:ring-1 focus:ring-blue-500" 
                                                              rows="2"></textarea>
                                                    <div class="inline-editor-actions flex justify-end gap-2">
                                                        <button class="px-4 py-1.5 text-sm font-medium text-white/60 hover:text-white transition-colors" @onclick="CancelEdit">Cancel</button>
                                                        <button class="px-4 py-1.5 text-sm font-medium text-white bg-[#007a5a] hover:bg-[#007a5a]/90 rounded-md transition-colors" @onclick="SaveEditMessage">Save</button>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="message-bubble">
                                                    @if (msg.Content.Contains("[video: "))
                                                    {
                                                        var startIndex = msg.Content.IndexOf("[video: ");
                                                        var endIndex = msg.Content.IndexOf("]", startIndex);
                                                        if (startIndex >= 0 && endIndex > startIndex)
                                                        {
                                                            var before = msg.Content.Substring(0, startIndex);
                                                            var url = msg.Content.Substring(startIndex + 8, endIndex - startIndex - 8);
                                                            var after = msg.Content.Substring(endIndex + 1);
                                                            
                                                            if (!string.IsNullOrWhiteSpace(before))
                                                            {
                                                                <span>@before</span>
                                                            }
                                                            <video src="@url" controls class="message-video" preload="metadata"></video>
                                                            if (!string.IsNullOrWhiteSpace(after))
                                                            {
                                                                <span>@after</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @msg.Content
                                                        }
                                                    }
                                                    else if (msg.Content.Contains("[image: "))
                                                    {
                                                        var startIndex = msg.Content.IndexOf("[image: ");
                                                        var endIndex = msg.Content.IndexOf("]", startIndex);
                                                        if (startIndex >= 0 && endIndex > startIndex)
                                                        {
                                                            var before = msg.Content.Substring(0, startIndex);
                                                            var url = msg.Content.Substring(startIndex + 8, endIndex - startIndex - 8);
                                                            var after = msg.Content.Substring(endIndex + 1);
                                                            
                                                            if (!string.IsNullOrWhiteSpace(before))
                                                            {
                                                                <span>@before</span>
                                                            }
                                                            <img src="@url" class="message-image" alt="Uploaded image" />
                                                            if (!string.IsNullOrWhiteSpace(after))
                                                            {
                                                                <span>@after</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @msg.Content
                                                        }
                                                    }
                                                    else if (msg.Content.Contains("[audio: "))
                                                    {
                                                        var startIndex = msg.Content.IndexOf("[audio: ");
                                                        var endIndex = msg.Content.IndexOf("]", startIndex);
                                                        if (startIndex >= 0 && endIndex > startIndex)
                                                        {
                                                            var before = msg.Content.Substring(0, startIndex);
                                                            var url = msg.Content.Substring(startIndex + 8, endIndex - startIndex - 8);
                                                            var after = msg.Content.Substring(endIndex + 1);
                                                            
                                                            if (!string.IsNullOrWhiteSpace(before))
                                                            {
                                                                <span>@before</span>
                                                            }
                                                            <div class="audio-player-wrapper">
                                                                <audio src="@url" controls class="message-audio"></audio>
                                                            </div>
                                                            if (!string.IsNullOrWhiteSpace(after))
                                                            {
                                                                <span>@after</span>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            @msg.Content
                                                        }
                                                    }
                                                    else
                                                    {
                                                        @if (msg.Content.StartsWith("IMPORTANT: "))
                                                        {
                                                            <span style="color: #e01e5a; font-weight: bold;">@msg.Content</span>
                                                        }
                                                        else
                                                        {
                                                            @msg.Content
                                                        }
                                                    }

                                                    @if (msg.UpdatedAt.HasValue)
                                                    {
                                                        <span class="edited-badge">(edited)</span>
                                                    }
                                                </div>
                                            }
                                            
                                            <div class="message-reactions">
                                                @if (msg.Reactions != null && msg.Reactions.Any())
                                                {
                                                    var groupedReactions = msg.Reactions.GroupBy(r => r.Emoji);
                                                    foreach (var reactionGroup in groupedReactions)
                                                    {
                                                        var hasReacted = reactionGroup.Any(r => r.UserId == CurrentUserId);
                                                        <button class="reaction-badge @(hasReacted ? "reacted" : "")" @onclick="@(() => ToggleReaction(msg.Id, reactionGroup.Key))" @onclick:stopPropagation>
                                                            <span class="emoji">@reactionGroup.Key</span>
                                                            <span class="count">@reactionGroup.Count()</span>
                                                        </button>
                                                    }
                                                }
                                            </div>

                                            @if (msg.ReplyCount > 0)
                                            {
                                                <div class="thread-replies-indicator" @onclick:stopPropagation @onclick="@(() => OpenThread(msg))">
                                                    <div class="reply-avatars flex -space-x-2">
                                                        <div class="w-5 h-5 rounded-md bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-[8px] border border-gray-800">
                                                            @GetInitials(msg.Username)
                                                        </div>
                                                    </div>
                                                    <span class="reply-count">@msg.ReplyCount @(msg.ReplyCount > 1 ? "replies" : "reply")</span>
                                                    <span class="view-thread-text">View thread</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                        </Virtualize>
                    }
                </div>
            }
        </div>

        <!-- Chat Input -->
        <div class="chat-input-container">
            <div class="chat-input-box" style="position: relative;">
                @if (_isAudioRecording)
                {
                    <div class="audio-recording-overlay !bg-[#1a1a1d] !border !border-red-500/30 !rounded-xl !shadow-[0_0_20px_rgba(220,38,38,0.15)] flex items-center justify-between p-3">
                        <div class="recording-status flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-red-500/10 flex items-center justify-center">
                                <i class="fas fa-microphone text-red-500 animate-pulse"></i>
                            </div>
                            <div class="audio-visualizer flex items-end gap-1 h-6">
                                <div class="bar animate-wave-1 bg-red-500 w-1.5 rounded-t-sm"></div>
                                <div class="bar animate-wave-2 bg-red-500 w-1.5 rounded-t-sm"></div>
                                <div class="bar animate-wave-3 bg-red-500 w-1.5 rounded-t-sm"></div>
                                <div class="bar animate-wave-4 bg-red-500 w-1.5 rounded-t-sm"></div>
                                <div class="bar animate-wave-5 bg-red-500 w-1.5 rounded-t-sm"></div>
                            </div>
                            <span class="text-red-400 font-mono font-bold text-lg">@_audioDurationString</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <button class="w-10 h-10 rounded-lg text-white/60 hover:text-white hover:bg-white/5 transition-all flex items-center justify-center" @onclick="CancelAudioRecording" title="Cancel">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                            <button class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-bold rounded-lg transition-all shadow-lg shadow-green-600/20 flex items-center gap-2" @onclick="StopAudioRecording">
                                <i class="fas fa-paper-plane"></i>
                                Send
                            </button>
                        </div>
                    </div>
                }
                <!-- Mentions Dropdown -->
                @if (_showMentionsList && _filteredMembers.Any())
                {
                    <div class="mentions-dropdown">
                        @foreach (var member in _filteredMembers)
                        {
                            <div class="mention-item @(member.Id == _selectedMentionId ? "selected" : "")" 
                                 @onclick="() => InsertMention(member.Username)">
                                @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                {
                                    <img src="@member.AvatarUrl" class="w-6 h-6 rounded-md object-cover" alt="@member.Username" />
                                }
                                else
                                {
                                    <div class="w-6 h-6 rounded-md bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-[10px]">
                                        @GetInitials(member.Username)
                                    </div>
                                }
                                <span class="ml-2 text-sm">@member.Username</span>
                            </div>
                        }
                    </div>
                }

                @if (_showFormattingBar)
                {
                    <div class="formatting-bar flex items-center gap-1 px-3 py-2 border-b border-white/5 bg-white/5 rounded-t-xl">
                        <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors font-serif font-bold" @onclick='() => ApplyFormat("**")' title="Bold (Ctrl+B)">B</button>
                        <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors font-serif italic" @onclick='() => ApplyFormat("*")' title="Italic (Ctrl+I)">I</button>
                        <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors font-serif line-through" @onclick='() => ApplyFormat("~~")' title="Strikethrough">S</button>
                        <div class="w-px h-4 bg-white/20 mx-1"></div>
                        <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors font-mono font-bold" @onclick='() => ApplyFormat("`")' title="Code"><i class="fas fa-code"></i></button>
                        <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors" @onclick='() => ApplyFormat("```\n", "\n```")' title="Code Block"><i class="fas fa-file-code"></i></button>
                    </div>
                }

                <div class="flex items-end bg-transparent gap-2 p-1">
                    <textarea @ref="_textAreaRef"
                              value="@_newMessageContent"
                              @oninput="@((ChangeEventArgs e) => OnChatInputChanged(e.Value?.ToString() ?? ""))"
                              @onkeydown="HandleKeyDown"
                              placeholder="@($"Message #{(_currentChannelName?.StartsWith("#") == true ? _currentChannelName.Substring(1) : _currentChannelName)}")"
                              title="Press Enter to send. Press Shift+Enter for a new line."
                              class="flex-1 bg-transparent border-none focus:ring-0 text-white p-3 min-h-[44px] max-h-[200px] resize-none overflow-y-auto"
                              rows="1"></textarea>
                    
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg @(string.IsNullOrWhiteSpace(_newMessageContent) ? "text-white/20" : "text-white bg-green-600 hover:bg-green-700") transition-all shrink-0 mb-1.5 mr-1"
                            @onclick="SendMessage"
                            disabled="@(string.IsNullOrWhiteSpace(_newMessageContent))"
                            title="Send message (Enter)">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                    </button>
                </div>

                <div class="bottom-toolbar flex justify-between items-center px-2 py-1 border-t border-white/5">
                    <div class="toolbar-left flex items-center gap-1">
                        <InputFile id="chat-file-upload" OnChange="HandleFileUpload" accept="image/*" style="display: none;" />
                        <label for="chat-file-upload" class="m-0 flex cursor-pointer">
                            <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            </span>
                        </label>
                        <div class="w-px h-5 bg-white/10 mx-1"></div>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="OpenVideoRecorder" title="Record video">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="StartAudioRecording" title="Record audio">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="@((e) => OpenEmojiPicker(e, default))" title="Add emoji">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="TriggerMention" title="Mention someone">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors @(_showFormattingBar ? "text-white bg-white/10 rounded" : "")" @onclick="ToggleFormatting" title="Formatting">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thread Sidebar -->
    @if (_activeThreadParent != null)
    {
        <div class="thread-sidebar">
            <div class="thread-header">
                <div style="display: flex; flex-direction: column;">
                    <h3 style="margin: 0; color: var(--flux-main-text); font-size: 1.1rem; font-weight: 700;">Thread</h3>
                    <span style="font-size: 0.8rem; color: rgba(204, 220, 219, 0.6);">#@_currentChannelName</span>
                </div>
                <button class="p-2 text-white/40 hover:text-white transition-colors" @onclick="CloseThread">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>

            <div class="thread-viewport" @ref="_threadViewport">
                <!-- Parent Message -->
                <div class="thread-parent-message">
                    @if (!string.IsNullOrEmpty(_activeThreadParent.AvatarUrl))
                    {
                        <img src="@_activeThreadParent.AvatarUrl" class="w-9 h-9 rounded-lg object-cover flex-shrink-0" alt="@_activeThreadParent.Username" />
                    }
                    else
                    {
                        <div class="w-9 h-9 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-xs flex-shrink-0">
                            @GetInitials(_activeThreadParent.Username)
                        </div>
                    }
                    <div class="message-content">
                        <div class="message-meta">
                            <span class="username">@_activeThreadParent.Username</span>
                            <span class="timestamp">@_activeThreadParent.CreatedAt.ToString("h:mm tt")</span>
                        </div>
                        <div class="message-bubble">@_activeThreadParent.Content</div>
                    </div>
                </div>
                
                <div class="thread-divider">
                    <span>@_messages.Count(m => m.ParentMessageId == _activeThreadParent.Id) replies</span>
                </div>

                <!-- Child Messages -->
                @foreach (var msg in _messages.Where(m => m.ParentMessageId == _activeThreadParent.Id).OrderBy(m => m.CreatedAt).ToList())
                {
                    <div class="message-group">
                        @if (!string.IsNullOrEmpty(msg.AvatarUrl))
                        {
                            <img src="@msg.AvatarUrl" class="w-9 h-9 rounded-lg object-cover flex-shrink-0" alt="@msg.Username" />
                        }
                        else
                        {
                            <div class="w-9 h-9 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-xs flex-shrink-0">
                                @GetInitials(msg.Username)
                            </div>
                        }
                        <div class="message-content">
                            <div class="message-meta">
                                <span class="username">@msg.Username</span>
                                <span class="timestamp">@msg.CreatedAt.ToString("h:mm tt")</span>
                            </div>
                            <div class="message-bubble">@msg.Content</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Thread Input -->
            <div class="thread-input-container p-4">
                <div class="chat-input-box bg-white/5 border border-white/10 rounded-xl overflow-hidden">
                    <div class="flex items-end bg-transparent gap-2 p-1">
                        <textarea @ref="_threadTextAreaRef"
                                  @bind="_newThreadMessageContent"
                                  @bind:event="oninput"
                                  @onkeydown="HandleThreadKeyDown"
                                  placeholder="Reply..."
                                  class="flex-1 bg-transparent border-none focus:ring-0 text-white p-3 min-h-[44px] max-h-[150px] resize-none overflow-y-auto"
                                  rows="1"></textarea>
                        
                        <button class="w-9 h-9 flex items-center justify-center rounded-lg @(string.IsNullOrWhiteSpace(_newThreadMessageContent) ? "text-white/20" : "text-white bg-green-600 hover:bg-green-700") transition-all shrink-0 mb-1.5 mr-1"
                                @onclick="SendThreadMessage"
                                disabled="@(string.IsNullOrWhiteSpace(_newThreadMessageContent))"
                                title="Send message (Enter)">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                        </button>
                    </div>

                    <div class="bottom-toolbar flex justify-between items-center px-2 py-1 border-t border-white/5">
                        <div class="toolbar-left flex items-center gap-1">
                            <button class="p-1.5 text-white/40 hover:text-white transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            </button>
                            <button class="p-1.5 text-white/40 hover:text-white transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Profile Sidebar -->
    @if (_activeProfile != null)
    {
        <div class="profile-sidebar">
            <div class="profile-header">
                <div style="display: flex; flex-direction: column;">
                    <h3 style="margin: 0; color: var(--flux-main-text); font-size: 1.1rem; font-weight: 700;">Profile</h3>
                </div>
                <button class="p-2 text-white/40 hover:text-white transition-colors" @onclick="CloseProfile">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>

            <div class="profile-body">
                <div class="profile-avatar-container">
                    @if (!string.IsNullOrEmpty(_activeProfile.AvatarUrl))
                    {
                        <img src="@_activeProfile.AvatarUrl" class="profile-avatar-large" alt="@_activeProfile.Username" />
                    }
                    else
                    {
                        <div class="profile-avatar-large profile-avatar-placeholder">
                            @GetInitials(_activeProfile.Username)
                        </div>
                    }
                </div>
                
                <div class="profile-info-section">
                    <h2 class="profile-name">@(_activeProfile.FullName ?? _activeProfile.Username)</h2>
                    <p class="profile-username">@_activeProfile.Username</p>
                    
                    @if (_activeProfile.Id != CurrentUserId)
                    {
                        <div class="profile-actions">
                            <button class="w-full py-2 bg-transparent border border-white/20 hover:bg-white/5 text-white rounded-md transition-colors">Message</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Emoji Picker Overlay -->
@if (_showEmojiPicker)
{
    <div class="menu-overlay" @onclick="CloseEmojiPicker" @oncontextmenu:preventDefault="true"></div>
    <div class="emoji-picker" style="left: @(_emojiPickerX - 100)px; top: @(_emojiPickerY)px;" @onclick:stopPropagation>
        <emoji-picker id="main-emoji-picker" class="light"></emoji-picker>
    </div>
}

<!-- Message Actions Menu Overlay -->
@if (_showMessageMenu)
{
    <div class="menu-overlay" @onclick="CloseMessageMenu" @oncontextmenu:preventDefault="true"></div>
    <div class="message-context-menu" style="left: @(_menuX)px; top: @(_menuY)px;">
        <div class="flex flex-col py-1">
            <button class="flex items-center gap-2 px-4 py-2 hover:bg-white/5 text-sm text-white text-left" @onclick="@(() => HandleAction("Reply"))">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l5 5m-5-5l5-5" /></svg>
                Reply in Thread
            </button>
            <button class="flex items-center gap-2 px-4 py-2 hover:bg-white/5 text-sm text-white text-left" @onclick="@(() => HandleAction("Edit"))">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                Edit
            </button>
            <div class="h-px bg-white/10 my-1"></div>
            <button class="flex items-center gap-2 px-4 py-2 hover:bg-red-500/10 text-sm text-red-500 text-left" @onclick="@(() => HandleAction("Delete"))">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                Delete
            </button>
        </div>
    </div>
}

<!-- Delete Confirm Dialog -->
@if (_showDeleteDialog)
{
    <div class="fixed inset-0 z-[2000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @onclick="() => _showDeleteDialog = false">
        <div class="glass-dialog w-full max-w-md bg-[#1a1a1d] border border-white/10 rounded-2xl p-6 shadow-2xl animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
            <h3 class="text-xl font-bold text-white mb-2">Delete Message</h3>
            <p class="text-white/60 mb-8 leading-relaxed">Are you sure you want to delete this message? This cannot be undone.</p>
            <div class="flex justify-end gap-3">
                <button class="px-4 py-2 text-sm font-medium text-white/60 hover:text-white transition-colors" @onclick="() => _showDeleteDialog = false">Cancel</button>
                <button class="px-6 py-2 text-sm font-bold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors shadow-lg shadow-red-600/20" @onclick="ExecuteDeleteMessage">Delete</button>
            </div>
        </div>
    </div>
}

<!-- Video Recorder Dialog -->
@if (_showVideoRecorder)
{
    <div class="video-recorder-overlay" @onclick="CloseVideoRecorder">
        <div class="video-recorder-dialog" @onclick:stopPropagation>
            <div class="recorder-header flex justify-between items-center p-4 border-b border-white/5">
                <h3 class="text-white font-bold">Record video clip</h3>
                <button class="p-2 text-white/40 hover:text-white transition-colors" @onclick="CloseVideoRecorder">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            
            <div class="recorder-body relative bg-black aspect-video flex items-center justify-center">
                <video id="videoPreview" autoplay playsinline class="w-full h-full object-cover"></video>
                @if (_isCameraError)
                {
                    <div class="camera-error-overlay absolute inset-0 flex flex-col items-center justify-center p-6 text-center bg-black/90">
                        <svg class="w-12 h-12 text-yellow-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                        <h4 class="text-lg font-bold text-white mb-2">Can't access camera</h4>
                        <p class="text-white/60 text-sm max-w-xs">Check your browser settings to make sure Flux has permission to access your camera, and try again.</p>
                    </div>
                }
            </div>
            
            <div class="recorder-footer flex items-center gap-4 p-4 bg-[#1a1a1d] border-t border-white/5">
                @if (_recordedVideoUrl != null)
                {
                    <button class="flex items-center gap-2 px-3 py-1.5 text-sm text-white/60 hover:text-white transition-colors" @onclick="DownloadVideo">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                        Download Video
                    </button>
                    <div class="flex-1"></div>
                    <button class="px-4 py-2 text-sm font-medium text-white/60 hover:text-white transition-colors" @onclick="RetakeVideo" disabled="@_isUploading">Retake</button>
                    <button class="px-6 py-2 text-sm font-bold bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors flex items-center gap-2" @onclick="UploadVideo" disabled="@_isUploading">
                        @if (_isUploading) { <div class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin"></div> }
                        Upload Video
                    </button>
                }
                else
                {
                    <div class="device-controls flex gap-2">
                        <button class="p-2 rounded-lg @(_currentCaptureMode == "camera" ? "bg-white/10 text-white" : "text-white/40 hover:text-white hover:bg-white/5")" @onclick='() => SwitchCaptureMode("camera")' title="Camera">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                        </button>
                        <button class="p-2 rounded-lg @(_currentCaptureMode == "screen" ? "bg-white/10 text-white" : "text-white/40 hover:text-white hover:bg-white/5")" @onclick='() => SwitchCaptureMode("screen")' title="Screen Share">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                        </button>
                        <button class="p-2 rounded-lg @(_isMicEnabled ? "text-white/40 hover:text-white" : "bg-red-500/20 text-red-500")" @onclick="ToggleMic" title="Toggle Microphone">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@(_isMicEnabled ? "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" : "M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z")" /></svg>
                        </button>
                    </div>
                    <div class="flex-1"></div>
                    @if (_isCountingDown)
                    {
                        <div class="px-6 py-2 text-sm font-bold bg-red-600/50 text-white rounded-lg">Starting in @_countdownSeconds...</div>
                    }
                    else if (_isRecording)
                    {
                        <div class="flex items-center gap-3 mr-4">
                            <div class="w-3 h-3 bg-red-600 rounded-full animate-pulse shadow-[0_0_10px_rgba(220,38,38,0.5)]"></div>
                            <span class="text-white font-mono font-bold text-lg">@_recordingDurationString</span>
                        </div>
                        <button class="px-6 py-2 text-sm font-bold bg-white text-black rounded-lg hover:bg-white/90 transition-colors" @onclick="StopRecording">Stop Recording</button>
                    }
                    else
                    {
                        <button class="px-8 py-2 text-sm font-bold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-all shadow-lg shadow-red-600/20" @onclick="StartRecording" disabled="@_isCameraError">Record</button>
                    }
                }
            </div>
        </div>
    </div>
}


<style>
    /* 3-Panel Layout */
    .chat-main-wrapper {
        display: flex;
        flex: 1;
        width: 100%;
        overflow: hidden;
    }

    .chat-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: transparent;
        transition: flex 0.3s ease;
    }

    /* Thread Sidebar */
    .thread-sidebar {
        width: 400px;
        background: var(--flux-glass-heavy);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border-left: 1px solid var(--flux-border);
        display: flex;
        flex-direction: column;
        z-index: 50;
        animation: slide-in 0.2s ease-out;
    }

    @@keyframes slide-in {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
    }

    .thread-header {
        height: 60px;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--flux-border);
    }

    .thread-viewport {
        flex: 1;
        overflow-y: auto;
        padding: 20px 0;
    }

    .thread-parent-message {
        padding: 0 20px 20px 20px;
        display: flex;
        gap: 14px;
    }

    .thread-divider {
        display: flex;
        align-items: center;
        padding: 0 20px;
        margin: 10px 0;
        color: rgba(204, 220, 219, 0.6);
        font-size: 0.8rem;
    }

    .thread-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--flux-border);
        margin-left: 10px;
    }

    .thread-input-container {
        padding: 0 20px 20px 20px;
    }

    /* Thread Replies Indicator */
    .thread-replies-indicator {
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 8px;
        border-radius: 6px;
        cursor: pointer;
        width: fit-content;
        transition: background-color 0.2s;
        border: 1px solid transparent;
    }

    .thread-replies-indicator:hover {
        background-color: var(--flux-glass-white);
        border-color: var(--flux-border);
    }

    .reply-count {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--flux-primary);
    }

    .view-thread-text {
        font-size: 0.8rem;
        color: rgba(204, 220, 219, 0.6);
        opacity: 0;
        transition: opacity 0.2s;
    }

    .thread-replies-indicator:hover .view-thread-text {
        opacity: 1;
    }

    .active-thread {
        background-color: rgba(19, 94, 75, 0.1) !important;
        border-left: 3px solid var(--flux-primary) !important;
    }

    /* Profile Sidebar */
    .profile-sidebar {
        width: 400px;
        background: var(--flux-glass-heavy);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border-left: 1px solid var(--flux-border);
        display: flex;
        flex-direction: column;
        z-index: 50;
        animation: slide-in 0.2s ease-out;
    }
    
    .profile-header {
        height: 60px;
        padding: 0 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--flux-border);
    }
    
    .profile-body {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 24px;
    }
    
    .profile-avatar-container {
        width: 256px;
        height: 256px;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }
    
    .profile-avatar-large {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .profile-avatar-placeholder {
        background-color: var(--flux-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        font-weight: 700;
        color: white;
    }
    
    .profile-info-section {
        width: 100%;
        display: flex;
        flex-direction: column;
    }
    
    .profile-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--flux-main-text);
        margin: 0;
    }
    
    .profile-username {
        font-size: 0.9rem;
        color: rgba(204, 220, 219, 0.7);
        margin: 4px 0 16px 0;
    }
    
    .profile-actions {
        width: 100%;
        margin-top: 16px;
    }

    /* Channel Hero */
    .channel-hero {
        margin: 88px 20px 16px 20px;
    }
    
    .hero-title {
        display: flex;
        align-items: center;
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--flux-main-text);
    }
    
    .hero-desc {
        font-size: 1rem;
        font-weight: 400;
        color: rgba(204, 220, 219, 0.8);
        margin-bottom: 16px;
    }

    /* Message Actions Menu */
    .menu-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1000;
        background: transparent;
    }

    .message-context-menu {
        position: fixed;
        z-index: 1001;
        background: var(--flux-glass-heavy);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--flux-glass-white);
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(19, 94, 75, 0.2);
        min-width: 200px;
        padding: 4px 0;
        animation: fade-in 0.1s ease-out;
        color: var(--flux-main-text);
    }

    @@keyframes fade-in {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Date Divider */
    .date-divider {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 20px 0;
        position: relative;
    }


@page "/workspace/{WorkspaceId:guid}/chat/{ChannelId:guid}"
@page "/workspace/{WorkspaceId:guid}/dms/{ChannelId:guid}"
@layout Flux.Components.Layout.WorkspaceLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@using Flux.Features.Messages.EditMessage
@using Flux.Features.Messages.SendMessage
@using Flux.Features.Messages.GetMessages
@using Flux.Components.Pages.ChatSub
@implements IAsyncDisposable

<PageTitle>Chat - @(_currentChannelName ?? "Loading...")</PageTitle>

@if (Navigation.Uri.Contains("/dms/"))
{
    <Flux.Components.Layout.DmSidebar />
}
else
{
    <Flux.Components.Layout.WorkspaceSidebar />
}

<div class="chat-main-wrapper flex-1">
    <div class="chat-container">
        <!-- Chat Header -->
        <div class="chat-header">
            <div class="flex items-center gap-3 w-full">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-xl @(StateService.ActiveCallChannelIds.Contains(ChannelId) ? "bg-[#3E9E60]/20 text-[#3E9E60]" : "bg-blue-500/10 text-blue-400") flex items-center justify-center">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                    </div>
                    <div>
                        <h2 class="text-base font-bold leading-none @(StateService.ActiveCallChannelIds.Contains(ChannelId) ? "text-[#3E9E60]" : "text-white")">@(_currentChannelName ?? "channel-name")</h2>
                        @if (StateService.ActiveCallChannelIds.Contains(ChannelId))
                        {
                            <p class="text-[10px] text-[#3E9E60]/80 uppercase tracking-widest mt-1 flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full bg-[#3E9E60] animate-pulse"></span> Huddle in progress
                            </p>
                        }
                        else
                        {
                            <p class="text-[10px] text-white/30 uppercase tracking-widest mt-1">Active Channel</p>
                        }
                    </div>
                </div>
                <div class="flex-1"></div>
                <div class="flex items-center gap-1">
                    @if (StateService.ActiveCallChannelIds.Contains(ChannelId))
                    {
                        <button class="px-3 py-1.5 bg-[#3E9E60] hover:bg-[#348b52] text-white text-xs font-bold rounded-md flex items-center gap-1.5 transition-colors animate-pulse" @onclick="StartHuddle" title="Join Huddle">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                            Join
                        </button>
                    }
                    else
                    {
                        <button class="p-2 text-white/20 hover:text-[#3E9E60] transition-colors" @onclick="StartHuddle" title="Start Huddle">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                        </button>
                    }
                    <button class="p-2 text-white/20 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </button>
                    <button class="p-2 text-white/20 hover:text-white transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Messages Viewport -->
        <div class="messages-viewport" @ref="_messagesViewport">
            @if (_isLoading)
            {
                <div class="flex flex-col items-center justify-center h-full gap-4">
                    <div class="w-10 h-10 border-4 border-blue-500/20 border-t-blue-500 rounded-full animate-spin"></div>
                    <p class="text-sm font-medium text-white/60">Loading messages...</p>
                </div>
            }
            else
            {
                <div class="message-list">
                    @if (!_messages.Any())
                    {
                        <div class="channel-hero">
                            <p class="hero-title"># @(_currentChannelName ?? "channel-name")</p>
                            <p class="hero-desc">This is the very beginning of the <strong>@(_currentChannelName ?? "channel-name")</strong> channel.</p>
                        </div>
                    }
                    else
                    {
                        @if (_hasMoreMessages)
                        {
                            <div class="flex justify-center my-4">
                                <button class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-white/60 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg transition-all disabled:opacity-50" 
                                        @onclick="LoadMoreMessages" 
                                        disabled="@_isLoadingMore">
                                    @if (_isLoadingMore)
                                    {
                                        <div class="w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin"></div>
                                    }
                                    else
                                    {
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                                    }
                                    Load older messages
                                </button>
                            </div>
                        }

                        <div class="channel-hero">
                            <p class="hero-title"># @(_currentChannelName ?? "channel-name")</p>
                            <p class="hero-desc">This is the very beginning of the <strong>@(_currentChannelName ?? "channel-name")</strong> channel.</p>
                        </div>

                        <Virtualize @ref="_messageVirtualizeRef" Items="@RootMessages" Context="msg" OverscanCount="20">
                            @{
                                var meta = GetMessageMeta(msg);
                                if (meta.ShowDate)
                                {
                                    <div class="date-divider">
                                        <hr />
                                        <span>@meta.DateLabel</span>
                                    </div>
                                }

                                <MessageItem Message="msg"
                                             IsCompact="meta.IsCompact"
                                             IsSelf="@(msg.UserId == CurrentUserId)"
                                             IsActiveThread="@(_activeThreadParent?.Id == msg.Id)"
                                             IsEditing="@(_editingMessageId == msg.Id)"
                                             EditText="@_editMessageContent"
                                             CurrentUserId="CurrentUserId"
                                             Initials="@GetInitials(msg.Username)"
                                             WorkspaceMembers="StateService.Members"
                                             OnReply="@(() => OpenThread(msg))"
                                             OnEdit="@(() => HandleQuickAction(msg, "Edit"))"
                                             OnDelete="@(() => HandleQuickAction(msg, "Delete"))"
                                             OnReaction="@((e) => OpenEmojiPicker(e, msg.Id))"
                                             OnToggleReaction="@((emoji) => ToggleReaction(msg.Id, emoji))"
                                             OnProfileClick="@(() => OpenProfile(msg.UserId))"
                                             OnMemberMentionClick="OpenProfile"
                                             OnCancelEdit="CancelEdit"
                                             OnSaveEdit="SaveEditMessage"
                                             OnEditTextChanged="@((val) => _editMessageContent = val)"
                                             OnContextMenu="@((e) => OpenMessageMenu(e, msg))" />
                            }
                        </Virtualize>
                    }
                </div>
            }
        </div>

        <!-- Chat Input -->
        <div class="chat-input-container">
            <div class="chat-input-box" style="position: relative;">
                @if (_isAudioRecording)
                {
                    <AudioRecordingOverlay DurationString="@_audioDurationString"
                                          OnCancel="CancelAudioRecording"
                                          OnStop="StopAudioRecording" />
                }
                
                <!-- Mentions Dropdown -->
                @if (_showMentionsList)
                {
                    <MentionsPopup Members="_filteredMembers"
                                  SelectedMemberId="_selectedMentionId"
                                  OnMemberSelected="@((m) => InsertMention(m.Username))" />
                }

                <div class="flex items-end bg-transparent gap-2 p-1 relative">
                    <textarea @ref="_textAreaRef"
                              value="@_newMessageContent"
                              @oninput="@((ChangeEventArgs e) => OnChatInputChanged(e.Value?.ToString() ?? ""))"
                              placeholder="@($"Message #{(_currentChannelName?.StartsWith("#") == true ? _currentChannelName.Substring(1) : _currentChannelName)}")"
                              title="Press Enter to send. Press Shift+Enter for a new line."
                              class="flex-1 bg-transparent border-none focus:ring-0 text-white p-3 min-h-[44px] max-h-[80px] resize-none overflow-y-auto"
                              rows="1"></textarea>
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg @(string.IsNullOrWhiteSpace(_newMessageContent) ? "text-white/20" : "text-white bg-green-600 hover:bg-green-700") transition-all shrink-0 mb-1.5 mr-1"
                            @onclick="SendMessage"
                            disabled="@(string.IsNullOrWhiteSpace(_newMessageContent))"
                            title="Send message (Enter)">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                    </button>
                </div>

                <div class="bottom-toolbar flex justify-between items-center px-2 py-1 border-t border-white/5">
                    <div class="toolbar-left flex items-center gap-1">
                        <InputFile id="chat-file-upload" OnChange="HandleFileUpload" accept="image/*" style="display: none;" />
                        <label for="chat-file-upload" class="m-0 flex cursor-pointer">
                            <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            </span>
                        </label>
                        <div class="w-px h-5 bg-white/10 mx-1"></div>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="OpenVideoRecorder" title="Record video">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="StartAudioRecording" title="Record audio">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="@((e) => OpenEmojiPicker(e, default))" title="Add emoji">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors" @onclick="TriggerMention" title="Mention someone">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206" /></svg>
                        </button>
                        <button class="p-1.5 text-white/40 hover:text-white transition-colors @(_showFormattingBar ? "text-white bg-white/10 rounded" : "")" @onclick="ToggleFormatting" title="Formatting">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" /></svg>
                        </button>

                        @if (_showFormattingBar)
                        {
                            <div class="w-px h-5 bg-white/10 mx-1"></div>
                            <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors font-bold text-xs" @onclick='() => ApplyFormat("**")' title="Bold">B</button>
                            <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors italic text-xs" @onclick='() => ApplyFormat("*")' title="Italic">I</button>
                            <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors font-serif line-through text-xs" @onclick='() => ApplyFormat("~~")' title="Strikethrough">S</button>
                            <button class="w-7 h-7 rounded hover:bg-white/10 text-white/70 hover:text-white flex items-center justify-center transition-colors" @onclick='() => ApplyFormat("```\n", "\n```")' title="Code Block">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Thread Sidebar -->
    @if (_activeThreadParent != null)
    {
        <ThreadSidebar @ref="_threadSidebar"
                       ParentMessage="_activeThreadParent"
                       ThreadMessages="@(_messages.Where(m => m.ParentMessageId == _activeThreadParent.Id).OrderBy(m => m.CreatedAt).ToList())"
                       ChannelName="@_currentChannelName"
                       NewMessageContent="@_newThreadMessageContent"
                       CurrentUserId="CurrentUserId"
                       WorkspaceMembers="StateService.Members"
                       OnClose="CloseThread"
                       OnInputChanged="OnThreadInputChanged"
                       OnSendMessage="SendThreadMessage"
                       OnKeyDown="HandleThreadKeyDown"
                       OnOpenEmojiPicker="@((args) => OpenEmojiPicker(args.Args, args.MessageId.GetValueOrDefault()))"
                       OnProfileClick="OpenProfile"
                       OnEdit="@((msg) => HandleQuickAction(msg, "Edit"))"
                       OnDelete="HandleQuickActionById"
                       OnReaction="@((args) => OpenEmojiPicker(args.Args, args.MessageId.GetValueOrDefault()))"
                       OnToggleReaction="@((args) => ToggleReaction(args.MessageId, args.Emoji))" />
    }

    <!-- Profile Sidebar -->
    @if (_activeProfile != null)
    {
        <ProfileSidebar Profile="_activeProfile"
                        CurrentUserId="CurrentUserId"
                        OnClose="CloseProfile"
                        OnMessageClick="@(() => StartDirectMessage(_activeProfile.Id))" />
    }
</div>

<!-- Emoji Picker Overlay -->
@if (_showEmojiPicker)
{
    <div class="menu-overlay" @onclick="CloseEmojiPicker" @oncontextmenu:preventDefault="true"></div>
    <div class="emoji-picker" style="left: @(_emojiPickerX - 100)px; top: @(_emojiPickerY)px;" @onclick:stopPropagation>
        <emoji-picker id="main-emoji-picker" class="light"></emoji-picker>
    </div>
}

<!-- Message Actions Menu Overlay -->
@if (_showMessageMenu)
{
    <div class="menu-overlay" @onclick="CloseMessageMenu" @oncontextmenu:preventDefault="true"></div>
    <div class="message-context-menu" style="left: @(_menuX)px; top: @(_menuY)px;">
        <div class="flex flex-col py-1">
            <button class="flex items-center gap-2 px-4 py-2 hover:bg-white/5 text-sm text-white text-left" @onclick="@(() => HandleAction("Reply"))">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l5 5m-5-5l5-5" /></svg>
                Reply in Thread
            </button>
            <button class="flex items-center gap-2 px-4 py-2 hover:bg-white/5 text-sm text-white text-left" @onclick="@(() => HandleAction("Edit"))">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                Edit
            </button>
            <div class="h-px bg-white/10 my-1"></div>
            <button class="flex items-center gap-2 px-4 py-2 hover:bg-red-500/10 text-sm text-red-500 text-left" @onclick="@(() => HandleAction("Delete"))">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                Delete
            </button>
        </div>
    </div>
}

<!-- Delete Confirm Dialog -->
@if (_showDeleteDialog)
{
    <div class="fixed inset-0 z-[2000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @onclick="() => _showDeleteDialog = false">
        <div class="glass-dialog w-full max-w-md bg-[#1a1a1d] border border-white/10 rounded-2xl p-6 shadow-2xl animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
            <h3 class="text-xl font-bold text-white mb-2">Delete Message</h3>
            <p class="text-white/60 mb-8 leading-relaxed">Are you sure you want to delete this message? This cannot be undone.</p>
            <div class="flex justify-end gap-3">
                <button class="px-4 py-2 text-sm font-medium text-white/60 hover:text-white transition-colors" @onclick="() => _showDeleteDialog = false">Cancel</button>
                <button class="px-6 py-2 text-sm font-bold bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors shadow-lg shadow-red-600/20" @onclick="ExecuteDeleteMessage">Delete</button>
            </div>
        </div>
    </div>
}

<!-- Video Recorder Dialog -->
@if (_showVideoRecorder)
{
    <VideoRecorderModal IsCameraError="@_isCameraError"
                        IsRecording="@_isRecording"
                        RecordedVideoUrl="@_recordedVideoUrl"
                        CurrentCaptureMode="@_currentCaptureMode"
                        IsMicEnabled="@_isMicEnabled"
                        IsUploading="@_isUploading"
                        RecordingDurationString="@_recordingDurationString"
                        CountdownSeconds="@_countdownSeconds"
                        IsCountingDown="@_isCountingDown"
                        OnClose="CloseVideoRecorder"
                        OnStart="StartRecording"
                        OnStop="StopRecording"
                        OnRetake="RetakeVideo"
                        OnDownload="DownloadVideo"
                        OnUpload="UploadVideo"
                        OnSwitchCaptureMode="SwitchCaptureMode"
                        OnToggleMic="ToggleCamera" />
}

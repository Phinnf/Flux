        display: flex;
        flex: 1;
        width: 100%;
        overflow: hidden;
    }

    .chat-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: transparent;
        transition: flex 0.3s ease;
    }

    /* Thread Sidebar */
    .thread-sidebar {
        width: 400px;
        background: var(--flux-glass-heavy);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border-left: 1px solid var(--flux-border);
        display: flex;

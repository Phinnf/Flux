@page "/workspaces"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NavigationManager Navigation
@inject FluxClientService FluxService
@inject AuthenticationStateProvider AuthStateProvider
@layout Flux.Components.Layout.MainLayout

<PageTitle>Your Workspaces - Flux</PageTitle>

<div style="padding: 40px; max-width: 1200px; margin: 0 auto;">
    
    <div style="text-align: center; margin-bottom: 50px;">
        <FluentLabel Typo="Typography.H2" Style="font-weight: bold;">Welcome to Flux!</FluentLabel>
        <FluentLabel Typo="Typography.Body" Style="margin-top: 10px; opacity: 0.8;">
            Choose a workspace to join your team, or create a new one.
        </FluentLabel>
    </div>

    @if (_workspaces == null)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 200px;">
            <FluentProgressRing />
            <FluentLabel Style="margin-top: 15px;">Finding your workspaces...</FluentLabel>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
            @foreach (var workspace in _workspaces)
            {
                <FluentCard Style="padding: 20px; cursor: pointer; transition: transform 0.2s; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.2); color: white;" @onclick="() => SelectWorkspace(workspace)">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="15">
                        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="10" VerticalAlignment="VerticalAlignment.Center">
                            <div style="background-color: var(--neutral-layer-2); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.2rem; color: var(--flux-primary);">
                                @(workspace.Name?.Length > 0 ? workspace.Name[0].ToString().ToUpper() : "?")
                            </div>
                            <FluentLabel Typo="Typography.H4" Style="margin: 0;">@workspace.Name</FluentLabel>
                        </FluentStack>
                        
                        <FluentLabel Typo="Typography.Body" Style="height: 40px; overflow: hidden; text-overflow: ellipsis; color: var(--neutral-foreground-hint);">
                            @(string.IsNullOrEmpty(workspace.Description) ? "No description provided." : workspace.Description)
                        </FluentLabel>

                        <FluentDivider />

                        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
                            <div @onclick:stopPropagation="true">
                                <FluentButton Appearance="Appearance.Stealth" 
                                              IconStart="@(new Icons.Regular.Size16.Delete())" 
                                              Color="Color.Error" 
                                              OnClick="() => DeleteWorkspace(workspace)"
                                              Title="Delete Workspace">
                                </FluentButton>
                            </div>
                            <FluentButton Appearance="Appearance.Accent" IconEnd="@(new Icons.Regular.Size16.ArrowRight())">Join Workspace</FluentButton>
                        </FluentStack>
                    </FluentStack>
                </FluentCard>
            }

            <!-- Create New Workspace Card -->
            <FluentCard Style="padding: 20px; border: 2px dashed var(--neutral-stroke-rest); background: transparent; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; min-height: 200px; transition: background-color 0.2s;" 
                        @onclick="() => _showCreateDialog = true">
                <FluentIcon Value="@(new Icons.Regular.Size48.AddCircle())" Color="Color.Accent" Style="margin-bottom: 15px;" />
                <FluentLabel Typo="Typography.H5">Create New Workspace</FluentLabel>
            </FluentCard>
        </div>
    }
</div>

@* Create Workspace Dialog *@
<FluentDialog Hidden="!_showCreateDialog" Modal="true" TrapFocus="true" @onclick:stopPropagation>
    <div style="padding: 20px; width: 400px;">
        <FluentLabel Typo="Typography.H3" Style="margin-bottom: 20px;">New Workspace</FluentLabel>
        
        <FluentTextField Label="Workspace Name" @bind-Value="_newWorkspaceName" Style="width: 100%; margin-bottom: 15px;" Required="true" />
        <FluentTextArea Label="Description" @bind-Value="_newWorkspaceDescription" Style="width: 100%; margin-bottom: 25px;" Rows="3" />
        
        <div style="display: flex; justify-content: flex-end; gap: 10px;">
            <FluentButton Appearance="Appearance.Stealth" OnClick="() => _showCreateDialog = false">Cancel</FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="CreateWorkspace" Disabled="@string.IsNullOrWhiteSpace(_newWorkspaceName)">Create & Join</FluentButton>
        </div>
    </div>
</FluentDialog>

@code {
    private List<WorkspaceSummary>? _workspaces;
    private Guid _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity is { IsAuthenticated: true })
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                _currentUserId = id;
            }
        }
        else 
        {
            Navigation.NavigateTo("/auth");
            return;
        }

        await LoadWorkspaces();
    }

    private async Task LoadWorkspaces()
    {
        try 
        {
            var result = await FluxService.GetWorkspacesAsync(_currentUserId);
            if (result.IsSuccess)
            {
                _workspaces = result.Value ?? new();
            }
            else
            {
                _workspaces = new();
            }
        }
        catch
        {
            _workspaces = new();
        }
    }

    private bool _showCreateDialog = false;
    private string _newWorkspaceName = "";
    private string _newWorkspaceDescription = "";

    private async Task SelectWorkspace(WorkspaceSummary workspace)
    {
        var channelsResult = await FluxService.GetChannelsAsync(workspace.Id, _currentUserId);
        
        if (channelsResult.IsSuccess && channelsResult.Value != null && channelsResult.Value.Any())
        {
            var firstChannel = channelsResult.Value.First();
            Navigation.NavigateTo($"/workspace/{workspace.Id}/chat/{firstChannel.Id}");
        }
        else
        {
            Navigation.NavigateTo($"/workspace/{workspace.Id}");
        }
    }

    private async Task DeleteWorkspace(WorkspaceSummary workspace)
    {
        var result = await FluxService.DeleteWorkspaceAsync(workspace.Id, _currentUserId);
        if (result.IsSuccess)
        {
            await LoadWorkspaces();
        }
    }

    private async Task CreateWorkspace()
    {
        if (string.IsNullOrWhiteSpace(_newWorkspaceName)) return;
        
        var result = await FluxService.CreateWorkspaceAsync(_currentUserId, _newWorkspaceName, _newWorkspaceDescription);
        
        if (result.IsSuccess && result.Value != null)
        {
            _newWorkspaceName = "";
            _newWorkspaceDescription = "";
            _showCreateDialog = false;
            
            // Immediately join the newly created workspace
            await SelectWorkspace(result.Value);
        }
    }
}

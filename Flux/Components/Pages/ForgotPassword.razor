@page "/forgot-password"
@using Flux.Infrastructure.Client
@using System.Text.RegularExpressions
@inject FluxClientService FluxService
@inject NavigationManager Navigation
@inject IToastService ToastService
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Forgot Password - Flux</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="logo">
                <FluentIcon Value="@(new Icons.Filled.Size32.Flash())" Color="Color.Custom" CustomColor="#4CB572" Style="margin-right: 8px;" />
                <h1>Flux</h1>
            </div>
            <h2>Reset your password</h2>
            <p>Enter your email and we'll send you an OTP to reset your password.</p>
        </div>

        @if (!_otpSent)
        {
            <div class="auth-form">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" @bind="_email" placeholder="name@company.com" class="form-input" />
                </div>

                <button class="btn-primary" @onclick="SendOtp" disabled="@_isLoading">
                    @if (_isLoading) { <FluentProgressRing Width="16px" Style="margin-right: 8px; stroke: white;" /> } Send OTP
                </button>
            </div>
        }
        else
        {
            <div class="auth-form">
                <div class="form-group">
                    <label>Enter 6-digit OTP sent to <span style="color: var(--flux-primary);">@_email</span></label>
                    <input type="text" @bind="_otp" placeholder="123456" class="form-input otp-input" maxlength="6" />
                </div>
                
                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" @bind="_newPassword" placeholder="Enter new password" class="form-input" />
                    <small class="hint-text">Must be at least 8 chars, 1 uppercase, 1 lowercase, 1 number, 1 special char.</small>
                </div>

                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" @bind="_confirmPassword" placeholder="Confirm new password" class="form-input" />
                </div>

                <div class="button-group">
                    <button class="btn-primary" @onclick="ResetPassword" disabled="@_isLoading">
                        @if (_isLoading) { <FluentProgressRing Width="16px" Style="margin-right: 8px; stroke: white;" /> } Reset Password
                    </button>
                    <button class="btn-text" @onclick="() => _otpSent = false" disabled="@_isLoading">Back</button>
                </div>
            </div>
        }

        <div class="auth-footer">
            Remember your password? <a href="/auth" class="auth-link">Log in</a>
        </div>
    </div>
</div>

<style>
    .auth-container {
        min-height: 100vh;
        width: 100vw;
        display: flex;
        align-items: center;
        justify-content: center;
        /* Match Auth.razor background if needed, or use a nice gradient */
        background: linear-gradient(135deg, #135E4B 0%, #4CB572 100%);
        font-family: 'Inter', sans-serif;
        color: white;
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        width: 100%;
        max-width: 420px;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .logo {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .logo h1 {
        font-size: 32px;
        font-weight: 800;
        color: white;
        margin: 0;
        letter-spacing: -1px;
    }

    .auth-header h2 {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin: 0 0 12px 0;
    }

    .auth-header p {
        color: rgba(255, 255, 255, 0.7);
        font-size: 14px;
        line-height: 1.5;
        margin: 0;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .form-group label {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.9);
    }

    .form-input {
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        font-size: 15px;
        color: white;
        transition: all 0.2s ease;
        width: 100%;
        box-sizing: border-box;
    }

    .form-input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .form-input:focus {
        outline: none;
        border-color: #4CB572;
        background: rgba(255, 255, 255, 0.1);
        box-shadow: 0 0 0 4px rgba(76, 181, 114, 0.2);
    }
    
    .otp-input {
        text-align: center;
        letter-spacing: 8px;
        font-size: 20px;
        font-weight: 700;
    }

    .hint-text {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.4;
    }

    .button-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 10px;
    }

    .btn-primary {
        background: #4CB572;
        color: white;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .btn-primary:hover:not(:disabled) {
        background: #3da163;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(76, 181, 114, 0.3);
    }
    
    .btn-primary:active {
        transform: translateY(0);
    }

    .btn-text {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        padding: 8px;
    }

    .btn-text:hover {
        color: white;
    }

    .btn-primary:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .auth-footer {
        text-align: center;
        margin-top: 32px;
        font-size: 14px;
        color: rgba(255, 255, 255, 0.6);
    }

    .auth-link {
        color: #4CB572;
        text-decoration: none;
        font-weight: 600;
    }

    .auth-link:hover {
        text-decoration: underline;
    }
</style>

@code {
    private string _email = "";
    private string _otp = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    
    private bool _isLoading = false;
    private bool _otpSent = false;

    private async Task SendOtp()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            ToastService.ShowError("Please enter your email.");
            return;
        }

        _isLoading = true;
        var result = await FluxService.ForgotPasswordAsync(_email);
        _isLoading = false;

        if (result.IsSuccess)
        {
            _otpSent = true;
            ToastService.ShowSuccess("If the email exists, an OTP has been sent.");
        }
        else
        {
            ToastService.ShowError(result.Error ?? "Failed to send OTP.");
        }
    }

    private async Task ResetPassword()
    {
        if (string.IsNullOrWhiteSpace(_otp) || _otp.Length != 6)
        {
            ToastService.ShowError("Please enter the 6-digit OTP.");
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            ToastService.ShowError("Please enter a new password.");
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            ToastService.ShowError("Passwords do not match.");
            return;
        }

        var regex = new Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$");
        if (!regex.IsMatch(_newPassword))
        {
            ToastService.ShowError("Password must be at least 8 chars, 1 uppercase, 1 lowercase, 1 number, 1 special char.");
            return;
        }

        _isLoading = true;
        var result = await FluxService.ResetPasswordAsync(_email, _otp, _newPassword);
        _isLoading = false;

        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Password reset successfully. Please login.");
            Navigation.NavigateTo("/auth");
        }
        else
        {
            ToastService.ShowError(result.Error ?? "Failed to reset password.");
        }
    }
}

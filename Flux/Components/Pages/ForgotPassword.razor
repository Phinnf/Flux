@page "/forgot-password"
@using Flux.Infrastructure.Client
@using System.Text.RegularExpressions
@inject AuthClientService AuthService
@inject NavigationManager Navigation
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Reset Password | Flux</PageTitle>

<div class="flux-auth min-h-screen flex items-center justify-center p-6">
    <!-- Glow Effects -->
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>

    <div class="auth-card glass-card animate-in max-w-[500px]">
        <div class="auth-content">
            <div class="auth-header text-center">
                <div class="flux-logo justify-center" @onclick='() => Navigation.NavigateTo("/")'>
                    <div class="logo-icon">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z" fill="currentColor"/>
                        </svg>
                    </div>
                    <span>Flux</span>
                </div>
                <h1>Reset Password</h1>
                <p>@(!_otpSent ? "Enter your email to receive a reset code." : "Check your email for the verification code.")</p>
            </div>

            @if (!string.IsNullOrEmpty(_message))
            {
                <div class="message-box @(_isError ? "error" : "success")">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>@_message</span>
                </div>
            }

            @if (!_otpSent)
            {
                <div class="auth-form fade-in">
                    <div class="input-group">
                        <label>Email Address</label>
                        <div class="input-group-icon icon-left">
                            <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                            <input type="email" @bind="_email" placeholder="name@example.com" required class="glass-input" />
                        </div>
                    </div>

                    <button class="flux-btn-primary full-width mt-4" @onclick="SendOtp" disabled="@_isLoading">
                        @(_isLoading ? "Sending..." : "Send Verification Code")
                    </button>
                </div>
            }
            else
            {
                <div class="auth-form fade-in">
                    <div class="input-group">
                        <label>6-Digit Code</label>
                        <input type="text" @bind="_otp" placeholder="••••••" maxlength="6" 
                               class="glass-input otp-input" />
                    </div>
                    
                    <div class="input-group">
                        <label>New Password</label>
                        <input type="password" @bind="_newPassword" placeholder="••••••••" class="glass-input" />
                    </div>

                    <div class="input-group">
                        <label>Confirm New Password</label>
                        <input type="password" @bind="_confirmPassword" placeholder="••••••••" class="glass-input" />
                    </div>

                    <div class="actions-stack mt-4">
                        <button class="flux-btn-primary full-width" @onclick="ResetPassword" disabled="@_isLoading">
                            @(_isLoading ? "Resetting..." : "Reset My Password")
                        </button>
                        <button class="back-link" @onclick="() => _otpSent = false">
                            Back to email entry
                        </button>
                    </div>
                </div>
            }

            <p class="toggle-auth">
                Remembered your password? 
                <button type="button" @onclick='() => Navigation.NavigateTo("/auth")' class="toggle-btn">Sign In</button>
            </p>
        </div>
    </div>
</div>

<style>
    .flux-auth {
        background-color: var(--flux-main-bg);
        color: var(--flux-main-text);
        position: relative;
        overflow: hidden;
    }

    /* Glow Orbs */
    .glow-orb {
        position: absolute;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
        z-index: 0;
        pointer-events: none;
    }
    .orb-1 { top: -200px; right: -200px; background: var(--flux-primary); }
    .orb-2 { bottom: -200px; left: -200px; background: var(--flux-secondary); }

    .auth-card {
        width: 100%;
        max-width: 500px;
        overflow: hidden;
        border-radius: 32px;
        z-index: 10;
    }

    .auth-content { padding: 48px; display: flex; flex-direction: column; justify-content: center; }

    .auth-header { margin-bottom: 32px; }
    .flux-logo { 
        display: flex; 
        align-items: center; 
        gap: 12px; 
        font-weight: 800; 
        font-size: 1.5rem; 
        margin-bottom: 24px;
        cursor: pointer;
    }
    .logo-icon {
        width: 32px;
        height: 32px;
        background: var(--flux-primary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }
    .auth-header h1 { font-size: 2rem; font-weight: 800; margin-bottom: 8px; color: white; }
    .auth-header p { color: rgba(255,255,255,0.5); font-size: 0.95rem; }

    .message-box { 
        padding: 12px 16px; 
        border-radius: 12px; 
        font-size: 0.875rem; 
        display: flex; 
        align-items: center; 
        gap: 12px; 
        margin-bottom: 24px;
    }
    .message-box.error { background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; }
    .message-box.success { background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.2); color: #22c55e; }

    .auth-form { display: flex; flex-direction: column; gap: 20px; }
    .input-group { display: flex; flex-direction: column; gap: 8px; }
    .input-group label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); margin-left: 4px; }
    
    .input-with-icon { position: relative; }
    .input-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 20px; height: 20px; color: rgba(255,255,255,0.2); }
    
    .otp-input { text-align: center; font-size: 1.5rem; letter-spacing: 0.5em; font-weight: 800; }

    .actions-stack { display: flex; flex-direction: column; gap: 12px; }
    .back-link { background: none; border: none; color: rgba(255,255,255,0.3); cursor: pointer; font-size: 0.875rem; transition: color 0.2s; }
    .back-link:hover { color: white; }

    .toggle-auth { text-align: center; margin-top: 32px; font-size: 0.875rem; color: rgba(255,255,255,0.5); }
    .toggle-btn { background: none; border: none; color: var(--flux-primary); font-weight: 700; cursor: pointer; margin-left: 4px; }
    .toggle-btn:hover { text-decoration: underline; }

    .text-gradient {
        background: linear-gradient(135deg, var(--flux-primary) 0%, var(--flux-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .flux-btn-primary {
        background: var(--flux-primary);
        color: white;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
    }
    .flux-btn-primary:hover:not(:disabled) { 
        background: var(--flux-primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px -4px rgba(59, 130, 246, 0.4);
    }
    .flux-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .full-width { width: 100%; }

    .animate-in { animation: fadeInScale 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes fadeInScale {
        from { opacity: 0; transform: scale(0.95) translateY(20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .fade-in { animation: fadeIn 0.4s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    @@media (max-width: 640px) {
        .auth-content { padding: 32px; }
    }
</style>

@code {
    private string _email = "";
    private string _otp = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    
    private bool _isLoading = false;
    private bool _otpSent = false;
    private string _message = "";
    private bool _isError = false;

    private void ShowMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }

    private async Task SendOtp()
    {
        _message = "";
        if (string.IsNullOrWhiteSpace(_email))
        {
            ShowMessage("Please enter your email.", true);
            return;
        }

        _isLoading = true;
        var result = await AuthService.ForgotPasswordAsync(_email);
        _isLoading = false;

        if (result.IsSuccess)
        {
            _otpSent = true;
            ShowMessage("If the email exists, an OTP has been sent.");
        }
        else
        {
            ShowMessage(result.Error ?? "Failed to send OTP.", true);
        }
    }

    private async Task ResetPassword()
    {
        _message = "";
        if (string.IsNullOrWhiteSpace(_otp) || _otp.Length != 6)
        {
            ShowMessage("Please enter the 6-digit OTP.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            ShowMessage("Please enter a new password.", true);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            ShowMessage("Passwords do not match.", true);
            return;
        }

        var regex = new Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$");
        if (!regex.IsMatch(_newPassword))
        {
            ShowMessage("Password doesn't meet security requirements.", true);
            return;
        }

        _isLoading = true;
        var result = await AuthService.ResetPasswordAsync(_email, _otp, _newPassword);
        _isLoading = false;

        if (result.IsSuccess)
        {
            ShowMessage("Password reset successfully. Please login.");
            await Task.Delay(2000);
            Navigation.NavigateTo("/auth");
        }
        else
        {
            ShowMessage(result.Error ?? "Failed to reset password.", true);
        }
    }
}
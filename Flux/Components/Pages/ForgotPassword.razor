@page "/forgot-password"
@using Flux.Infrastructure.Client
@using System.Text.RegularExpressions
@inject FluxClientService FluxService
@inject NavigationManager Navigation
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Reset Password - Flux</PageTitle>

<div class="auth-wrapper min-h-screen w-full flex items-center justify-center p-4">
    <!-- Animated background elements (consistent with Auth.razor) -->
    <div class="bg-glow"></div>
    <div class="bg-glow-2"></div>

    <div class="auth-container relative w-full max-w-[500px] flex flex-col rounded-3xl overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.3)] border border-white/10 p-8 md:p-12">
        
        @if (_isLoading)
        {
            <div class="loading-overlay absolute inset-0 z-50 flex items-center justify-center rounded-3xl">
                <div class="loader"></div>
            </div>
        }

        <div class="brand-logo mb-8 flex justify-center">
            <div class="logo-box">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
            </div>
            <span class="text-2xl font-bold text-white tracking-tight ml-3">Flux</span>
        </div>

        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-white mb-2">Reset Password</h1>
            <p class="text-white/60">
                @(!_otpSent ? "Enter your email to receive a reset code." : "Check your email for the verification code.")
            </p>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="error-box p-3 rounded-xl border @(_isError ? "border-red-500/50 bg-red-500/10 text-red-400" : "border-green-500/50 bg-green-500/10 text-green-400") text-sm flex items-center gap-3 mb-6 animate-shake">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>@_message</span>
            </div>
        }

        @if (!_otpSent)
        {
            <div class="space-y-6 fade-in">
                <div class="input-group">
                    <label class="text-xs font-semibold text-white/50 uppercase tracking-wider ml-1">Email Address</label>
                    <div class="relative mt-1">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-white/30">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                        </span>
                        <input type="email" @bind="_email" placeholder="name@example.com" required 
                               class="auth-input pl-12" />
                    </div>
                </div>

                <button class="w-full auth-btn-primary py-4" @onclick="SendOtp" disabled="@_isLoading">
                    Send Verification Code
                </button>
            </div>
        }
        else
        {
            <div class="space-y-5 fade-in">
                <div class="input-group">
                    <label class="text-xs font-semibold text-white/50 uppercase tracking-wider ml-1">6-Digit Code</label>
                    <input type="text" @bind="_otp" placeholder="••••••" maxlength="6" 
                           class="auth-input text-center text-2xl font-bold tracking-[0.5em]" />
                </div>
                
                <div class="input-group">
                    <label class="text-xs font-semibold text-white/50 uppercase tracking-wider ml-1">New Password</label>
                    <input type="password" @bind="_newPassword" placeholder="••••••••" 
                           class="auth-input" />
                    <p class="mt-2 text-[10px] text-white/40 leading-relaxed px-1">
                        Must be 8+ chars with uppercase, lowercase, number & symbol.
                    </p>
                </div>

                <div class="input-group">
                    <label class="text-xs font-semibold text-white/50 uppercase tracking-wider ml-1">Confirm New Password</label>
                    <input type="password" @bind="_confirmPassword" placeholder="••••••••" 
                           class="auth-input" />
                </div>

                <div class="pt-2 space-y-3">
                    <button class="w-full auth-btn-primary py-4" @onclick="ResetPassword" disabled="@_isLoading">
                        Reset My Password
                    </button>
                    <button class="w-full text-white/40 hover:text-white transition-colors text-sm py-2" @onclick="() => _otpSent = false">
                        Back to email entry
                    </button>
                </div>
            </div>
        }

        <div class="mt-10 text-center text-white/60 text-sm">
            Remembered your password? 
            <a href="/auth" class="text-blue-400 font-bold hover:text-blue-300 ml-1 underline-offset-4 hover:underline transition-all">Sign In</a>
        </div>
    </div>
</div>

<style>
    :root {
        --auth-bg: #0b0c10;
        --card-bg: #1a1c24;
        --input-bg: rgba(255, 255, 255, 0.03);
        --accent: #3b82f6;
    }

    .auth-wrapper {
        background: var(--auth-bg);
        overflow: hidden;
        position: relative;
    }

    .bg-glow {
        position: absolute;
        top: -10%;
        left: -10%;
        width: 50%;
        height: 50%;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
        filter: blur(80px);
        z-index: 0;
    }

    .bg-glow-2 {
        position: absolute;
        bottom: -10%;
        right: -10%;
        width: 60%;
        height: 60%;
        background: radial-gradient(circle, rgba(147, 51, 234, 0.1) 0%, transparent 70%);
        filter: blur(80px);
        z-index: 0;
    }

    .auth-container {
        background: var(--card-bg);
        z-index: 10;
    }

    .auth-input {
        width: 100%;
        padding: 14px 16px;
        background: var(--input-bg);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        color: white;
        font-size: 15px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .auth-input:focus {
        outline: none;
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    }

    .auth-btn-primary {
        background: var(--accent);
        color: white;
        padding: 14px;
        border-radius: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px -5px rgba(59, 130, 246, 0.3);
    }

    .auth-btn-primary:hover:not(:disabled) {
        background: #2563eb;
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -10px rgba(59, 130, 246, 0.5);
    }

    .auth-btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .logo-box {
        width: 44px;
        height: 44px;
        background: var(--accent);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 16px -4px rgba(59, 130, 246, 0.4);
    }

    .loading-overlay {
        background: rgba(26, 28, 36, 0.7);
        backdrop-filter: blur(8px);
    }

    .loader {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    .fade-in { animation: fadeIn 0.4s ease-out; }
    .animate-shake { animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both; }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes shake {
        10%, 90% { transform: translateX(-1px); }
        20%, 80% { transform: translateX(2px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }
</style>

@code {
    private string _email = "";
    private string _otp = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    
    private bool _isLoading = false;
    private bool _otpSent = false;
    private string _message = "";
    private bool _isError = false;

    private void ShowMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }

    private async Task SendOtp()
    {
        _message = "";
        if (string.IsNullOrWhiteSpace(_email))
        {
            ShowMessage("Please enter your email.", true);
            return;
        }

        _isLoading = true;
        var result = await FluxService.ForgotPasswordAsync(_email);
        _isLoading = false;

        if (result.IsSuccess)
        {
            _otpSent = true;
            ShowMessage("If the email exists, an OTP has been sent.");
        }
        else
        {
            ShowMessage(result.Error ?? "Failed to send OTP.", true);
        }
    }

    private async Task ResetPassword()
    {
        _message = "";
        if (string.IsNullOrWhiteSpace(_otp) || _otp.Length != 6)
        {
            ShowMessage("Please enter the 6-digit OTP.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            ShowMessage("Please enter a new password.", true);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            ShowMessage("Passwords do not match.", true);
            return;
        }

        var regex = new Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$");
        if (!regex.IsMatch(_newPassword))
        {
            ShowMessage("Password doesn't meet security requirements.", true);
            return;
        }

        _isLoading = true;
        var result = await FluxService.ResetPasswordAsync(_email, _otp, _newPassword);
        _isLoading = false;

        if (result.IsSuccess)
        {
            ShowMessage("Password reset successfully. Please login.");
            await Task.Delay(2000);
            Navigation.NavigateTo("/auth");
        }
        else
        {
            ShowMessage(result.Error ?? "Failed to reset password.", true);
        }
    }
}
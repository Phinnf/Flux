@page "/workspace/{WorkspaceId:guid}/dms"
@layout Flux.Components.Layout.WorkspaceLayout
@using Flux.Domain.Entities
@using Flux.Infrastructure.Client
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@implements IDisposable
@inject WorkspaceStateService StateService
@inject WorkspaceClientService WorkspaceService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Direct Messages</PageTitle>

<Flux.Components.Layout.DmSidebar />

<div class="flex-1 flex items-center justify-center h-full bg-[#1A1D21] text-gray-200">
    <div class="text-center max-w-md p-6">
        <div class="flex flex-col items-center">
            <svg class="w-24 h-24 mb-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            <h3 class="text-2xl font-bold text-white mb-2">Direct Messages</h3>
            <p class="text-gray-400">Select a person from the sidebar to start a 1-on-1 conversation.</p>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }

    protected override void OnInitialized()
    {
        StateService.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnParametersSetAsync()
    {
        // Auto-redirect to the first direct channel if available
        var firstDirect = StateService.Channels.FirstOrDefault(c => c.Type == ChannelType.Direct);
        if (firstDirect != null)
        {
            Navigation.NavigateTo($"/workspace/{WorkspaceId}/dms/{firstDirect.Id}");
        }
    }
    
    public void Dispose()
    {
        StateService.OnStateChanged -= HandleStateChanged;
    }
}

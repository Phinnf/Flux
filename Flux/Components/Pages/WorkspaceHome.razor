@page "/workspace/{WorkspaceId:guid}"
@layout Flux.Components.Layout.WorkspaceLayout
@implements IDisposable
@inject WorkspaceStateService StateService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Workspace - Flux</PageTitle>

<div class="workspace-home-container">
    <div class="glass-card welcome-card">
        <FluentIcon Value="@(new Icons.Regular.Size48.Organization())" Color="Color.Accent" Style="margin-bottom: 20px;" />
        <FluentLabel Typo="Typography.H2" Style="font-weight: bold; margin-bottom: 10px;">
            Welcome to @(StateService.CurrentWorkspaceName ?? "your workspace")!
        </FluentLabel>
        
        @if (!StateService.Channels.Any())
        {
            <FluentLabel Typo="Typography.Body" Style="margin-bottom: 30px; opacity: 0.8; text-align: center; max-width: 400px;">
                This workspace doesn't have any channels yet. Channels are where your team communicates.
            </FluentLabel>
            
            <div class="hint-box">
                <FluentIcon Value="@(new Icons.Regular.Size24.ArrowCircleLeft())" />
                <span>Click the <b>+ Add Channels</b> button in the sidebar to get started!</span>
            </div>
        }
        else
        {
            <FluentLabel Typo="Typography.Body" Style="margin-bottom: 30px; opacity: 0.8; text-align: center; max-width: 400px;">
                Select a channel from the sidebar to start chatting.
            </FluentLabel>
        }
    </div>
</div>

<style>
    .workspace-home-container {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 40px;
    }

    .welcome-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 50px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        color: white;
    }

    .hint-box {
        display: flex;
        align-items: center;
        gap: 15px;
        background: rgba(0, 0, 0, 0.2);
        padding: 15px 25px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
</style>

@code {
    [Parameter]
    public Guid WorkspaceId { get; set; }

    protected override void OnInitialized()
    {
        StateService.OnStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        StateService.OnStateChanged -= StateHasChanged;
    }
}

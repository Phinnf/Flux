@using Flux.Features.Kanban
@using Flux.Domain.Entities
@using Flux.Infrastructure.Client
@inject KanbanStateService KanbanState

<div class="bg-[#2b2d31] p-4 rounded-2xl border border-gray-800 shadow-sm hover:border-blue-500/50 hover:shadow-xl hover:shadow-blue-500/5 transition-all cursor-grab active:cursor-grabbing group relative overflow-hidden"
     draggable="true"
     @ondragstart="HandleDragStart"
     @onclick="ShowTaskDetail">
    
    @if (!string.IsNullOrEmpty(Task.Color))
    {
        <div class="absolute left-0 top-0 bottom-0 w-1.5" style="background-color: @Task.Color"></div>
    }

    <div class="flex flex-col gap-3">
        <div class="flex items-start justify-between">
            <span class="px-2 py-0.5 rounded-lg text-[9px] font-black uppercase tracking-widest @GetPriorityClass(Task.Priority)">
                @Task.Priority
            </span>
            <div class="flex -space-x-1.5 group-hover:translate-x-1 transition-transform">
                @if (!string.IsNullOrEmpty(Task.AssignedAvatarUrl))
                {
                    <img src="@Task.AssignedAvatarUrl" class="w-6 h-6 rounded-full border-2 border-[#2b2d31] shadow-md" title="@Task.AssignedUsername" />
                }
            </div>
        </div>

        <h4 class="text-sm font-bold text-white leading-tight line-clamp-2 group-hover:text-blue-400 transition-colors">@Task.Title</h4>

        @if (!string.IsNullOrEmpty(Task.Description))
        {
            <p class="text-[11px] text-zinc-500 line-clamp-2 leading-relaxed">@Task.Description</p>
        }

        <div class="flex items-center justify-between mt-1 pt-3 border-t border-gray-800/50">
            <div class="flex items-center gap-3 text-zinc-600">
                @if (Task.DueDate.HasValue)
                {
                    <div class="flex items-center gap-1.5 text-[10px] font-bold @(Task.DueDate < DateTime.UtcNow ? "text-red-400" : "")">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                        @Task.DueDate.Value.ToString("MMM d")
                    </div>
                }
                
                @if (Task.Subtasks.Any())
                {
                    <div class="flex items-center gap-1.5 text-[10px] font-bold">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        @Task.Subtasks.Count(s => s.IsCompleted)/@Task.Subtasks.Count
                    </div>
                }
            </div>
            
            @if (Task.Subtasks.Any())
            {
                <div class="w-16 h-1.5 bg-[#1e1f22] rounded-full overflow-hidden shadow-inner">
                    <div class="h-full bg-blue-500 rounded-full transition-all duration-500" style="width: @(GetProgress())%"></div>
                </div>
            }
        </div>
    </div>
</div>

@if (_showDetail)
{
    <KanbanTaskModal Task="Task" WorkspaceId="KanbanState.SelectedBoard!.WorkspaceId" OnClose="() => _showDetail = false" />
}

@code {
    [Parameter] public KanbanTaskDto Task { get; set; } = null!;
    [Parameter] public Guid ColumnId { get; set; }

    private bool _showDetail = false;

    private void HandleDragStart()
    {
        DragDropService.DraggedTask = Task;
    }

    private void ShowTaskDetail() => _showDetail = true;

    private double GetProgress()
    {
        if (!Task.Subtasks.Any()) return 0;
        return (double)Task.Subtasks.Count(s => s.IsCompleted) / Task.Subtasks.Count * 100;
    }

    private string GetPriorityClass(Priority priority) => priority switch
    {
        Priority.Urgent => "bg-red-500/10 text-red-500 border border-red-500/20",
        Priority.High => "bg-orange-500/10 text-orange-500 border border-orange-500/20",
        Priority.Medium => "bg-blue-500/10 text-blue-500 border border-blue-500/20",
        _ => "bg-zinc-500/10 text-zinc-500 border border-zinc-500/20"
    };
}

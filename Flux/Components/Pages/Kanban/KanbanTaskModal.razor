@using Flux.Features.Kanban
@using Flux.Domain.Entities
@using Flux.Infrastructure.Client
@inject KanbanStateService KanbanState
@inject KanbanClientService KanbanClient

<Flux.Components.UI.Modal Title="Task Intelligence" OnClose="OnClose">
    <div class="space-y-8 max-h-[80vh] overflow-y-auto pr-4 scrollbar-hide p-2">
        <!-- Title & Basic Info -->
        <div class="space-y-4">
            <div class="flex items-center gap-3">
                <div class="w-2 h-8 rounded-full" style="background-color: @(string.IsNullOrEmpty(Task.Color) ? "#3b82f6" : Task.Color)"></div>
                <input type="text" @bind="Task.Title" @bind:after="UpdateTask"
                       class="flex-1 bg-transparent text-2xl font-black text-white border-none focus:ring-2 focus:ring-blue-500/20 rounded-xl px-2 py-1 outline-none transition-all" />
            </div>
            
            <div class="flex flex-wrap gap-4 items-center pl-5">
                <div class="flex flex-col gap-1">
                    <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Priority</label>
                    <select @bind="Task.Priority" @bind:after="UpdateTask"
                            class="bg-[#1e1f22] text-[10px] font-black uppercase tracking-widest text-zinc-400 rounded-lg px-3 py-1.5 border border-gray-800 outline-none focus:border-blue-500/50 transition-all">
                        @foreach (var p in Enum.GetValues<Priority>())
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Timeline</label>
                    <input type="date" value="@Task.DueDate?.ToString("yyyy-MM-dd")" 
                           @onchange="UpdateDueDate"
                           class="bg-[#1e1f22] text-[10px] font-black uppercase tracking-widest text-zinc-400 rounded-lg px-3 py-1.5 border border-gray-800 outline-none focus:border-blue-500/50 transition-all" />
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-[9px] font-black uppercase tracking-[0.2em] text-zinc-500">Identity Color</label>
                    <div class="flex gap-1.5 p-1 bg-[#1e1f22] rounded-lg border border-gray-800">
                        @foreach (var color in _colors.Take(5))
                        {
                            <button class="w-4 h-4 rounded-md transition-transform hover:scale-125 @(Task.Color == color ? "ring-2 ring-white scale-110" : "")"
                                    style="background-color: @color"
                                    @onclick="() => SetColor(color)"></button>
                        }
                        <button class="w-4 h-4 rounded-md bg-zinc-800 flex items-center justify-center text-[8px]" @onclick="() => SetColor(null)">
                            <svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description -->
        <div class="space-y-3 pl-5 border-l-2 border-gray-800/50">
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" /></svg>
                <label class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-500">Intelligence Brief</label>
            </div>
            <textarea @bind="Task.Description" @bind:after="UpdateTask" rows="4"
                      class="w-full bg-[#1e1f22] text-sm text-zinc-300 rounded-2xl px-5 py-4 border-2 border-transparent focus:border-blue-500/30 outline-none transition-all resize-none shadow-inner placeholder:text-zinc-700" 
                      placeholder="Add strategic details about this task..."></textarea>
        </div>

        <!-- Subtasks -->
        <div class="space-y-4">
            <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    <label class="text-[10px] font-black uppercase tracking-[0.2em] text-zinc-500">Tactical Milestones (@Task.Subtasks.Count(s => s.IsCompleted)/@Task.Subtasks.Count)</label>
                </div>
                <div class="w-32 h-2 bg-[#1e1f22] rounded-full overflow-hidden shadow-inner">
                    <div class="h-full bg-blue-600 rounded-full transition-all duration-700" style="width: @(GetProgress())%"></div>
                </div>
            </div>
            
            <div class="space-y-2.5">
                @foreach (var sub in Task.Subtasks.OrderBy(s => s.Order))
                {
                    <div class="flex items-center gap-4 group p-3 hover:bg-[#2b2d31]/30 rounded-2xl border border-transparent hover:border-gray-800/50 transition-all">
                        <div class="relative flex items-center">
                            <input type="checkbox" checked="@sub.IsCompleted" @onchange="() => ToggleSubtask(sub)"
                                   class="w-5 h-5 rounded-lg bg-[#1e1f22] border-gray-700 text-blue-600 focus:ring-0 focus:ring-offset-0 transition-all cursor-pointer" />
                        </div>
                        <span class="text-sm font-medium flex-1 transition-all @(sub.IsCompleted ? "line-through text-zinc-600" : "text-zinc-200")">@sub.Title</span>
                        <button class="opacity-0 group-hover:opacity-100 p-2 text-zinc-600 hover:text-red-400 hover:bg-red-400/10 rounded-xl transition-all"
                                @onclick="() => DeleteSubtask(sub)">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                        </button>
                    </div>
                }

                <div class="flex gap-3 mt-4 group">
                    <div class="flex-1 relative">
                        <input type="text" @bind="_newSubtaskTitle" placeholder="Deploy new milestone..." 
                               @onkeyup="HandleSubtaskKeyUp"
                               class="w-full bg-[#1e1f22] text-sm text-white rounded-xl px-4 py-3 border-2 border-transparent focus:border-blue-500/30 outline-none transition-all shadow-inner" />
                    </div>
                    <button class="bg-[#2b2d31] hover:bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest px-6 rounded-xl transition-all shadow-lg active:scale-95"
                            @onclick="AddSubtask">Add</button>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="pt-8 border-t border-gray-800/50 flex items-center justify-between">
            <div class="flex gap-4">
                <button class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest text-zinc-500 hover:text-white hover:bg-[#2b2d31] transition-all"
                        @onclick="ToggleArchive">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>
                    @(Task.IsArchived ? "Unarchive" : "Archive")
                </button>
                <button class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest text-red-500/70 hover:text-red-500 hover:bg-red-500/10 transition-all"
                        @onclick="DeleteTask">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    Eliminate
                </button>
            </div>
            <button class="px-10 py-3 bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl shadow-xl shadow-blue-600/20 hover:bg-blue-700 transition-all active:scale-95"
                    @onclick="OnClose">Done</button>
        </div>
    </div>
</Flux.Components.UI.Modal>

@code {
    [Parameter] public KanbanTaskDto Task { get; set; } = null!;
    [Parameter] public Guid WorkspaceId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string _newSubtaskTitle = "";
    private string[] _colors = { "#ef4444", "#f97316", "#f59e0b", "#10b981", "#3b82f6", "#8b5cf6", "#ec4899" };

    private async Task UpdateTask()
    {
        var request = new UpdateTaskRequest(
            Task.Title, Task.Description, Task.Priority, Task.DueDate, Task.Color, Task.IsArchived, Task.AssignedUserId);
        await KanbanState.UpdateTaskAsync(WorkspaceId, Task.Id, request);
    }

    private async Task UpdateDueDate(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            Task.DueDate = DateTime.SpecifyKind(date, DateTimeKind.Utc);
            await UpdateTask();
        }
    }

    private async Task SetColor(string? color)
    {
        Task.Color = color;
        await UpdateTask();
    }

    private async Task ToggleArchive()
    {
        Task.IsArchived = !Task.IsArchived;
        await UpdateTask();
        // The service UpdateTaskAsync will notify the board, and the board will filter out the archived card.
        // We close the modal to show the update.
        await OnClose.InvokeAsync();
    }

    private double GetProgress()
    {
        if (!Task.Subtasks.Any()) return 0;
        return (double)Task.Subtasks.Count(s => s.IsCompleted) / Task.Subtasks.Count * 100;
    }

    private async Task HandleSubtaskKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddSubtask();
    }

    private async Task AddSubtask()
    {
        if (string.IsNullOrWhiteSpace(_newSubtaskTitle)) return;
        var result = await KanbanState.CreateSubtaskAsync(WorkspaceId, Task.Id, new CreateSubtaskRequest(_newSubtaskTitle, Priority.Low, Task.Subtasks.Count));
        if (result.IsSuccess)
        {
            Task.Subtasks.Add(result.Value!);
            _newSubtaskTitle = "";
        }
    }

    private async Task ToggleSubtask(KanbanSubtaskDto sub)
    {
        var result = await KanbanState.ToggleSubtaskAsync(WorkspaceId, sub.Id);
        if (result.IsSuccess)
        {
            sub.IsCompleted = !sub.IsCompleted;
        }
    }

    private async Task DeleteSubtask(KanbanSubtaskDto sub)
    {
        var result = await KanbanState.DeleteSubtaskAsync(WorkspaceId, sub.Id);
        if (result.IsSuccess)
        {
            Task.Subtasks.Remove(sub);
        }
    }

    private async Task DeleteTask()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to eliminate this card?")) return;
        
        var result = await KanbanState.DeleteTaskAsync(WorkspaceId, Task.Id);
        if (result.IsSuccess)
        {
            // The service now handles local cleanup and notification
            await OnClose.InvokeAsync();
        }
    }

    [Inject] private IJSRuntime JSRuntime { get; set; } = null!;
}

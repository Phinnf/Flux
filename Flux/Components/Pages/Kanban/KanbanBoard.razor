@page "/workspace/{WorkspaceId:guid}/kanban"
@using Flux.Infrastructure.Client
@using Flux.Features.Kanban
@using Flux.Domain.Entities
@layout Layout.WorkspaceLayout
@inject KanbanStateService KanbanState
@inject WorkspaceStateService WorkspaceState
@inject NavigationManager Navigation
@implements IDisposable

<div class="flex flex-col h-full w-full bg-[#1a1c1e] text-gray-200 overflow-hidden">
    <!-- Toolbar -->
    <div class="flex items-center justify-between p-6 border-b border-gray-800/50 bg-[#1e1f22]/50 backdrop-blur-md">
        <div class="flex items-center gap-6">
            <h1 class="text-2xl font-black text-white tracking-tight">Kanban</h1>
            <div class="h-6 w-px bg-gray-800"></div>
            @if (KanbanState.Boards.Count > 1)
            {
                <select class="bg-[#2b2d31] text-xs font-bold uppercase tracking-widest rounded-xl px-4 py-2 border-none focus:ring-2 focus:ring-blue-500/50 transition-all cursor-pointer shadow-lg"
                        @onchange="(e) => KanbanState.SelectBoard(Guid.Parse(e.Value?.ToString() ?? Guid.Empty.ToString()))">
                    @foreach (var board in KanbanState.Boards)
                    {
                        <option value="@board.Id" selected="@(KanbanState.SelectedBoard?.Id == board.Id)">@board.Name</option>
                    }
                </select>
            }
            else if (KanbanState.SelectedBoard != null)
            {
                <span class="text-xs font-black uppercase tracking-widest text-zinc-500">@KanbanState.SelectedBoard.Name</span>
            }
        </div>

        <div class="flex items-center gap-4">
            <div class="relative group">
                <input type="text" placeholder="Search cards..." 
                       @bind="_searchQuery" @bind:event="oninput"
                       class="bg-[#1e1f22] text-sm rounded-2xl pl-10 pr-4 py-2.5 w-64 border-2 border-transparent focus:border-blue-500/50 transition-all outline-none shadow-inner text-white" />
                <svg class="w-4 h-4 absolute left-3.5 top-3 text-gray-500 group-focus-within:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>

            <button @onclick="() => _showArchived = !_showArchived"
                    class="p-2.5 rounded-xl transition-all @(_showArchived ? "bg-blue-600 text-white shadow-lg shadow-blue-600/20" : "bg-[#2b2d31] text-zinc-500 hover:text-white border border-gray-800")"
                    title="@(_showArchived ? "Hide Archived" : "Show Archived")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>
            </button>
            
            <button class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-black uppercase tracking-widest rounded-2xl transition-all shadow-lg shadow-blue-600/20 active:scale-95"
                    @onclick="ShowCreateColumnModal">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Add Column
            </button>
        </div>
    </div>

    <!-- Board Area -->
    <div class="flex-1 overflow-x-auto overflow-y-hidden p-8 scrollbar-hide">
        <div class="flex gap-8 h-full items-start">
            @if (KanbanState.SelectedBoard?.Columns != null)
            {
                @foreach (var column in KanbanState.SelectedBoard.Columns.OrderBy(c => c.Order))
                {
                    <KanbanColumn Column="column" SearchQuery="@_searchQuery" ShowArchived="@_showArchived" />
                }
            }

            @if (KanbanState.SelectedBoard == null)
            {
                <div class="flex flex-col items-center justify-center w-full h-full text-zinc-500 gap-6">
                    <div class="w-24 h-24 bg-white/5 rounded-3xl flex items-center justify-center">
                        <svg class="w-12 h-12 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    </div>
                    <div class="text-center space-y-2">
                        <p class="text-xl font-bold text-white">No Boards Found</p>
                        <p class="text-sm">Create your first board to start managing tasks.</p>
                    </div>
                    <button class="px-8 py-3 bg-blue-600 text-white font-black uppercase tracking-widest rounded-2xl shadow-lg hover:bg-blue-700 transition-all active:scale-95" 
                            @onclick="ShowCreateBoardModal">Create Board</button>
                </div>
            }

            <!-- Add Column Placeholder -->
            @if (KanbanState.SelectedBoard != null)
            {
                <button @onclick="ShowCreateColumnModal"
                        class="flex-shrink-0 w-80 h-32 border-2 border-dashed border-gray-800 rounded-3xl flex flex-col items-center justify-center gap-3 text-zinc-600 hover:text-blue-500 hover:border-blue-500/50 hover:bg-blue-500/5 transition-all group">
                    <div class="p-3 bg-gray-800/50 rounded-2xl group-hover:bg-blue-500/10 transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    </div>
                    <span class="text-xs font-black uppercase tracking-widest">Add New Column</span>
                </button>
            }
        </div>
    </div>
</div>

@if (_showBoardModal)
{
    <Flux.Components.UI.Modal Title="Create New Board" OnClose="() => _showBoardModal = false">
        <div class="space-y-6 p-2">
            <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 mb-2">Board Name</label>
                <input type="text" @bind="_newBoardName" class="w-full bg-[#1e1f22] text-white rounded-2xl px-4 py-3 border-2 border-transparent focus:border-blue-500/50 outline-none transition-all shadow-inner" placeholder="e.g. Project Roadmap" />
            </div>
            <div class="flex justify-end gap-3 pt-4">
                <button class="px-6 py-2.5 text-xs font-black uppercase tracking-widest text-zinc-500 hover:text-white transition-colors" @onclick="() => _showBoardModal = false">Cancel</button>
                <button class="px-8 py-2.5 bg-blue-600 text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-lg shadow-blue-600/20 active:scale-95 transition-all" @onclick="CreateBoard">Create Board</button>
            </div>
        </div>
    </Flux.Components.UI.Modal>
}

@if (_showColumnModal)
{
    <Flux.Components.UI.Modal Title="Add Column" OnClose="() => _showColumnModal = false">
        <div class="space-y-6 p-2">
            <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-zinc-500 mb-2">Column Name</label>
                <input type="text" @bind="_newColumnName" class="w-full bg-[#1e1f22] text-white rounded-2xl px-4 py-3 border-2 border-transparent focus:border-blue-500/50 outline-none transition-all shadow-inner" placeholder="e.g. Doing" />
            </div>
            <div class="flex justify-end gap-3 pt-4">
                <button class="px-6 py-2.5 text-xs font-black uppercase tracking-widest text-zinc-500 hover:text-white transition-colors" @onclick="() => _showColumnModal = false">Cancel</button>
                <button class="px-8 py-2.5 bg-blue-600 text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-lg shadow-blue-600/20 active:scale-95 transition-all" @onclick="CreateColumn">Add Column</button>
            </div>
        </div>
    </Flux.Components.UI.Modal>
}

<style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }

    private string _searchQuery = "";
    private bool _showBoardModal = false;
    private bool _showColumnModal = false;
    private bool _showArchived = false;
    private string _newBoardName = "";
    private string _newColumnName = "";
    private bool _isDisposed = false;
    private Guid _currentWorkspaceId;

    protected override void OnInitialized()
    {
        KanbanState.OnStateChanged += HandleStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_currentWorkspaceId != WorkspaceId)
        {
            _currentWorkspaceId = WorkspaceId;
            await KanbanState.LoadBoardsAsync(WorkspaceId);
        }
    }

    private async void HandleStateChanged()
    {
        if (!_isDisposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ShowCreateBoardModal() => _showBoardModal = true;
    private void ShowCreateColumnModal() => _showColumnModal = true;

    private async Task CreateBoard()
    {
        if (string.IsNullOrWhiteSpace(_newBoardName)) return;
        var result = await KanbanState.CreateBoardAsync(WorkspaceId, _newBoardName, null);
        if (result.IsSuccess)
        {
            _showBoardModal = false;
            _newBoardName = "";
        }
    }

    private async Task CreateColumn()
    {
        if (string.IsNullOrWhiteSpace(_newColumnName) || KanbanState.SelectedBoard == null) return;
        var result = await KanbanState.CreateColumnAsync(WorkspaceId, KanbanState.SelectedBoard.Id, _newColumnName);
        if (result.IsSuccess)
        {
            _showColumnModal = false;
            _newColumnName = "";
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        KanbanState.OnStateChanged -= HandleStateChanged;
    }
}

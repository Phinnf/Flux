@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Flux | Unified Communication & Task Management</PageTitle>

<div class="flux-landing">
    <!-- Glow Effects -->
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>

    <!-- Navigation -->
    <nav class="flux-nav glass-card">
        <div class="nav-container">
            <div class="nav-left">
                <div class="flux-logo" @onclick='() => Navigation.NavigateTo("/")'>
                    <div class="logo-icon">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M13 10V3L4 14h7v7l9-11h-7z" fill="currentColor"/>
                        </svg>
                    </div>
                    <span>Flux</span>
                </div>
                <div class="nav-links">
                    <a href="#features">Features</a>
                    <a href="#solutions">Solutions</a>
                    <a href="#pricing">Pricing</a>
                </div>
            </div>
            <div class="nav-right">
                <AuthorizeView>
                    <Authorized>
                        <button class="flux-btn-primary" @onclick='() => Navigation.NavigateTo("/workspaces")'>
                            Open Flux
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <button class="flux-btn-ghost" @onclick='() => Navigation.NavigateTo("/auth")'>Login</button>
                        <button class="flux-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>
                            Try Free
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                        </button>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero-section">
        <div class="container">
            <div class="hero-grid">
                <div class="hero-text">
                    <h1>Where Teams <br/><span class="text-gradient">Flow Together.</span></h1>
                    <p>Unified communication software that enables your teams to collaborate, chat, and manage everyday tasks seamlessly in one beautiful workspace.</p>
                    <div class="hero-btns">
                        <button class="flux-btn-primary large" @onclick='() => Navigation.NavigateTo("/auth")'>
                            Get Started for Free
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                        </button>
                        <button class="flux-btn-secondary large">
                            Watch Demo
                        </button>
                    </div>
                </div>
                <div class="hero-visual">
                    <div class="app-mockup glass-card">
                        <div class="mockup-header">
                            <div class="dots"><span></span><span></span><span></span></div>
                            <div class="address-bar">flux.app/workspace-1</div>
                        </div>
                        <div class="mockup-body">
                            <div class="mock-sidebar">
                                <div class="mock-item active"></div>
                                <div class="mock-item"></div>
                                <div class="mock-item"></div>
                            </div>
                            <div class="mock-content">
                                <div class="mock-chat">
                                    <div class="bubble-left">Hey team, let's finish the landing page!</div>
                                    <div class="bubble-right">On it! Just converting this message to a task.</div>
                                    <div class="task-card">
                                        <div class="task-check"></div>
                                        <span>Landing Page Redesign</span>
                                        <div class="task-tag">UI/UX</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Trust Section -->
    <section class="trust-section">
        <div class="container">
            <p class="section-tag">Trusted by innovative teams worldwide</p>
            <div class="logo-cloud">
                <div class="logo-item">TechFlow</div>
                <div class="logo-item">CloudScale</div>
                <div class="logo-item">ApexData</div>
                <div class="logo-item">NexusUI</div>
                <div class="logo-item">Vortex</div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="features-section">
        <div class="container">
            <div class="section-header">
                <h2>Designed for the <span class="text-gradient">Modern Workflow</span></h2>
                <p>Everything you need to stay productive, without the clutter of multiple tools.</p>
            </div>

            <div class="features-grid">
                <div class="feature-card glass-card">
                    <div class="feature-icon blue">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                    </div>
                    <h3>Smart Messaging</h3>
                    <p>Real-time chat with threading, reactions, and file sharing to keep communication focused.</p>
                </div>
                <div class="feature-card glass-card">
                    <div class="feature-icon green">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                    </div>
                    <h3>Task Conversion</h3>
                    <p>Instantly turn any chat message into a task. No more losing track of actionable items in long conversations.</p>
                </div>
                <div class="feature-card glass-card">
                    <div class="feature-icon yellow">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    </div>
                    <h3>Video Calls</h3>
                    <p>Jump into a call directly from your workspace. High-quality video and audio for seamless remote work.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="pricing-section">
        <div class="container">
            <div class="section-header">
                <h2>Simple, <span class="text-gradient">Transparent</span> Pricing</h2>
                <p>Choose the plan that fits your team's needs.</p>
            </div>

            <div class="pricing-grid">
                <!-- Free -->
                <div class="price-card glass-card">
                    <h3>Free</h3>
                    <div class="price">$0<span>/mo</span></div>
                    <ul class="price-features">
                        <li>Unlimited Messages</li>
                        <li>Up to 10 Members</li>
                        <li>5GB Storage</li>
                    </ul>
                    <button class="flux-btn-secondary full-width" @onclick='() => Navigation.NavigateTo("/auth")'>Get Started</button>
                </div>

                <!-- Pro -->
                <div class="price-card glass-card featured">
                    <div class="popular-tag">Most Popular</div>
                    <h3>Pro</h3>
                    <div class="price">$12<span>/mo</span></div>
                    <ul class="price-features">
                        <li>Everything in Free</li>
                        <li>Unlimited Members</li>
                        <li>100GB Storage</li>
                        <li>Priority Support</li>
                    </ul>
                    <button class="flux-btn-primary full-width" @onclick='() => Navigation.NavigateTo("/auth")'>Go Pro Now</button>
                </div>

                <!-- Enterprise -->
                <div class="price-card glass-card">
                    <h3>Enterprise</h3>
                    <div class="price">Custom</div>
                    <ul class="price-features">
                        <li>Everything in Pro</li>
                        <li>SAML SSO</li>
                        <li>Unlimited Storage</li>
                        <li>Dedicated Manager</li>
                    </ul>
                    <button class="flux-btn-secondary full-width" @onclick='() => Navigation.NavigateTo("/auth")'>Contact Sales</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="flux-footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="flux-logo">
                        <div class="logo-icon">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M13 10V3L4 14h7v7l9-11h-7z" fill="currentColor"/>
                            </svg>
                        </div>
                        <span>Flux</span>
                    </div>
                    <p>Building the future of team collaboration.</p>
                </div>
                <div class="footer-links">
                    <div class="link-group">
                        <h4>Product</h4>
                        <a href="#">Features</a>
                        <a href="#">Integrations</a>
                        <a href="#">Pricing</a>
                    </div>
                    <div class="link-group">
                        <h4>Company</h4>
                        <a href="#">About Us</a>
                        <a href="#">Blog</a>
                        <a href="#">Careers</a>
                    </div>
                    <div class="link-group">
                        <h4>Support</h4>
                        <a href="#">Help Center</a>
                        <a href="#">API Docs</a>
                        <a href="#">Status</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Flux Inc. All rights reserved.</p>
                <div class="social-links">
                    <a href="#">Twitter</a>
                    <a href="#">GitHub</a>
                    <a href="#">LinkedIn</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<style>
    .flux-landing {
        min-height: 100vh;
        background-color: var(--flux-main-bg);
        color: var(--flux-main-text);
        position: relative;
        overflow-x: hidden;
        /* Bypass the body { overflow: hidden; } in app.css */
        height: 100vh;
        width: 100vw;
        overflow-y: auto;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* Glow Orbs */
    .glow-orb {
        position: absolute;
        width: 400px;
        height: 400px;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
        z-index: 0;
        pointer-events: none;
    }
    .orb-1 { top: -100px; right: -100px; background: var(--flux-primary); }
    .orb-2 { top: 40%; left: -100px; background: var(--flux-secondary); }

    /* Typography */
    h1 { font-size: 4.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 24px; }
    h2 { font-size: 3rem; font-weight: 700; margin-bottom: 16px; text-align: center; }
    p { font-size: 1.125rem; line-height: 1.6; color: rgba(226, 232, 240, 0.7); }

    .text-gradient {
        background: linear-gradient(135deg, var(--flux-primary) 0%, var(--flux-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Buttons */
    .flux-btn-primary {
        background: var(--flux-primary);
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
    }
    .flux-btn-primary:hover { 
        background: var(--flux-primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px -4px rgba(59, 130, 246, 0.4);
    }

    .flux-btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        border: 1px solid var(--flux-border);
        transition: all 0.2s;
        cursor: pointer;
    }
    .flux-btn-secondary:hover { background: rgba(255, 255, 255, 0.1); }

    .flux-btn-ghost {
        background: transparent;
        color: rgba(255, 255, 255, 0.7);
        padding: 12px 24px;
        font-weight: 600;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
    }
    .flux-btn-ghost:hover { color: white; }

    .large { padding: 16px 32px; font-size: 1.1rem; }
    .full-width { width: 100%; justify-content: center; }

    /* Nav */
    .flux-nav {
        position: sticky;
        top: 24px;
        margin: 24px auto;
        max-width: 1100px;
        z-index: 1000;
        padding: 8px 24px;
    }
    .nav-container { display: flex; justify-content: space-between; align-items: center; }
    .nav-left { display: flex; align-items: center; gap: 48px; }
    .flux-logo { 
        display: flex; 
        align-items: center; 
        gap: 12px; 
        font-weight: 800; 
        font-size: 1.5rem; 
        cursor: pointer;
    }
    .logo-icon {
        width: 32px;
        height: 32px;
        background: var(--flux-primary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a { 
        color: rgba(255, 255, 255, 0.6); 
        text-decoration: none; 
        font-weight: 500; 
        transition: color 0.2s;
    }
    .nav-links a:hover { color: white; }
    .nav-right { display: flex; gap: 12px; }

    /* Hero */
    .hero-section { padding: 80px 0 120px; position: relative; }
    .hero-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 80px; align-items: center; }
    .badge {
        display: inline-block;
        padding: 6px 12px;
        background: rgba(59, 130, 246, 0.1);
        color: var(--flux-primary);
        border-radius: 100px;
        font-size: 0.875rem;
        font-weight: 600;
        margin-bottom: 24px;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }
    .hero-btns { display: flex; gap: 16px; margin-top: 40px; }

    /* App Mockup */
    .app-mockup {
        width: 100%;
        aspect-ratio: 4/3;
        overflow: hidden;
        box-shadow: 0 40px 100px -20px rgba(0,0,0,0.5);
    }
    .mockup-header {
        height: 40px;
        background: rgba(255,255,255,0.02);
        display: flex;
        align-items: center;
        padding: 0 16px;
        border-bottom: 1px solid var(--flux-border);
    }
    .dots { display: flex; gap: 6px; }
    .dots span { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.1); }
    .address-bar {
        margin-left: 24px;
        flex: 1;
        background: rgba(255,255,255,0.03);
        border-radius: 4px;
        font-size: 10px;
        padding: 4px 12px;
        color: rgba(255,255,255,0.3);
    }
    .mockup-body { display: flex; height: calc(100% - 40px); }
    .mock-sidebar { width: 60px; border-right: 1px solid var(--flux-border); padding: 12px; display: flex; flex-direction: column; gap: 12px; }
    .mock-item { width: 100%; aspect-ratio: 1; border-radius: 8px; background: rgba(255,255,255,0.03); }
    .mock-item.active { background: rgba(59, 130, 246, 0.2); border: 1px solid rgba(59, 130, 246, 0.3); }
    .mock-content { flex: 1; padding: 24px; display: flex; align-items: flex-end; }
    .mock-chat { width: 100%; display: flex; flex-direction: column; gap: 12px; }
    .bubble-left, .bubble-right { 
        padding: 10px 16px; 
        border-radius: 12px; 
        font-size: 0.8rem; 
        max-width: 80%;
    }
    .bubble-left { background: rgba(255,255,255,0.05); align-self: flex-start; }
    .bubble-right { background: var(--flux-primary); color: white; align-self: flex-end; }
    .task-card {
        background: #1a1c24;
        border: 1px solid var(--flux-border);
        border-radius: 12px;
        padding: 12px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.75rem;
        margin-top: 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    .task-check { width: 16px; height: 16px; border-radius: 4px; border: 2px solid var(--flux-primary); }
    .task-tag { margin-left: auto; padding: 2px 8px; border-radius: 4px; background: rgba(59, 130, 246, 0.1); color: var(--flux-primary); font-size: 9px; font-weight: 700; }

    /* Trust */
    .trust-section { padding: 40px 0; border-bottom: 1px solid var(--flux-border); }
    .section-tag { text-align: center; font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 32px; color: rgba(255,255,255,0.3); }
    .logo-cloud { display: flex; justify-content: center; align-items: center; gap: 64px; flex-wrap: wrap; opacity: 0.4; filter: grayscale(1); }
    .logo-item { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.05em; }

    /* Features */
    .features-section { padding: 120px 0; }
    .section-header { max-width: 700px; margin: 0 auto 64px; text-align: center; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; }
    .feature-card { padding: 40px; transition: transform 0.3s ease; }
    .feature-card:hover { transform: translateY(-8px); border-color: rgba(59, 130, 246, 0.3); }
    .feature-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; }
    .feature-icon svg { width: 24px; height: 24px; }
    .feature-icon.blue { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
    .feature-icon.green { background: rgba(34, 197, 94, 0.1); color: #22c55e; }
    .feature-icon.purple { background: rgba(168, 85, 247, 0.1); color: #a855f7; }
    .feature-icon.yellow { background: rgba(234, 179, 8, 0.1); color: #eab308; }
    .feature-card h3 { margin-bottom: 12px; font-size: 1.25rem; font-weight: 700; }

    /* Pricing */
    .pricing-section { padding: 120px 0; }
    .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; max-width: 1000px; margin: 0 auto; }
    .price-card { padding: 48px; display: flex; flex-direction: column; position: relative; }
    .price-card.featured { border-color: var(--flux-primary); box-shadow: 0 0 40px -10px rgba(59, 130, 246, 0.2); }
    .popular-tag {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
        background: var(--flux-primary);
        color: white;
        padding: 4px 16px;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
    }
    .price { font-size: 3rem; font-weight: 800; margin: 24px 0; }
    .price span { font-size: 1rem; color: rgba(255,255,255,0.4); font-weight: 400; }
    .price-features { list-style: none; padding: 0; margin: 0 0 40px 0; flex: 1; }
    .price-features li { padding: 12px 0; border-bottom: 1px solid var(--flux-border); font-size: 0.95rem; color: rgba(255,255,255,0.7); }

    /* Footer */
    .flux-footer { padding: 80px 0 40px; border-top: 1px solid var(--flux-border); }
    .footer-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; margin-bottom: 64px; }
    .footer-brand p { margin-top: 16px; max-width: 240px; }
    .footer-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
    .link-group h4 { margin-bottom: 24px; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); }
    .link-group a { display: block; margin-bottom: 12px; color: rgba(255,255,255,0.6); text-decoration: none; transition: color 0.2s; }
    .link-group a:hover { color: white; }
    .footer-bottom { padding-top: 40px; border-top: 1px solid var(--flux-border); display: flex; justify-content: space-between; align-items: center; color: rgba(255,255,255,0.3); font-size: 0.875rem; }
    .social-links { display: flex; gap: 24px; }
    .social-links a { color: inherit; text-decoration: none; transition: color 0.2s; }
    .social-links a:hover { color: white; }

    /* Responsive */
    @@media (max-width: 1024px) {
        h1 { font-size: 3.5rem; }
        .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 40px; }
        .hero-btns { justify-content: center; }
        .nav-left .nav-links { display: none; }
        .footer-grid { grid-template-columns: 1fr; gap: 40px; }
    }
</style>

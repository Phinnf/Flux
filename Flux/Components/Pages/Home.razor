@page "/"
@inject NavigationManager Navigation
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Flux - Unified Communication & Task Management</PageTitle>

<div class="scenic-landing-page">
    <!-- Transparent Navbar -->
    <nav class="scenic-nav">
        <div class="logo-container">
            <span class="logo-text">FLUX</span>
        </div>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#services">Services</a>
            <a href="#contact">Contact</a>
            <a href="#about">About</a>
        </div>
        <div class="nav-actions">
            <button class="scenic-btn-outline" @onclick='() => Navigation.NavigateTo("/auth")'>Login</button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="scenic-hero">
        <div class="hero-content-wrapper">
            <div class="hero-text-content">
                <div class="animated-pill">🚀 The Future of Work</div>
                <h1 class="hero-heading">Where Communication<br/>Meets Productivity</h1>
                <p class="hero-subheading">
                    Flux brings your team's chats and tasks into one unified platform. 
                    Turn conversations into actionable tasks with a single click.
                </p>
                <div class="hero-buttons">
                    <button class="scenic-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>
                        Start for free
                    </button>
                    <button class="scenic-btn-text">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Play())" Color="Color.Custom" CustomColor="#ffffff" Style="margin-right: 8px;" />
                        Watch Demo
                    </button>
                </div>
            </div>
            
            <div class="hero-visual-content">
                <!-- Kept the cool mockup but styled it to match the new vibe -->
                <div class="glass-mockup">
                    <div class="glass-header">
                        <div class="dots"><span></span><span></span><span></span></div>
                        <span class="title">Flux Workspace</span>
                    </div>
                    <div class="glass-body">
                        <div class="glass-sidebar"></div>
                        <div class="glass-chat">
                            <div class="glass-msg left"></div>
                            <div class="glass-msg right"></div>
                            <div class="glass-msg left" style="width: 80%;"></div>
                        </div>
                    </div>
                    
                    <div class="floating-badge badge-success">
                        <FluentIcon Value="@(new Icons.Regular.Size20.CheckmarkCircle())" Color="Color.Success" />
                        Task Completed
                    </div>
                    <div class="floating-badge badge-warning">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Alert())" Color="Color.Warning" />
                        New Message
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* Immersive Scenic Background */
    .scenic-landing-page {
        min-height: 100vh;
        width: 100%;
        /* Simulating the vibrant sunset/night landscape with a rich gradient */
        background: linear-gradient(135deg, #1a0b2e 0%, #4b1d52 40%, #89216b 80%, #e14960 100%);
        color: white;
        font-family: 'Inter', 'Segoe UI', sans-serif;
        position: relative;
        overflow: hidden;
    }

    /* Ambient Sun/Moon Glow */
    .scenic-landing-page::before {
        content: '';
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(255, 230, 153, 0.4) 0%, transparent 60%);
        top: 10%;
        left: 30%;
        border-radius: 50%;
        pointer-events: none;
    }

    /* Navbar */
    .scenic-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 25px 60px;
        position: relative;
        z-index: 10;
    }

    .logo-text {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 2px;
        color: white;
    }

    .nav-links {
        display: flex;
        gap: 40px;
    }

    .nav-links a {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .nav-links a:hover {
        color: white;
    }

    /* Standardized Buttons (Fixes the Fluent UI button layout break) */
    .scenic-btn-outline {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, 0.6);
        color: white;
        padding: 8px 30px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .scenic-btn-outline:hover {
        border-color: white;
        background: rgba(255, 255, 255, 0.1);
    }

    .scenic-btn-primary {
        background: white;
        color: #4b1d52;
        border: none;
        padding: 15px 40px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .scenic-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 25px rgba(0,0,0,0.3);
    }

    .scenic-btn-text {
        background: transparent;
        border: none;
        color: white;
        display: flex;
        align-items: center;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        padding: 15px 20px;
    }

    /* Hero Section */
    .scenic-hero {
        padding: 60px 60px;
        min-height: calc(100vh - 90px);
        display: flex;
        align-items: center;
        position: relative;
        z-index: 2;
    }

    .hero-content-wrapper {
        display: flex;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
        align-items: center;
        gap: 60px;
    }

    .hero-text-content {
        flex: 1;
        animation: slideUp 0.8s ease-out;
    }

    .animated-pill {
        display: inline-block;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 25px;
        backdrop-filter: blur(10px);
    }

    .hero-heading {
        font-size: 4.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin: 0 0 25px 0;
        letter-spacing: -1px;
    }

    .hero-subheading {
        font-size: 1.2rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.8);
        max-width: 500px;
        margin-bottom: 40px;
    }

    .hero-buttons {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .hero-visual-content {
        flex: 1;
        display: flex;
        justify-content: center;
        position: relative;
        animation: fadeIn 1s ease-out 0.3s both;
    }

    /* Redesigned Glass Mockup */
    .glass-mockup {
        width: 500px;
        height: 340px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.3);
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .glass-header {
        height: 36px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        padding: 0 15px;
    }

    .dots {
        display: flex;
        gap: 6px;
    }

    .dots span {
        width: 12px; height: 12px; border-radius: 50%;
    }
    .dots span:nth-child(1) { background: #ff5f56; }
    .dots span:nth-child(2) { background: #ffbd2e; }
    .dots span:nth-child(3) { background: #27c93f; }

    .title {
        margin: 0 auto;
        font-size: 13px;
        color: rgba(255,255,255,0.7);
    }

    .glass-body {
        display: flex;
        flex: 1;
    }

    .glass-sidebar {
        width: 100px;
        border-right: 1px solid rgba(255,255,255,0.1);
        background: rgba(0,0,0,0.1);
    }

    .glass-chat {
        flex: 1;
        padding: 25px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .glass-msg {
        height: 30px;
        border-radius: 15px;
        background: rgba(255,255,255,0.1);
    }

    .glass-msg.left { width: 65%; align-self: flex-start; }
    .glass-msg.right { width: 55%; align-self: flex-end; background: rgba(255,255,255,0.2); }

    /* Floating Badges */
    .floating-badge {
        position: absolute;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 12px 20px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .badge-success {
        top: 50px; right: -40px;
        animation: floatY 4s ease-in-out infinite;
    }

    .badge-warning {
        bottom: 80px; left: -50px;
        animation: floatY 5s ease-in-out infinite reverse;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @@keyframes floatY {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }
</style>

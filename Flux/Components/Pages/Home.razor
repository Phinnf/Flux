@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation
@layout Flux.Components.Layout.EmptyLayout

<PageTitle>Flux - Get More Done</PageTitle>

<div class="whitespace-theme">
    <!-- Navbar -->
    <nav class="ws-nav">
        <div class="ws-nav-left">
            <div class="ws-logo">
                <svg class="w-6 h-6 text-white mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Flux
            </div>
            <div class="ws-links">
                <a href="#">Products <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></a>
                <a href="#">Solutions <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></a>
                <a href="#">Resources <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></a>
                <a href="#">Pricing <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg></a>
            </div>
        </div>
        <div class="ws-nav-right">
            <AuthorizeView>
                <Authorized>
                    <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/workspaces")'>Go to Workspaces <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
                </Authorized>
                <NotAuthorized>
                    <button class="ws-btn-secondary" @onclick='() => Navigation.NavigateTo("/auth")'>Login</button>
                    <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Try Flux free <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="ws-hero">
        <div class="ws-container hero-grid">
            <div class="hero-content">
                <h1>Get More Done with Flux</h1>
                <p>Unified communication software that enables your teams to collaborate, chat, and manage everyday tasks seamlessly.</p>
                <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Try Flux free <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
            </div>
            <div class="hero-image">
                <div class="placeholder-box blue-box"></div>
            </div>
        </div>
    </section>

    <!-- Project Management (Task Conversion) -->
    <section class="ws-section light-section relative-section">
        <div class="bg-pattern pattern-top-left"></div>
        <div class="ws-container feature-grid">
            <div class="feature-content">
                <h2>Message to <br/><span class="underline-accent">Task Management</span></h2>
                <p>Don't let ideas get lost in the chat. Convert any message into an actionable task with a single click. Organize them on Kanban boards, assign members, and track progress effortlessly.</p>
                <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Get Started <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
            </div>
            <div class="feature-image">
                <div class="placeholder-box light-blue-box"></div>
            </div>
        </div>
    </section>

    <!-- Work Together -->
    <section class="ws-section light-section">
        <div class="ws-container feature-grid reverse">
            <div class="feature-content">
                <h2>Work <span class="underline-accent">together</span></h2>
                <p>With Flux, communicate with your colleagues in public channels or private direct messages. Share files, record videos, and keep everyone on the same page.</p>
                <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Try it now <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
            </div>
            <div class="feature-image circle-diagram">
                <!-- Abstract circle diagram representation -->
                <div class="orbit">
                    <div class="center-logo">
                        <svg class="w-8 h-8 text-blue-500" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <div class="node n1" style="background: #A1D8B5;"></div>
                    <div class="node n2" style="background: #4CB572;"></div>
                    <div class="node n3" style="background: #135E4B;"></div>
                    <div class="node n4" style="background: #A1D8B5;"></div>
                    <div class="node n5" style="background: #135E4B;"></div>
                    <div class="node n6" style="background: #4CB572;"></div>
                    <div class="node n7" style="background: #A1D8B5;"></div>
                    <div class="node n8" style="background: #4CB572;"></div>
                    <div class="node n9" style="background: #4CB572;"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- Integrations / Extension -->
    <section class="ws-section dark-section">
        <div class="ws-container feature-grid">
            <div class="feature-content text-white">
                <h2>Use as <span class="underline-accent yellow-accent">Workspace</span></h2>
                <p>Create dedicated workspaces for different teams or projects. Keep channels, tasks, and members perfectly isolated and organized within their specific context.</p>
                <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Let's Go <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
            </div>
            <div class="feature-image">
                <div class="placeholder-box light-blue-box"></div>
            </div>
        </div>
    </section>

    <!-- Customise -->
    <section class="ws-section light-section">
        <div class="ws-container feature-grid reverse">
            <div class="feature-content">
                <h2>Customise it to <br/><span class="underline-accent">your needs</span></h2>
                <p>Organize your tasks with drag-and-drop Kanban boards. Tailor your workflow, categorize by status, and manage everyday productivity precisely how your team prefers.</p>
                <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Let's Go <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
            </div>
            <div class="feature-image">
                <div class="placeholder-box light-blue-box"></div>
            </div>
        </div>
    </section>

    <!-- Pricing -->
    <section class="ws-section light-section pricing-section">
        <div class="ws-container">
            <div class="pricing-header">
                <h2>Choose <span class="underline-accent">Your Plan</span></h2>
                <p>Whether you want to get organized, keep your personal life on track, or boost workplace productivity, Flux has the right plan for you.</p>
            </div>
            
            <div class="pricing-cards">
                <!-- Free -->
                <div class="price-card">
                    <h3>Free</h3>
                    <div class="price">$0</div>
                    <p class="subtitle">Capture ideas and find them quickly</p>
                    <ul class="features">
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Sync unlimited devices</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 10 GB monthly uploads</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 200 MB max. file size</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Convert messages to tasks</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Basic Kanban boards</li>
                    </ul>
                    <button class="ws-btn-outline" @onclick='() => Navigation.NavigateTo("/auth")'>Get Started</button>
                </div>

                <!-- Personal (Highlighted) -->
                <div class="price-card highlighted">
                    <h3>Pro</h3>
                    <div class="price">$11.99</div>
                    <p class="subtitle">Keep team productivity on track</p>
                    <ul class="features">
                        <li><svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Sync unlimited devices</li>
                        <li><svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 100 GB monthly uploads</li>
                        <li><svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 2 GB max. file size</li>
                        <li><svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Advanced Kanban boards</li>
                        <li><svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Video message recording</li>
                    </ul>
                    <button class="ws-btn-primary full-width" @onclick='() => Navigation.NavigateTo("/auth")'>Get Started</button>
                </div>

                <!-- Organization -->
                <div class="price-card">
                    <h3>Organization</h3>
                    <div class="price">$49.99</div>
                    <p class="subtitle">Capture ideas and find them quickly</p>
                    <ul class="features">
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Sync unlimited devices</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Unlimited monthly uploads</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> 10 GB max. file size</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Custom workspace branding</li>
                        <li><svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Priority support</li>
                    </ul>
                    <button class="ws-btn-outline" @onclick='() => Navigation.NavigateTo("/auth")'>Get Started</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Bottom Banner -->
    <section class="ws-section bottom-banner dark-section relative-section">
        <div class="bg-pattern pattern-bottom-left"></div>
        <div class="ws-container text-center">
            <h2 class="text-white">Your work, everywhere <span class="underline-accent blue-accent">you are</span></h2>
            <p class="text-white mt-4" style="max-width: 800px; margin: 20px auto 40px;">
                Access your messages and tasks from your computer, phone or tablet by synchronizing with various services. The web app is available on Windows, macOS, Linux, Android and iOS.
            </p>
            <button class="ws-btn-primary" @onclick='() => Navigation.NavigateTo("/auth")'>Try Flux <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></button>
        </div>
    </section>
</div>

<style>
    /* Flux Custom Theme Variables */
    :root {
        --ws-dark-blue: #0b0c10; /* Main Text & Dark Accents */
        --ws-light-blue: #3b82f6; /* Primary/Action Color */
        --ws-light-bg: #16181d; /* Secondary Background/Cards */
        --ws-main-bg: #0b0c10; /* Main Background */
        --ws-text: #e2e8f0; /* Main text color */
    }

    .whitespace-theme {
        font-family: 'Inter', sans-serif;
        color: var(--ws-text);
        background: var(--ws-main-bg);
        
        /* FIX FOR SCROLLING: Bypass the body { overflow: hidden; } in app.css */
        height: 100vh;
        width: 100vw;
        overflow-x: hidden;
        overflow-y: auto;
        background: transparent;
    }

    .ws-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
    }

    h1, h2, h3 { margin: 0; font-weight: 700; letter-spacing: -0.02em; color: var(--ws-dark-blue); }
    h1 { font-size: 4.5rem; line-height: 1.1; margin-bottom: 24px; }
    h2 { font-size: 4rem; line-height: 1.1; margin-bottom: 24px; }
    p { font-size: 1.125rem; line-height: 1.6; margin-bottom: 32px; }

    /* Buttons */
    .ws-btn-primary {
        background: var(--ws-light-blue);
        color: white;
        border: none;
        padding: 16px 32px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        transition: transform 0.2s, background 0.2s;
    }
    .ws-btn-primary:hover { 
        background: #3e9e60; 
        transform: translateY(-2px);
    }
    
    .ws-btn-secondary {
        background: var(--ws-light-bg);
        color: var(--ws-dark-blue);
        border: none;
        padding: 16px 32px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }
    .ws-btn-secondary:hover { background: #8dc5a0; }
    
    .ws-btn-outline {
        background: transparent;
        color: var(--ws-dark-blue);
        border: 2px solid var(--ws-dark-blue);
        padding: 16px 32px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: background 0.2s, color 0.2s;
    }
    .ws-btn-outline:hover {
        background: var(--ws-dark-blue);
        color: white;
    }

    .full-width { width: 100%; justify-content: center; }

    /* Navbar */
    .ws-nav {
        background: var(--ws-dark-blue);
        color: white;
        padding: 20px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .ws-nav-left { display: flex; align-items: center; gap: 60px; }
    .ws-logo { font-size: 1.5rem; font-weight: 700; display: flex; align-items: center; color: white; }
    .ws-links { display: flex; gap: 32px; }
    .ws-links a { color: rgba(255,255,255,0.9); text-decoration: none; font-size: 0.95rem; font-weight: 500; display: flex; align-items: center; gap: 4px; transition: color 0.2s; }
    .ws-links a:hover { color: white; }
    .ws-nav-right { display: flex; gap: 16px; }

    /* Layout Grids */
    .ws-section { padding: 120px 0; }
    .dark-section { background: var(--ws-dark-blue); }
    .light-section { background: var(--ws-main-bg); }
    .text-white { color: white !important; }
    
    .dark-section h1, .dark-section h2, .dark-section h3, .dark-section p { color: white; }

    .hero-grid, .feature-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    .feature-grid.reverse {
        grid-template-columns: 1fr 1fr;
    }
    .feature-grid.reverse .feature-content {
        order: 2;
    }
    .feature-grid.reverse .feature-image {
        order: 1;
    }

    /* Hero */
    .ws-hero {
        background: var(--ws-dark-blue);
        color: white;
        padding: 80px 0 120px;
        position: relative;
        overflow: hidden;
    }
    .ws-hero h1, .ws-hero p { color: white; }
    
    /* Background wave effect simulation */
    .ws-hero::before {
        content: ''; position: absolute; bottom: -50%; left: -10%; width: 120%; height: 100%;
        background: radial-gradient(ellipse at center, rgba(255,255,255,0.05) 0%, transparent 70%);
        pointer-events: none;
    }

    /* Placeholders */
    .placeholder-box {
        width: 100%;
        height: 450px;
        border-radius: 12px;
        box-shadow: 0 20px 40px rgba(19, 94, 75, 0.1);
    }
    .blue-box { background: var(--ws-light-bg); }
    .light-blue-box { background: var(--ws-light-bg); }

    /* Underline Accents */
    .underline-accent {
        position: relative;
        display: inline-block;
        z-index: 1;
    }
    .underline-accent::after {
        content: '';
        position: absolute;
        bottom: 8px;
        left: 0;
        width: 100%;
        height: 12px;
        background: var(--ws-light-bg);
        z-index: -1;
    }
    .yellow-accent::after { background: var(--ws-light-bg); }
    .blue-accent::after { background: var(--ws-light-blue); bottom: 4px; height: 8px; }

    /* Abstract Circle Diagram */
    .circle-diagram { display: flex; justify-content: center; align-items: center; height: 500px; }
    .orbit {
        width: 400px; height: 400px;
        border: 1.5px dashed var(--ws-dark-blue);
        opacity: 0.8;
        border-radius: 50%;
        position: relative;
        display: flex; justify-content: center; align-items: center;
    }
    .center-logo {
        width: 80px; height: 80px; background: white; border-radius: 16px;
        box-shadow: 0 10px 30px rgba(19, 94, 75, 0.15);
        display: flex; justify-content: center; align-items: center;
    }
    .node { position: absolute; border-radius: 50%; width: 24px; height: 24px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
    .n1 { top: -12px; left: 50%; transform: translateX(-50%); width: 40px; height: 40px; }
    .n2 { top: 20%; right: 10%; width: 30px; height: 30px; }
    .n3 { bottom: 20%; right: 5%; width: 35px; height: 35px; }
    .n4 { bottom: -15px; left: 30%; width: 45px; height: 45px; }
    .n5 { top: 30%; left: -10px; width: 35px; height: 35px; }
    
    /* Inner nodes */
    .n6 { top: 20%; left: 35%; }
    .n7 { bottom: 20%; left: 40%; }
    .n8 { right: 20%; top: 40%; }
    .n9 { left: 20%; top: 60%; }

    /* Pricing */
    .pricing-section { text-align: center; }
    .pricing-header { max-width: 700px; margin: 0 auto 60px; }
    .pricing-cards { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; }
    
    .price-card {
        background: white;
        border: 1px solid rgba(19, 94, 75, 0.1);
        border-radius: 12px;
        padding: 40px 30px;
        width: 320px;
        text-align: left;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 10px 30px rgba(19, 94, 75, 0.05);
    }
    .price-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(19, 94, 75, 0.1); }
    
    .price-card.highlighted {
        background: var(--ws-dark-blue);
        color: white;
        transform: scale(1.05);
        border: none;
        box-shadow: 0 20px 50px rgba(19, 94, 75, 0.2);
    }
    .price-card.highlighted:hover { transform: scale(1.05) translateY(-5px); }
    
    .price-card h3 { font-size: 1.5rem; margin-bottom: 20px; color: inherit; }
    .price-card .price { font-size: 2.5rem; font-weight: 700; margin-bottom: 20px; }
    .price-card .subtitle { font-size: 1rem; margin-bottom: 30px; font-weight: 500; }
    .price-card.highlighted .subtitle { color: rgba(255,255,255,0.8); }
    
    .features { list-style: none; padding: 0; margin: 0 0 40px 0; }
    .features li { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 20px; font-size: 0.95rem; line-height: 1.4; color: var(--ws-text); }
    .price-card.highlighted .features li { color: white; }

    /* Background Patterns */
    .relative-section { position: relative; overflow: hidden; }
    .bg-pattern { position: absolute; width: 300px; height: 300px; opacity: 0.3; z-index: 0; pointer-events: none; }
    .pattern-top-left { top: -50px; left: -50px; background: radial-gradient(circle, transparent 20%, var(--ws-dark-blue) 20%, var(--ws-dark-blue) 80%, transparent 80%, transparent) 0 0 / 20px 20px; }
    .pattern-bottom-left { bottom: -100px; left: -50px; border: 2px solid rgba(255,255,255,0.1); border-radius: 50%; width: 500px; height: 500px; }

    .bottom-banner { padding: 140px 0; }
    .mt-4 { margin-top: 1.5rem; }
    .text-center { text-align: center; }

    /* Responsive */
    @@media (max-width: 992px) {
        .hero-grid, .feature-grid, .feature-grid.reverse { grid-template-columns: 1fr; text-align: center; }
        .feature-grid.reverse .feature-content { order: 1; }
        .feature-grid.reverse .feature-image { order: 2; }
        h1 { font-size: 3.5rem; }
        h2 { font-size: 3rem; }
        .ws-nav-left .ws-links { display: none; }
        .price-card.highlighted { transform: scale(1); }
    }
</style>
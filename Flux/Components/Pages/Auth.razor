@page "/auth"
@layout Flux.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Flux.Infrastructure.Identity
@inject NavigationManager Navigation
@inject FluxClientService FluxService
@inject IJSRuntime JS
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@( _isRegister ? "Register" : "Login" ) - Flux</PageTitle>

<div class="auth-page-wrapper">
    <div class="auth-card">
        <!-- Form Section -->
        <div class="auth-form-section">
            
            <!-- Login View -->
            <div class="auth-view" style="display: @(!_isRegister && !_isVerifyingEmail ? "block" : "none")">
                <h1 class="auth-title">Welcome back!</h1>
                <p class="auth-subtitle">Enter your Credentials to access your account</p>

                <form @onsubmit="HandleLogin" class="auth-form">
                    <div class="form-group">
                        <label>Email address</label>
                        <input type="email" placeholder="Enter your email" @bind="_loginEmail" required />
                    </div>
                    
                    <div class="form-group">
                        <div class="label-row">
                            <label>Password</label>
                            <a href="/forgot-password" class="forgot-link">Forgot password</a>
                        </div>
                        <div class="password-input-wrapper">
                            <input type="@(_showLoginPassword ? "text" : "password")" placeholder="Enter your password" @bind="_loginPassword" required />
                            <FluentIcon Value="@( (Icon)(_showLoginPassword ? new Icons.Regular.Size20.Eye() : new Icons.Regular.Size20.EyeOff()) )" 
                                       class="password-toggle-icon" 
                                       @onclick="() => _showLoginPassword = !_showLoginPassword" />
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(_loginError))
                    {
                        <div class="auth-error">@_loginError</div>
                    }

                    <div class="checkbox-group">
                        <input type="checkbox" id="rememberMe" @bind="_rememberMe" />
                        <label for="rememberMe">Remember for 30 days</label>
                    </div>
                    
                    <button type="submit" class="primary-btn" disabled="@_isLoading">
                        @if (_isLoading) { <FluentProgressRing Width="20px" Style="margin-right: 8px; color: white;" /> }
                        Login
                    </button>
                </form>

                <div class="divider">
                    <span>Or</span>
                </div>

                <div class="social-login">
                    <button type="button" class="social-btn" @onclick="LoginWithGoogle">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20px" height="20px">
                            <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
                            <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                            <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
                            <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
                        </svg>
                        Sign in with Google
                    </button>
                    <button type="button" class="social-btn" @onclick="LoginWithGitHub">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20px" height="20px">
                            <path fill="#24292e" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                        Sign in with GitHub
                    </button>
                </div>

                <p class="switch-auth">
                    Don't have an account? <a href="javascript:void(0)" @onclick="() => { _isRegister = true; _isVerifyingEmail = false; _successMessage = null; _loginError = null; }">Sign Up</a>
                </p>
            </div>

            <!-- Register View -->
            <div class="auth-view" style="display: @(_isRegister && !_isVerifyingEmail ? "block" : "none")">
                <h1 class="auth-title" style="margin-bottom: 30px;">Get Started Now</h1>

                <form @onsubmit="HandleRegister" class="auth-form">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" placeholder="Enter your name" @bind="_registerUsername" required />
                    </div>
                    
                    <div class="form-group">
                        <label>Email address</label>
                        <input type="email" placeholder="Enter your email" @bind="_registerEmail" required />
                    </div>
                    
                    <div class="form-group">
                        <label>Password</label>
                        <div class="password-input-wrapper">
                            <input type="@(_showRegisterPassword ? "text" : "password")" placeholder="Enter your password" @bind="_registerPassword" required />
                            <FluentIcon Value="@( (Icon)(_showRegisterPassword ? new Icons.Regular.Size20.Eye() : new Icons.Regular.Size20.EyeOff()) )" 
                                       class="password-toggle-icon" 
                                       @onclick="() => _showRegisterPassword = !_showRegisterPassword" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_registerError))
                    {
                        <div class="auth-error">@_registerError</div>
                    }

                    <div class="checkbox-group">
                        <input type="checkbox" id="terms" required />
                        <label for="terms">I agree to the terms & policy</label>
                    </div>
                    
                    <button type="submit" class="primary-btn" disabled="@_isLoading">
                        @if (_isLoading) { <FluentProgressRing Width="20px" Style="margin-right: 8px; color: white;" /> }
                        Signup
                    </button>
                </form>

                <div class="divider">
                    <span>Or</span>
                </div>

                <div class="social-login">
                    <button type="button" class="social-btn" @onclick="LoginWithGoogle">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20px" height="20px">
                            <path fill="#FFC107" d="M43.611,20.083H42V20H24v8h11.303c-1.649,4.657-6.08,8-11.303,8c-6.627,0-12-5.373-12-12c0-6.627,5.373-12,12-12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C12.955,4,4,12.955,4,24c0,11.045,8.955,20,20,20c11.045,0,20-8.955,20-20C44,22.659,43.862,21.35,43.611,20.083z"/>
                            <path fill="#FF3D00" d="M6.306,14.691l6.571,4.819C14.655,15.108,18.961,12,24,12c3.059,0,5.842,1.154,7.961,3.039l5.657-5.657C34.046,6.053,29.268,4,24,4C16.318,4,9.656,8.337,6.306,14.691z"/>
                            <path fill="#4CAF50" d="M24,44c5.166,0,9.86-1.977,13.409-5.192l-6.19-5.238C29.211,35.091,26.715,36,24,36c-5.202,0-9.619-3.317-11.283-7.946l-6.522,5.025C9.505,39.556,16.227,44,24,44z"/>
                            <path fill="#1976D2" d="M43.611,20.083H42V20H24v8h11.303c-0.792,2.237-2.231,4.166-4.087,5.571l6.19,5.238C36.971,39.205,44,34,44,24C44,22.659,43.862,21.35,43.611,20.083z"/>
                        </svg>
                        Sign in with Google
                    </button>
                    <button type="button" class="social-btn" @onclick="LoginWithGitHub">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20px" height="20px">
                            <path fill="#24292e" d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                        Sign in with GitHub
                    </button>
                </div>

                <p class="switch-auth">
                    Have an account? <a href="javascript:void(0)" @onclick="() => { _isRegister = false; _isVerifyingEmail = false; _successMessage = null; _registerError = null; }">Sign In</a>
                </p>
            </div>

            <!-- Verify Email View -->
            <div class="auth-view" style="display: @(_isVerifyingEmail ? "block" : "none")">
                <h1 class="auth-title">Verify Email</h1>
                <p class="auth-subtitle">
                    We've sent a 6-digit code to <strong>@_registerEmail</strong>. Please enter it below.
                </p>
                <form @onsubmit="HandleVerifyEmail" class="auth-form">
                    <div class="form-group">
                        <label>6-digit OTP</label>
                        <input type="text" placeholder="Enter OTP" @bind="_verifyOtp" required maxlength="6" style="text-align: center; letter-spacing: 5px; font-size: 1.2rem; font-weight: 600;" />
                    </div>

                    @if (!string.IsNullOrEmpty(_verifyError))
                    {
                        <div class="auth-error">@_verifyError</div>
                    }

                    @if (!string.IsNullOrEmpty(_successMessage))
                    {
                        <div class="auth-success">@_successMessage</div>
                    }
                    
                    <button type="submit" class="primary-btn" disabled="@_isLoading">
                        @if (_isLoading) { <FluentProgressRing Width="20px" Style="margin-right: 8px; color: white;" /> }
                        Verify
                    </button>
                </form>

                <p class="switch-auth">
                    <a href="javascript:void(0)" @onclick="() => { _isVerifyingEmail = false; _isRegister = true; }">Back to Registration</a>
                </p>
            </div>

        </div>

        <!-- Image Section -->
        <div class="auth-image-section">
            <img src="https://images.unsplash.com/photo-1518531933037-91b2f5f229cc?q=80&w=2727&auto=format&fit=crop" alt="Monstera plant" />
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                Navigation.NavigateTo("/workspaces", forceLoad: true);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Token))
        {
            _isLoading = true;
            StateHasChanged();

            await JS.InvokeVoidAsync("localStorage.setItem", "authToken", Token);
            
            if (AuthStateProvider is FluxAuthStateProvider fluxAuthProvider)
            {
                fluxAuthProvider.NotifyUserAuthentication(Token);
            }
            
            ToastService.ShowSuccess("Login successful!");
            Navigation.NavigateTo("/workspaces");
        }
    }

    private bool _isRegister = false;
    private bool _isVerifyingEmail = false;
    private bool _isLoading = false;
    private string? _successMessage;
    private bool _showLoginPassword = false;
    private bool _showRegisterPassword = false;

    // Login
    private string _loginEmail = "";
    private string _loginPassword = "";
    private string? _loginError;
    private bool _rememberMe = false;

    // Register
    private string _registerUsername = "";
    private string _registerEmail = "";
    private string _registerPassword = "";
    private string? _registerError;

    // Verify Email
    private string _verifyOtp = "";
    private string? _verifyError;

    private async Task HandleLogin()
    {
        _loginError = null;
        _successMessage = null;
        _isLoading = true;
        StateHasChanged();
        
        var result = await FluxService.LoginAsync(_loginEmail, _loginPassword);
        
        if (result.IsSuccess)
        {
            if (_rememberMe)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Value);
            }
            else
            {
                await JS.InvokeVoidAsync("sessionStorage.setItem", "authToken", result.Value);
            }
            
            // Notify the authentication state provider
            if (AuthStateProvider is FluxAuthStateProvider fluxAuthProvider)
            {
                fluxAuthProvider.NotifyUserAuthentication(result.Value!);
            }
            
            ToastService.ShowSuccess("Login successful!");
            ToastService.ShowInfo("Redirecting to workspaces...");
            
            await Task.Delay(1500); // 1.5s delay so the user can see the popup
            
            // Redirect to workspace selection page
            Navigation.NavigateTo("/workspaces");
        }
        else
        {
            _loginError = result.Error ?? "Login failed. Please check your credentials.";
        }
        
        _isLoading = false;
        StateHasChanged();
    }

    private async Task HandleRegister()
    {
        _registerError = null;
        _successMessage = null;
        _isLoading = true;
        StateHasChanged();
        
        var result = await FluxService.RegisterAsync(_registerUsername, _registerEmail, _registerPassword);
        
        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("OTP sent to your email.");
            _isVerifyingEmail = true;
        }
        else
        {
            _registerError = result.Error ?? "Registration failed. Please try again.";
        }

        _isLoading = false;
        StateHasChanged();
    }

    private async Task HandleVerifyEmail()
    {
        _verifyError = null;
        _isLoading = true;
        StateHasChanged();

        var result = await FluxService.VerifyEmailAsync(_registerEmail, _verifyOtp);

        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Email verified successfully! You can now login.");
            _isVerifyingEmail = false;
            _isRegister = false;
            _loginEmail = _registerEmail;
            
            // Clear register form
            _registerUsername = "";
            _registerEmail = "";
            _registerPassword = "";
            _verifyOtp = "";
        }
        else
        {
            _verifyError = result.Error ?? "Invalid or expired OTP.";
        }

        _isLoading = false;
        StateHasChanged();
    }

    private void LoginWithGoogle()
    {
        Navigation.NavigateTo("/api/auth/google", forceLoad: true);
    }

    private void LoginWithGitHub()
    {
        Navigation.NavigateTo("/api/auth/github", forceLoad: true);
    }
}
@page "/auth"
@layout Flux.Components.Layout.EmptyLayout
@using Microsoft.AspNetCore.Components.Authorization
@using Flux.Infrastructure.Identity
@inject NavigationManager Navigation
@inject AuthClientService AuthService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@( _isRegister ? "Join Flux" : "Welcome Back" )</PageTitle>

<div class="flux-auth min-h-screen flex items-center justify-center p-6">
    <!-- Glow Effects -->
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>

    <div class="auth-card glass-card animate-in">
        <div class="auth-grid">
            <!-- Left Side: Content -->
            <div class="auth-content">
                <div class="auth-header">
                    <div class="flux-logo" @onclick='() => Navigation.NavigateTo("/")'>
                        <div class="logo-icon">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M13 10V3L4 14h7v7l9-11h-7z" fill="currentColor"/>
                            </svg>
                        </div>
                        <span>Flux</span>
                    </div>
                    <h1>@(_isRegister ? "Create Account" : "Welcome Back")</h1>
                    <p>@(_isRegister ? "Start your journey with us today." : "Please enter your details to sign in.")</p>
                </div>

                @if (_isMfaRequired)
                {
                    <div class="verify-form fade-in">
                        <div class="verify-icon">
                            <svg class="w-10 h-10 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </div>
                        <h2>Two-Factor Auth</h2>
                        <p>Enter the security code sent to <span class="text-gradient">@_loginEmail</span></p>

                        <form @onsubmit="HandleVerifyMfa" class="space-y-6">
                            <div class="input-group">
                                <input type="text" @bind="_mfaOtp" placeholder="••••••" maxlength="6"
                                       class="glass-input otp-input" />
                            </div>

                            @if (!string.IsNullOrEmpty(_mfaError))
                            {
                                <div class="error-msg">@_mfaError</div>
                            }

                            <button type="submit" class="flux-btn-primary full-width" disabled="@_isLoading">
                                @(_isLoading ? "Verifying..." : "Verify & Sign In")
                            </button>
                        </form>

                        <button @onclick="() => _isMfaRequired = false" class="back-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                            Back to login
                        </button>
                    </div>
                }
                else if (_isVerifyingEmail)
                {
                    <div class="verify-form fade-in">
                        <div class="verify-icon">
                            <svg class="w-10 h-10 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <h2>Verify your email</h2>
                        <p>We've sent a code to <span class="text-gradient">@_registerEmail</span></p>

                        <form @onsubmit="HandleVerifyEmail" class="space-y-6">
                            <div class="input-group">
                                <input type="text" @bind="_verifyOtp" placeholder="••••••" maxlength="6"
                                       class="glass-input otp-input" />
                            </div>

                            @if (!string.IsNullOrEmpty(_verifyError))
                            {
                                <div class="error-msg">@_verifyError</div>
                            }

                            <button type="submit" class="flux-btn-primary full-width" disabled="@_isLoading">
                                @(_isLoading ? "Verifying..." : "Verify Account")
                            </button>
                        </form>

                        <button @onclick="() => _isVerifyingEmail = false" class="back-link">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                            Back to registration
                        </button>
                    </div>
                }
                else
                {
                    <form @onsubmit="HandleSubmit" class="auth-form">
                        @if (_isRegister)
                        {
                            <div class="input-group">
                                <label>Username</label>
                                <div class="input-group-icon icon-left">
                                    <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                                    <input type="text" @bind="_registerUsername" placeholder="Enter your username" required class="glass-input" />
                                </div>
                            </div>

                            <div class="input-group">
                                <label>Email Address</label>
                                <div class="input-group-icon icon-left">
                                    <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                    <input type="email" @bind="_registerEmail" placeholder="name@example.com" required class="glass-input" />
                                </div>
                            </div>

                            <div class="input-group">
                                <label>Password</label>
                                <div class="input-group-icon icon-right">
                                    <input type="@(_showPassword ? "text" : "password")" @bind="_registerPassword" placeholder="••••••••" required class="glass-input" />
                                    <button type="button" class="toggle-password" @onclick="() => _showPassword = !_showPassword">
                                        @if (_showPassword)
                                        {
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543 7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268-2.943-9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>
                                        }
                                        else
                                        {
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268-2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                        }
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="input-group">
                                <label>Email Address</label>
                                <div class="input-group-icon icon-left">
                                    <svg class="input-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                                    <input type="email" @bind="_loginEmail" placeholder="name@example.com" required class="glass-input" />
                                </div>
                            </div>

                            <div class="input-group">
                                <div class="label-row">
                                    <label>Password</label>
                                    <a href="/forgot-password" class="forgot-link">Forgot?</a>
                                </div>
                                <div class="input-group-icon icon-right">
                                    <input type="@(_showPassword ? "text" : "password")" @bind="_loginPassword" placeholder="••••••••" required class="glass-input" />
                                    <button type="button" class="toggle-password" @onclick="() => _showPassword = !_showPassword">
                                        @if (_showPassword)
                                        {
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543 7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268-2.943-9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>
                                        }
                                        else
                                        {
                                            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268-2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                                        }
                                    </button>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="error-msg">@_errorMessage</div>
                        }

                        <button type="submit" class="flux-btn-primary full-width" disabled="@_isLoading">
                            @if (_isLoading)
                            {
                                <div class="loader-small"></div>
                            }
                            else
                            {
                                <span>@(_isRegister ? "Create Account" : "Sign In")</span>
                                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                            }
                        </button>
                    </form>

                    <div class="divider">
                        <span>or continue with</span>
                    </div>

                    <div class="social-grid">
                        <button type="button" @onclick="LoginWithGoogle" class="social-btn glass-card">
                            <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" />
                            <span>Google</span>
                        </button>
                        <button type="button" @onclick="LoginWithGitHub" class="social-btn glass-card">
                            <img src="https://www.svgrepo.com/show/512317/github-142.svg" alt="GitHub" class="invert" />
                            <span>GitHub</span>
                        </button>
                    </div>

                    <p class="toggle-auth">
                        @(_isRegister ? "Already have an account?" : "New to Flux?") 
                        <button type="button" @onclick="ToggleMode" class="toggle-btn">
                            @(_isRegister ? "Sign In" : "Create Account")
                        </button>
                    </p>
                }
            </div>

            <!-- Right Side: Visual -->
            <div class="auth-visual">
                <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop" alt="Decoration" />
                <div class="visual-overlay"></div>
                <div class="visual-content">
                    <h3>Connect <span class="text-gradient">Globally.</span></h3>
                    <p>Join thousands of teams collaborating in real-time across the world.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .flux-auth {
        background-color: var(--flux-main-bg);
        color: var(--flux-main-text);
        position: relative;
        overflow: hidden;
    }

    /* Glow Orbs */
    .glow-orb {
        position: absolute;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
        z-index: 0;
        pointer-events: none;
    }
    .orb-1 { top: -200px; right: -200px; background: var(--flux-primary); }
    .orb-2 { bottom: -200px; left: -200px; background: var(--flux-secondary); }

    .auth-card {
        width: 100%;
        max-width: 1000px;
        overflow: hidden;
        border-radius: 32px;
        z-index: 10;
    }

    .auth-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; min-height: 700px; }

    .auth-content { padding: 64px; display: flex; flex-direction: column; justify-content: center; }

    .auth-header { margin-bottom: 40px; }
    .flux-logo { 
        display: flex; 
        align-items: center; 
        gap: 12px; 
        font-weight: 800; 
        font-size: 1.5rem; 
        margin-bottom: 32px;
        cursor: pointer;
    }
    .logo-icon {
        width: 32px;
        height: 32px;
        background: var(--flux-primary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }
    .auth-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 12px; color: white; }
    .auth-header p { color: rgba(255,255,255,0.5); }

    .auth-form { display: flex; flex-direction: column; gap: 20px; }
    .input-group { display: flex; flex-direction: column; gap: 8px; }
    .input-group label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); margin-left: 4px; }
    
    .label-row { display: flex; justify-content: space-between; align-items: center; }
    .forgot-link { font-size: 0.75rem; font-weight: 700; color: var(--flux-primary); text-decoration: none; }
    .forgot-link:hover { text-decoration: underline; }

    .toggle-password { color: rgba(255,255,255,0.2); background: none; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10; height: 100%; }
    .toggle-password:hover { color: white; }
    .toggle-password svg { width: 20px; height: 20px; transition: all 0.3s ease; }

    .error-msg { 
        padding: 12px; 
        background: rgba(239, 68, 68, 0.1); 
        border: 1px solid rgba(239, 68, 68, 0.2); 
        border-radius: 12px; 
        color: #ef4444; 
        font-size: 0.875rem; 
        text-align: center;
    }

    .divider { position: relative; text-align: center; margin: 32px 0; }
    .divider::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: var(--flux-border); }
    .divider span { position: relative; background: #16181d; padding: 0 16px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3); }

    .social-grid { display: grid; grid-template-cols: 1fr 1fr; gap: 16px; }
    .social-btn { 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        gap: 12px; 
        padding: 12px; 
        font-size: 0.875rem; 
        font-weight: 600; 
        color: white; 
        cursor: pointer; 
        transition: all 0.2s;
    }
    .social-btn:hover { background: rgba(255,255,255,0.05); transform: translateY(-2px); }
    .social-btn img { width: 20px; height: 20px; }
    .invert { filter: invert(1); }

    .toggle-auth { text-align: center; margin-top: 32px; font-size: 0.875rem; color: rgba(255,255,255,0.5); }
    .toggle-btn { background: none; border: none; color: var(--flux-primary); font-weight: 700; cursor: pointer; margin-left: 4px; }
    .toggle-btn:hover { text-decoration: underline; }

    /* Verify Section */
    .verify-form { text-align: center; }
    .verify-icon { width: 80px; height: 80px; background: rgba(59, 130, 246, 0.1); border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px; border: 1px solid rgba(59, 130, 246, 0.2); }
    .verify-form h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 8px; }
    .otp-input { text-align: center; font-size: 1.5rem; letter-spacing: 0.5em; font-weight: 800; }
    .back-link { display: flex; align-items: center; justify-content: center; gap: 8px; margin: 32px auto 0; background: none; border: none; color: rgba(255,255,255,0.3); cursor: pointer; font-size: 0.875rem; }
    .back-link:hover { color: white; }

    /* Visual Side */
    .auth-visual { position: relative; overflow: hidden; }
    .auth-visual img { width: 100%; height: 100%; object-cover: cover; }
    .visual-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(11, 12, 16, 0.8) 0%, transparent 60%); }
    .visual-content { position: absolute; bottom: 48px; left: 48px; right: 48px; }
    .visual-content h3 { font-size: 2rem; font-weight: 800; margin-bottom: 12px; }
    .visual-content p { color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.5; }

    .text-gradient {
        background: linear-gradient(135deg, var(--flux-primary) 0%, var(--flux-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .flux-btn-primary {
        background: var(--flux-primary);
        color: white;
        padding: 14px 24px;
        border-radius: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
    }
    .flux-btn-primary:hover { 
        background: var(--flux-primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px -4px rgba(59, 130, 246, 0.4);
    }
    .full-width { width: 100%; }

    .loader-small {
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.2);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .animate-in { animation: fadeInScale 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes fadeInScale {
        from { opacity: 0; transform: scale(0.95) translateY(20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    @@media (max-width: 1024px) {
        .auth-grid { grid-template-columns: 1fr; }
        .auth-visual { display: none; }
        .auth-content { padding: 48px; }
    }
    @@media (max-width: 640px) {
        .auth-content { padding: 32px; }
        .auth-header h1 { font-size: 2rem; }
        .social-grid { grid-template-columns: 1fr; }
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private bool _isRegister = false;
    private bool _isVerifyingEmail = false;
    private bool _isLoading = false;
    private bool _showPassword = false;
    private string? _errorMessage;
    private string? _verifyError;

    // Form fields
    private string _loginEmail = "";
    private string _loginPassword = "";
    private string _registerUsername = "";
    private string _registerEmail = "";
    private string _registerPassword = "";
    private string _verifyOtp = "";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                Navigation.NavigateTo("/workspaces", forceLoad: true);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Token))
        {
            await SaveTokenAndRedirect(Token);
        }
    }

    private bool _isMfaRequired = false;
    private string _mfaOtp = "";
    private string? _mfaError;

    private void ToggleMode()
    {
        _isRegister = !_isRegister;
        _errorMessage = null;
    }

    private async Task HandleSubmit()
    {
        if (_isRegister)
            await HandleRegister();
        else
            await HandleLogin();
    }

    private async Task HandleLogin()
    {
        _errorMessage = null;
        _isLoading = true;
        StateHasChanged();

        var result = await AuthService.LoginAsync(_loginEmail, _loginPassword);
        
        if (result.IsSuccess)
        {
            if (result.Value!.RequiresTwoFactor)
            {
                _isMfaRequired = true;
                _isLoading = false;
            }
            else
            {
                await SaveTokenAndRedirect(result.Value.Token!);
            }
        }
        else
        {
            _errorMessage = result.Error;
            _isLoading = false;
        }
        StateHasChanged();
    }

    private async Task HandleVerifyMfa()
    {
        _mfaError = null;
        _isLoading = true;
        StateHasChanged();

        var result = await AuthService.VerifyMfaAsync(_loginEmail, _mfaOtp);

        if (result.IsSuccess)
        {
            await SaveTokenAndRedirect(result.Value!);
        }
        else
        {
            _mfaError = result.Error;
        }

        _isLoading = false;
        StateHasChanged();
    }

    private async Task HandleRegister()
    {
        _errorMessage = null;
        _isLoading = true;
        StateHasChanged();

        // Validation
        if (!IsValidEmail(_registerEmail))
        {
            _errorMessage = "Please enter a valid email address.";
            _isLoading = false;
            return;
        }

        if (!IsValidPassword(_registerPassword))
        {
            _errorMessage = "Password doesn't meet security requirements.";
            _isLoading = false;
            return;
        }

        var result = await AuthService.RegisterAsync(_registerUsername, _registerEmail, _registerPassword);
        
        if (result.IsSuccess)
        {
            _isVerifyingEmail = true;
        }
        else
        {
            _errorMessage = result.Error;
        }

        _isLoading = false;
        StateHasChanged();
    }

    private async Task HandleVerifyEmail()
    {
        _verifyError = null;
        _isLoading = true;
        StateHasChanged();

        var result = await AuthService.VerifyEmailAsync(_registerEmail, _verifyOtp);

        if (result.IsSuccess)
        {
            _isVerifyingEmail = false;
            _isRegister = false;
            _loginEmail = _registerEmail;
            _loginPassword = "";
            _errorMessage = "Email verified! Please sign in.";
        }
        else
        {
            _verifyError = result.Error;
        }

        _isLoading = false;
        StateHasChanged();
    }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private async Task SaveTokenAndRedirect(string token)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "authToken", token);
        
        if (AuthStateProvider is FluxAuthStateProvider fluxAuthProvider)
        {
            fluxAuthProvider.NotifyUserAuthentication(token);
        }
        
        if (!string.IsNullOrEmpty(ReturnUrl) && IsLocalUrl(ReturnUrl))
        {
            Navigation.NavigateTo(ReturnUrl);
        }
        else
        {
            Navigation.NavigateTo("/workspaces");
        }
    }

    private bool IsLocalUrl(string url)
    {
        if (string.IsNullOrEmpty(url)) return true;
        return url.StartsWith("/") && !url.StartsWith("//") && !url.StartsWith("/\\");
    }

    private bool IsValidEmail(string email) => 
        new System.Text.RegularExpressions.Regex(@"^[^@\s]+@[^@\s]+\.[^@\s]+$").IsMatch(email);

    private bool IsValidPassword(string password) => 
        new System.Text.RegularExpressions.Regex(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$").IsMatch(password);

    private void LoginWithGoogle() => Navigation.NavigateTo("/api/auth/google", forceLoad: true);
    private void LoginWithGitHub() => Navigation.NavigateTo("/api/auth/github", forceLoad: true);
}
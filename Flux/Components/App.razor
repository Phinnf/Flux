<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="Flux.styles.css" />
    <link rel="stylesheet" href="css/app.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#3b82f6',
                        secondary: '#64748b',
                        fluxPrimary: '#3E9E60',
                        background: 'var(--bg-main, #0b0c10)',
                        surface: 'var(--bg-surface, #1a1c24)',
                        text: 'var(--text-main, #e2e8f0)'
                    },
                    borderRadius: {
                        '3xl': '1.5rem',
                    }
                }
            }
        }
    </script>
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <script src="_framework/blazor.web.js"></script>
    <script type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@1/index.js"></script>
    <script src="js/emoji-helper.js"></script>
    <script src="js/videoRecorder.js"></script>
    <script src="js/voiceRecorder.js"></script>
    <script>
        window.scrollToBottom = (element) => {
            if (element) {
                element.scrollTop = element.scrollHeight;
            }
        };

        window.registerEnterKeyHandler = (element, dotNetHelper) => {
            if (!element) return;
            
            // Try to find textarea in the element or its shadow root
            const textarea = element.querySelector('textarea') || 
                           (element.shadowRoot && element.shadowRoot.querySelector('textarea'));
            
            if (!textarea) return;

            textarea.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !e.ctrlKey && !e.shiftKey) {
                    e.preventDefault();
                    dotNetHelper.invokeMethodAsync('SendMessageFromJS');
                }
            });
        };
    </script>
</body>

</html>

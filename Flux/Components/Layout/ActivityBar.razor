@using Flux.Infrastructure.Client
@inject WorkspaceStateService WorkspaceState
@inject NavigationManager Navigation
@implements IDisposable

<div class="activity-bar">
    <div class="activity-top">
        <div class="workspace-brand-wrapper" @onclick="NavigateToWorkspaceHome" title="Go to Workspace Home">
            <span class="text-xs font-black tracking-tighter">F</span>
        </div>

        <div class="activity-item @(IsHome() ? "active" : "")" 
                title="Home" @onclick="NavigateToWorkspaceHome">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 v4a1 1 0 001 1m-6 0h6"></path></svg>
        </div>

        <div class="activity-item @(IsDms() ? "active" : "")" 
                title="Direct Messages" @onclick="NavigateToDms">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        </div>

        <div class="activity-item @(IsWeather() ? "active" : "")" 
                title="Weather" @onclick='() => Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/weather")'>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
        </div>

        <div class="activity-item @(IsWiki() ? "active" : "")" 
                title="Wikipedia" @onclick='() => Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/wiki")'>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
        </div>

        <div class="activity-item @(IsActivity() ? "active" : "")"
                title="Activity" style="position: relative;" @onclick='() => Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/activity")'>
            <svg class="w-6 h-6 @(WorkspaceState.UnreadNotificationCount > 0 ? "text-yellow-400 drop-shadow-[0_0_8px_rgba(250,204,21,0.8)] animate-pulse" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
            @if (WorkspaceState.UnreadNotificationCount > 0)
            {
                <div class="notification-badge">
                    @WorkspaceState.UnreadNotificationCount
                </div>
            }
        </div>        
        <div class="activity-item" title="More">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z"></path></svg>
        </div>
    </div>
    
    <div class="flex-1"></div>
    
    <div class="activity-bottom">
        <div id="profile-icon" class="profile-avatar-wrapper @(IsProfile() ? "ring-2 ring-blue-500" : "")" title="Profile" @onclick='() => Navigation.NavigateTo("/profile")'>
            @if (!string.IsNullOrEmpty(AvatarUrl))
            {
                <img src="@AvatarUrl" alt="Avatar" class="w-full h-full object-cover" />
            }
            else
            {
                @Initials
            }
            <div class="status-dot"></div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? AvatarUrl { get; set; }
    [Parameter] public string Initials { get; set; } = "U";
    [Parameter] public Guid CurrentUserId { get; set; }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private bool IsActive(string href) => Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith(href.TrimStart('/'));
    private bool IsHome() => IsActive("/workspace") && !IsDms() && !IsActivity() && !IsWeather() && !IsWiki();
    private bool IsWeather() => Navigation.Uri.Contains("/weather");
    private bool IsWiki() => Navigation.Uri.Contains("/wiki");
    private bool IsDms() => Navigation.Uri.Contains("/dms");
    private bool IsActivity() => Navigation.Uri.Contains("/activity");
    private bool IsProfile() => Navigation.Uri.Contains("/profile");

    private void NavigateToWorkspaceHome()
    {
        var workspaceId = WorkspaceState.CurrentWorkspaceId;
        
        // Try to get workspaceId from URL if state is not loaded
        if (workspaceId == null)
        {
            var uri = Navigation.Uri;
            var parts = uri.Split('/');
            int wsIndex = Array.IndexOf(parts, "workspace");
            if (wsIndex != -1 && wsIndex + 1 < parts.Length && Guid.TryParse(parts[wsIndex + 1], out Guid id))
            {
                workspaceId = id;
            }
        }

        if (workspaceId != null)
        {
            // If we have channels, go to the first one, otherwise go to the workspace home
            var firstChannel = WorkspaceState.Channels.FirstOrDefault(c => c.Type != ChannelType.Direct);
            if (firstChannel != null)
            {
                Navigation.NavigateTo($"/workspace/{workspaceId}/chat/{firstChannel.Id}");
            }
            else
            {
                Navigation.NavigateTo($"/workspace/{workspaceId}");
            }
        }
        else
        {
            Navigation.NavigateTo("/workspaces");
        }
    }

    private void NavigateToDms()
    {
        var workspaceId = WorkspaceState.CurrentWorkspaceId;
        
        if (workspaceId == null)
        {
            var uri = Navigation.Uri;
            var parts = uri.Split('/');
            int wsIndex = Array.IndexOf(parts, "workspace");
            if (wsIndex != -1 && wsIndex + 1 < parts.Length && Guid.TryParse(parts[wsIndex + 1], out Guid id))
            {
                workspaceId = id;
            }
        }

        if (workspaceId == null) 
        {
            Navigation.NavigateTo("/workspaces");
            return;
        }
        Navigation.NavigateTo($"/workspace/{workspaceId}/dms");
    }
}

@using Flux.Infrastructure.Client

<div class="section-title mt-6">
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3"/></svg>
    <span>Direct Messages</span>
</div>
<div class="space-y-0.5">
    @foreach (var member in Members)
    {
        if (member.Id == CurrentUserId) continue;

        <button @onclick="@(() => OnStartDM.InvokeAsync(member.Id))" class="nav-link w-full text-left">
            <div class="flex items-center gap-2">
                <div class="status-indicator @(member.Status?.ToLower() ?? "offline")"></div>
                <span class="truncate">@member.Username</span>
            </div>
        </button>
    }
</div>

@code {
    [Parameter] public List<MemberDto> Members { get; set; } = new();
    [Parameter] public Guid CurrentUserId { get; set; }
    [Parameter] public EventCallback<Guid> OnStartDM { get; set; }
}

@using Flux.Domain.Entities
@using Flux.Infrastructure.Client

<div class="section-title" @oncontextmenu="@(e => OnGroupContextMenu.InvokeAsync(e))" @oncontextmenu:preventDefault="true">
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3"/></svg>
    <span>Channels</span>
</div>
<div class="space-y-0.5">
    @foreach (var channel in Channels.Where(c => c.Type != ChannelType.Direct))
    {
        <div @oncontextmenu="@(e => OnChannelContextMenu.InvokeAsync((e, channel.Id, channel.Name)))" 
                @oncontextmenu:preventDefault="true"
                @oncontextmenu:stopPropagation="true">
            <a href="@($"/workspace/{WorkspaceId}/chat/{channel.Id}")" class="nav-link @(IsActive($"/workspace/{WorkspaceId}/chat/{channel.Id}") ? "active" : "")">
                @if (channel.Type == ChannelType.Private)
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                }
                else
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                }
                <span class="truncate flex-1">@channel.Name</span>
                @if (ActiveCallChannelIds.Contains(channel.Id))
                {
                    <div class="huddle-indicator">
                        <svg class="w-3 h-3 text-[#3E9E60] animate-pulse" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path></svg>
                    </div>
                }
            </a>
        </div>
    }
    <button @onclick="OnCreateChannel" class="add-channel-btn">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        <span>Add Channels</span>
    </button>
</div>

@code {
    [Parameter] public List<ChannelSummary> Channels { get; set; } = new();
    [Parameter] public Guid WorkspaceId { get; set; }
    [Parameter] public List<Guid> ActiveCallChannelIds { get; set; } = new();
    [Parameter] public string CurrentUrl { get; set; } = "";

    [Parameter] public EventCallback<MouseEventArgs> OnGroupContextMenu { get; set; }
    [Parameter] public EventCallback<(MouseEventArgs Args, Guid Id, string Name)> OnChannelContextMenu { get; set; }
    [Parameter] public EventCallback OnCreateChannel { get; set; }

    private bool IsActive(string url) => CurrentUrl.EndsWith(url);
}

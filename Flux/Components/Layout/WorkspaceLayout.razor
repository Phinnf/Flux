@inherits LayoutComponentBase
@layout MainLayout
@using Flux.Domain.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@using Flux.Infrastructure.Client
@inject WorkspaceStateService WorkspaceState
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="main-container text-white">
    <div class="slack-layout">
        <!-- Shared Activity Bar -->
        <ActivityBar AvatarUrl="@_avatarUrl" Initials="@_initials" CurrentUserId="@_currentUserId" />

        @if (Navigation.Uri.Contains("/dms/"))
        {
            <Flux.Components.Layout.DmSidebar />
        }
        else if (Navigation.Uri.Contains("/workspace/"))
        {
            <Flux.Components.Layout.WorkspaceSidebar />
        }

        <!-- Page Specific Content -->
        @Body
    </div>
</div>

@code {
    private Guid _currentUserId;
    private string? _avatarUrl;
    private string _initials = "U";
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        WorkspaceState.OnStateChanged += HandleStateChanged;
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                _currentUserId = id;
                if (WorkspaceState.CurrentWorkspaceId.HasValue && WorkspaceState.Channels.Count == 0)
                {
                    await WorkspaceState.LoadWorkspaceAsync(WorkspaceState.CurrentWorkspaceId.Value, _currentUserId);
                }
            }
        }

        UpdateUserAvatar();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chatHub"), options =>
            {
                options.AccessTokenProvider = async () =>
                {
                    try {
                        var token = await JS.InvokeAsync<string>("sessionStorage.getItem", "authToken");
                        return string.IsNullOrWhiteSpace(token) ? await JS.InvokeAsync<string>("localStorage.getItem", "authToken") : token;
                    } catch { return null; }
                };
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<NotificationDto>("ReceiveNotification", (notification) =>
        {
            if (!Navigation.Uri.Contains(notification.ChannelId.ToString()))
            {
                WorkspaceState.AddNotification(notification);
            }
            return Task.CompletedTask;
        });

        _hubConnection.On<string, string>("CallStarted", (channelId, callId) =>
        {
            if (Guid.TryParse(channelId, out var cid))
            {
                WorkspaceState.SetCallActive(cid, true);
            }
            return Task.CompletedTask;
        });

        _hubConnection.On<string>("CallEnded", (channelId) =>
        {
            if (Guid.TryParse(channelId, out var cid))
            {
                WorkspaceState.SetCallActive(cid, false);
            }
            return Task.CompletedTask;
        });

        try { await _hubConnection.StartAsync(); } catch { }
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnParametersSetAsync()
    {
        try {
            var uri = Navigation.Uri;
            var parts = uri.Split('/');
            int wsIndex = Array.IndexOf(parts, "workspace");
            if (wsIndex != -1 && wsIndex + 1 < parts.Length && Guid.TryParse(parts[wsIndex + 1], out Guid workspaceId))
            {
                if (_currentUserId != Guid.Empty || (await AuthStateProvider.GetAuthenticationStateAsync()).User.Identity?.IsAuthenticated == true)
                {
                    await WorkspaceState.LoadWorkspaceAsync(workspaceId, _currentUserId);
                    UpdateUserAvatar();
                }
            }
        } catch { }
    }

    private void UpdateUserAvatar()
    {
        var currentUser = WorkspaceState.Members.FirstOrDefault(m => m.Id == _currentUserId);
        _avatarUrl = currentUser?.AvatarUrl;
        if (!string.IsNullOrEmpty(currentUser?.Username))
        {
            _initials = currentUser.Username[0].ToString().ToUpper();
        }
    }

    public async ValueTask DisposeAsync()
    {
        WorkspaceState.OnStateChanged -= HandleStateChanged;
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}

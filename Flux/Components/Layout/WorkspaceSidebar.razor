@using Flux.Domain.Entities
@using Flux.Features.Channels.CreateChannel
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@using Flux.Infrastructure.Client
@using Flux.Components.Layout.Sidebar
@inject WorkspaceStateService WorkspaceState
@inject NavigationManager Navigation
@inject WorkspaceClientService WorkspaceService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<div class="workspace-sidebar">
    <div class="sidebar-header">
        <div class="flex items-center gap-2 w-full">
            <div class="workspace-name-display">
                <span class="font-black truncate">@(WorkspaceState.CurrentWorkspaceName ?? "Loading...")</span>
            </div>
            <button class="invite-btn ml-auto" @onclick="OpenInviteDialog" title="Invite People">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
            </button>
        </div>
    </div>
    
    <div class="sidebar-scrollable">
        <nav class="w-full px-3">
            <div class="space-y-1 mb-6">
                <a href="@($"/workspace/{WorkspaceState.CurrentWorkspaceId}/threads")" class="nav-link @(IsActive($"/workspace/{WorkspaceState.CurrentWorkspaceId}/threads") ? "active" : "")">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg>
                    <span>Threads</span>
                </a>
            </div>

            @if (WorkspaceState.CurrentWorkspaceId.HasValue)
            {
                <ChannelList Channels="WorkspaceState.Channels"
                             WorkspaceId="WorkspaceState.CurrentWorkspaceId.Value"
                             ActiveCallChannelIds="WorkspaceState.ActiveCallChannelIds.ToList()"
                             CurrentUrl="@Navigation.Uri"
                             OnGroupContextMenu="ShowGroupContextMenu"
                             OnChannelContextMenu="ShowContextMenu"
                             OnCreateChannel="OpenCreateDialog" />
                
                <MemberList Members="WorkspaceState.Members"
                            CurrentUserId="_currentUserId"
                            OnStartDM="StartDirectMessage" />
            }
        </nav>
    </div>
</div>

<!-- Context Menu & Dialogs -->
@if (_showContextMenu)
{
    <div class="fixed inset-0 z-[9998] bg-transparent" @onclick="() => _showContextMenu = false" @oncontextmenu:preventDefault="true" @oncontextmenu="() => _showContextMenu = false"></div>
    <div class="fixed z-[9999] context-menu" style="left: @(_mouseX)px; top: @(_mouseY)px;">
        <div class="flex flex-col py-1">
            <button class="context-menu-item" @onclick="OpenRenameDialog">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                <span>Rename Channel</span>
            </button>
            <button class="context-menu-item text-red-500 hover:bg-red-500/10" @onclick="OpenDeleteDialog">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-4v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                <span>Delete Channel</span>
            </button>
        </div>
    </div>
}

@if (_showGroupContextMenu)
{
    <div class="fixed inset-0 z-[9998] bg-transparent" @onclick="() => _showGroupContextMenu = false" @oncontextmenu:preventDefault="true" @oncontextmenu="() => _showGroupContextMenu = false"></div>
    <div class="fixed z-[9999] context-menu" style="left: @(_mouseX)px; top: @(_mouseY)px;">
        <div class="flex flex-col py-1">
            <button class="context-menu-item" @onclick="OpenCreateDialog">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                <span>Create Channel</span>
            </button>
        </div>
    </div>
}

@if (_showCreateDialog)
{
    <div class="fixed inset-0 z-[10000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @onclick="() => _showCreateDialog = false">
        <div class="glass-dialog w-full max-md:max-w-md bg-[#1a1a1d] border border-white/10 rounded-2xl p-6 shadow-2xl animate-in fade-in zoom-in duration-200" @onclick:stopPropagation>
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold text-white">Create a channel</h3>
                <button class="p-2 text-white/40 hover:text-white transition-colors" @onclick="() => _showCreateDialog = false">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            
            <p class="text-white/60 mb-6 text-sm">Channels are where your team communicates. They’re best when organized around a topic — #marketing, for example.</p>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-1.5 ml-1">Name</label>
                    <input type="text" @bind="_newChannelName" @bind:event="oninput" placeholder="e.g. plan-budget" 
                           class="w-full bg-white/5 border border-white/10 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all" />
                </div>
                
                <div class="flex items-center justify-between p-3 bg-white/5 rounded-xl border border-white/10">
                    <div>
                        <p class="text-sm font-bold text-white">Make private</p>
                        <p class="text-xs text-white/40">Only invited members can view</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" @bind="_isPrivate" class="sr-only peer">
                        <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white/40 after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600 peer-checked:after:bg-white"></div>
                    </label>
                </div>
            </div>
            
            <div class="flex justify-end mt-8">
                <button class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-bold rounded-lg transition-all shadow-lg shadow-blue-600/20" 
                        @onclick="CreateChannel" disabled="@(string.IsNullOrWhiteSpace(_newChannelName))">
                    Create
                </button>
            </div>
        </div>
    </div>
}

@if (_showRenameDialog)
{
    <div class="fixed inset-0 z-[10000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @onclick="() => _showRenameDialog = false">
        <div class="glass-dialog w-full max-w-md bg-[#1a1a1d] border border-white/10 rounded-2xl p-6 shadow-2xl" @onclick:stopPropagation>
            <h3 class="text-xl font-bold text-white mb-6">Rename this channel</h3>
            <input type="text" @bind="_newChannelName" class="w-full bg-white/5 border border-white/10 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50" />
            <div class="flex justify-end gap-3 mt-8">
                <button class="px-4 py-2 text-white/60 hover:text-white" @onclick="() => _showRenameDialog = false">Cancel</button>
                <button class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg" @onclick="RenameChannel">Save Changes</button>
            </div>
        </div>
    </div>
}

@if (_showDeleteDialog)
{
    <div class="fixed inset-0 z-[10000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @onclick="() => _showDeleteDialog = false">
        <div class="glass-dialog w-full max-w-md bg-[#1a1a1d] border border-white/10 rounded-2xl p-6 shadow-2xl" @onclick:stopPropagation>
            <h3 class="text-xl font-bold text-white mb-2">Delete #@_selectedChannelName?</h3>
            <p class="text-white/60 mb-8 leading-relaxed">When you delete #@_selectedChannelName, all of its messages will be removed from Flux immediately. This cannot be undone.</p>
            <div class="flex justify-end gap-3">
                <button class="px-4 py-2 text-white/60 hover:text-white" @onclick="() => _showDeleteDialog = false">Cancel</button>
                <button class="px-6 py-2 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg" @onclick="DeleteChannel">Delete Channel</button>
            </div>
        </div>
    </div>
}

@if (_showInviteDialog)
{
    <div class="fixed inset-0 z-[10000] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" @onclick="() => _showInviteDialog = false">
        <div class="glass-dialog w-full max-w-md bg-[#1a1a1d] border border-white/10 rounded-2xl p-6 shadow-2xl" @onclick:stopPropagation>
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold text-white">Invite people to @WorkspaceState.CurrentWorkspaceName</h3>
                <button class="p-2 text-white/40 hover:text-white transition-colors" @onclick="() => _showInviteDialog = false">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            
            <div class="space-y-6">
                <div>
                    <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-2 ml-1">Share this link with others</label>
                    <div class="flex gap-2">
                        <div class="flex-1 bg-white/5 border border-white/10 rounded-lg p-3 text-white text-sm truncate font-mono">
                            @GetInviteLink()
                        </div>
                        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-all flex items-center gap-2" @onclick="CopyInviteLink">
                            @if (_linkCopied)
                            {
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                <span>Copied</span>
                            }
                            else
                            {
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" /></svg>
                                <span>Copy</span>
                            }
                        </button>
                    </div>
                </div>

                <div class="relative">
                    <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-white/10"></div></div>
                    <div class="relative flex justify-center text-xs uppercase"><span class="bg-[#1a1a1d] px-2 text-white/20 tracking-widest">Or invite by email</span></div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-white/40 uppercase tracking-widest mb-1.5 ml-1">Email Address</label>
                    <input type="email" @bind="_inviteEmail" placeholder="name@work-email.com" 
                           class="w-full bg-white/5 border border-white/10 rounded-lg p-3 text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50" />
                </div>
            </div>
            
            <div class="flex justify-end mt-8">
                <button class="px-6 py-2.5 bg-white/5 hover:bg-white/10 text-white font-bold rounded-lg transition-all" 
                        @onclick="SendInvite" disabled="@(string.IsNullOrWhiteSpace(_inviteEmail))">
                    Send Email Invite
                </button>
            </div>
        </div>
    </div>
}

@code {
    private Guid _currentUserId;
    private bool _showContextMenu;
    private bool _showGroupContextMenu;
    private double _mouseX;
    private double _mouseY;
    private Guid _selectedChannelId;
    private string _selectedChannelName = "";
    
    private bool _showCreateDialog;
    private bool _showRenameDialog;
    private bool _showDeleteDialog;
    private bool _showInviteDialog;
    
    private string _newChannelName = "";
    private bool _isPrivate;
    private string _inviteEmail = "";
    private string _inviteCode = "";
    private bool _linkCopied = false;

    private string GetInviteLink() => string.IsNullOrEmpty(_inviteCode) ? "Generating..." : $"{Navigation.BaseUri}invite/{_inviteCode}";

    private async Task CopyInviteLink()
    {
        var link = GetInviteLink();
        if (link == "Generating...") return;
        
        var success = await JS.InvokeAsync<bool>("chatHelper.copyToClipboard", link);
        if (success)
        {
            _linkCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _linkCopied = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        WorkspaceState.OnStateChanged += HandleStateChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is { IsAuthenticated: true })
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier) ?? user.FindFirst("sub");
            if (idClaim != null && Guid.TryParse(idClaim.Value, out var id))
            {
                _currentUserId = id;
            }
        }
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        WorkspaceState.OnStateChanged -= HandleStateChanged;
    }

    private bool IsActive(string url)
    {
        return Navigation.Uri.EndsWith(url);
    }

    private void ShowContextMenu(MouseEventArgs e, Guid channelId, string channelName)
    {
        _mouseX = e.ClientX;
        _mouseY = e.ClientY;
        _selectedChannelId = channelId;
        _selectedChannelName = channelName;
        _showContextMenu = true;
    }

    private void ShowGroupContextMenu(MouseEventArgs e)
    {
        _mouseX = e.ClientX;
        _mouseY = e.ClientY;
        _showGroupContextMenu = true;
    }

    private void OpenCreateDialog()
    {
        _showGroupContextMenu = false;
        _newChannelName = "";
        _isPrivate = false;
        _showCreateDialog = true;
    }

    private async Task CreateChannel()
    {
        if (string.IsNullOrWhiteSpace(_newChannelName) || !WorkspaceState.CurrentWorkspaceId.HasValue) return;

        var request = new CreateChannelRequest(_newChannelName, null, _isPrivate ? ChannelType.Private : ChannelType.Public, _currentUserId);
        var result = await WorkspaceService.CreateChannelAsync(WorkspaceState.CurrentWorkspaceId.Value, request);
        
        if (result.IsSuccess && result.Value != null)
        {
            _showCreateDialog = false;
            Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/chat/{result.Value.Id}");
        }
    }

    private void OpenRenameDialog()
    {
        _showContextMenu = false;
        _newChannelName = _selectedChannelName;
        _showRenameDialog = true;
    }

    private async Task RenameChannel()
    {
        if (string.IsNullOrWhiteSpace(_newChannelName) || !WorkspaceState.CurrentWorkspaceId.HasValue) return;

        var result = await WorkspaceService.RenameChannelAsync(WorkspaceState.CurrentWorkspaceId.Value, _selectedChannelId, _newChannelName, _currentUserId);
        if (result.IsSuccess)
        {
            _showRenameDialog = false;
            await WorkspaceState.RefreshChannelsAsync(_currentUserId);
        }
    }

    private void OpenDeleteDialog()
    {
        _showContextMenu = false;
        _showDeleteDialog = true;
    }

    private async Task DeleteChannel()
    {
        if (!WorkspaceState.CurrentWorkspaceId.HasValue) return;

        var result = await WorkspaceService.DeleteChannelAsync(WorkspaceState.CurrentWorkspaceId.Value, _selectedChannelId, _currentUserId);
        if (result.IsSuccess)
        {
            _showDeleteDialog = false;
            await WorkspaceState.RefreshChannelsAsync(_currentUserId);
            Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}");
        }
    }

    private async Task OpenInviteDialog()
    {
        _inviteEmail = "";
        _inviteCode = "";
        _showInviteDialog = true;
        
        if (WorkspaceState.CurrentWorkspaceId.HasValue)
        {
            var result = await WorkspaceService.CreateInviteAsync(WorkspaceState.CurrentWorkspaceId.Value, _currentUserId, 72); // 3 days
            if (result.IsSuccess)
            {
                _inviteCode = result.Value;
                StateHasChanged();
            }
        }
    }

    [Inject] private Flux.Infrastructure.Services.IToastService ToastService { get; set; } = default!;

    private async Task SendInvite()
    {
        if (string.IsNullOrWhiteSpace(_inviteEmail) || !WorkspaceState.CurrentWorkspaceId.HasValue) return;

        var result = await WorkspaceService.SendInviteAsync(WorkspaceState.CurrentWorkspaceId.Value, _inviteEmail, _currentUserId);
        if (result.IsSuccess)
        {
            ToastService.ShowSuccess("Invite sent successfully!");
            _inviteEmail = "";
            _showInviteDialog = false;
        }
        else
        {
            ToastService.ShowError(result.Error);
        }
    }

    private async Task StartDirectMessage(Guid memberId)
    {
        if (!WorkspaceState.CurrentWorkspaceId.HasValue) return;

        var result = await WorkspaceService.GetOrCreateDirectChannelAsync(WorkspaceState.CurrentWorkspaceId.Value, _currentUserId, memberId);
        if (result.IsSuccess && result.Value != null)
        {
            Navigation.NavigateTo($"/workspace/{WorkspaceState.CurrentWorkspaceId}/dms/{result.Value.Id}");
        }
    }

    private void ShowContextMenu((MouseEventArgs Args, Guid Id, string Name) data)
    {
        ShowContextMenu(data.Args, data.Id, data.Name);
    }
}